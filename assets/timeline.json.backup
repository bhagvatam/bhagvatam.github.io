    "nodes": [
        {
            "chapter": 1,
            "phase": "advent",
            "hook": "Brahma and the demigods petition Vishnu to relieve Earth; Vasudeva weds Devaki; Kamsa hears the prophecy.",
            "hook_hindi": "ब्रह्मा और देवता पृथ्वी को राहत दिलाने के लिए विष्णु से प्रार्थना करते हैं; वसुदेव और देवकी का विवाह; कंस ने भविष्यवाणी सुनी।",
            "hook_gujarati": "બ્રહ્મા અને દેવતાઓ પૃથ્વીને મુક્ત કરવા માટે વિષ્ણુને વિનંતી કરે છે; વસુદેવ અને દેવકીના લગ્ન; કંસ ભવિષ્યવાણી સાંભળે છે."
        },
        {
            "chapter": 2,
            "phase": "advent",
            "hook": "Kamsa kills six newborns; the demigods praise Krishna already present in Devaki's womb.",
            "hook_hindi": "कंस छह नवजातों को मारता है; देवता देवकी के गर्भ में पहले से उपस्थित कृष्ण की स्तुति करते हैं।",
            "hook_gujarati": "કંસ છ નવજાત શિશુઓને મારી નાખે છે; દેવતાઓ દેવકીના ગર્ભમાં પહેલેથી જ બિરાજમાન શ્રીકૃષ્ણની સ્તુતિ કરે છે."
        },
        {
            "chapter": 3,
            "phase": "advent",
            "hook": "At midnight on Janmashtami, Krishna appears in four-armed form; Vasudeva carries Him across the Yamuna to Gokula.",
            "hook_hindi": "जन्माष्टमी की आधी रात को, कृष्ण चार भुजाओं वाले रूप में प्रकट होते हैं; वासुदेव उन्हें यमुना पार करके गोकुल ले जाते हैं।",
            "hook_gujarati": "જન્માષ્ટમીની મધ્યરાત્રિએ, કૃષ્ણ ચતુર્ભુજ સ્વરૂપે પ્રગટ થાય છે; વાસુદેવ તેમને યમુના પાર કરીને ગોકુળ લઈ જાય છે."
        },
        {
            "chapter": 4,
            "phase": "advent",
            "hook": "Yogamaya slips from Kamsa's grasp and reveals his killer is already born elsewhere.",
            "hook_hindi": "योगमाया कंस की पकड़ से छूटकर आकाशवाणी करती हैं कि उसका वध करने वाला कहीं और जन्म ले चुका है।",
            "hook_gujarati": "યોગમાયા કંસની પકડમાંથી છૂટીને આકાશવાણી કરે છે કે તેનો વધ કરનાર બાળક બીજે ક્યાંક જન્મ લઈ ચૂક્યો છે."
        },
        {
            "chapter": 5,
            "phase": "advent",
            "hook": "Nanda celebrates the birth-festival in Gokula and meets Vasudeva while paying taxes in Mathura.",
            "hook_hindi": "नन्द महाराज गोकुल में कृष्ण के जन्म का उत्सव मनाते हैं और मथुरा में कर चुकाते समय वसुदेव से मिलते हैं।",
            "hook_gujarati": "નંદ મહારાજ ગોકુળમાં કૃષ્ણના જન્મનો ઉત્સવ ઉજવે છે અને મથુરામાં કર ભરતી વખતે વસુદેવને મળે છે."
        },
        {
            "chapter": 6,
            "phase": "advent",
            "hook": "The poison-breasted demoness Putana is killed at infant Krishna's nursing.",
            "hook_hindi": "विषाक्त स्तनों वाली राक्षसी पूतना शिशु कृष्ण को दूध पिलाते समय मारी जाती है।",
            "hook_gujarati": "ઝેરી સ્તનો ધરાવતી રાક્ષસી પૂતના શિશુ કૃષ્ણને સ્તનપાન કરાવતી વખતે મૃત્યુ પામે છે."
        },
        {
            "chapter": 7,
            "phase": "advent",
            "hook": "Baby Krishna kicks over the cart-demon Shakatasura and strangles the whirlwind-demon Trinavarta.",
            "hook_hindi": "बाल कृष्ण ने शकटासुर (गाडा) को लात मारकर उलट दिया और बवंडर रूपी राक्षस तृणावर्त का गला घोंटकर उसका वध कर दिया।",
            "hook_gujarati": "બાલ કૃષ્ણે શકાસુર (ગાડા) ને લાત મારીને ઉલટાવી દીધું અને વંટોળિયા રૂપી રાક્ષસ તૃણાવર્તનું ગળું દબાવીને તેનો વધ કર્યો."
        },
        {
            "chapter": 8,
            "phase": "gokula",
            "hook": "Garga Muni names Krishna and Balarama; Yashoda sees the entire cosmos inside Krishna's mouth.",
            "hook_hindi": "गर्ग मुनि कृष्ण और बलराम का नामकरण करते हैं; यशोदा कृष्ण के मुख में संपूर्ण ब्रह्मांड देखती हैं।",
            "hook_gujarati": "ગર્ગ મુનિ કૃષ્ણ અને બલરામનું નામકરણ કરે છે; યશોદા કૃષ્ણના મુખમાં સમગ્ર બ્રહ્માંડ જુએ છે."
        },
        {
            "chapter": 9,
            "phase": "gokula",
            "hook": "Yashoda binds the butter-thief to a mortar — the Damodara lila.",
            "hook_hindi": "यशोदा ने मक्खन चुराने वाले को ओखल से बांधा — दामोदर लीला।",
            "hook_gujarati": "યશોદાએ માખણ ચોરનારને ઓખલ સાથે બાંધ્યા — દામોદર લીલા।"
        },
        {
            "chapter": 10,
            "phase": "gokula",
            "hook": "Krishna drags the mortar between two trees, liberating Kuvera's cursed sons."
        },
        {
            "chapter": 11,
            "phase": "gokula",
            "hook": "The cowherds move to Vrindavana; Krishna kills the calf-demon Vatsasura and the crane-demon Bakasura."
        },
        {
