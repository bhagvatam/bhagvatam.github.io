[
    {
        "id": 100101,
        "sloka": "10.1.1",
        "verse_id": 100101,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "King Parīkṣit said: My dear lord, you have elaborately described the dynasties of both the moon-god and the sun-god, with the exalted and wonderful character of their kings."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "राजा परीक्षित ने कहा: हे प्रभु, आपने सोमवंश और सूर्यवंश का विस्तार से वर्णन किया है, साथ ही उन दोनों वंशों के राजाओं के परम अद्भुत चरित्र भी सुनाए हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "રાજા પરીક્ષિતે કહ્યું: હે પ્રભુ, આપે ચંદ્રવંશ અને સૂર્યવંશનું વિસ્તારપૂર્વક વર્ણન કર્યું છે, તેમજ બંને વંશના રાજાઓના પરમ અદ્ભુત ચરિત્રો પણ સંભળાવ્યા છે."
            }
        }
    },
    {
        "id": 100102,
        "sloka": "10.1.2",
        "verse_id": 100102,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O most fortunate Śukadeva Gosvāmī, you have described the character of those kings who were devoted to dharma and who were always obedient to the infallible Supreme Personality of Godhead, Acyuta."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे परम भाग्यशाली शुकदेव गोस्वामी, आपने उन धर्मात्मा राजाओं के चरित्र का वर्णन किया है जो सदा धर्मपरायण थे और अच्युत भगवान श्रीकृष्ण के प्रति सदैव समर्पित रहते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે પરમ ભાગ્યશાળી શુકદેવ ગોસ્વામી, આપે તે ધર્માત્મા રાજાઓના ચરિત્રનું વર્ણન કર્યું છે જેઓ સદા ધર્મપરાયણ હતા અને અચ્યુત ભગવાન શ્રીકૃષ્ણ પ્રત્યે હંમેશા સમર્પિત રહેતા હતા."
            }
        }
    },
    {
        "id": 100103,
        "sloka": "10.1.3",
        "verse_id": 100103,
        "verseNumber": 3,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O learned teacher, you have also described the glorious activities of Lord Viṣṇu. In those accounts, the Supreme Lord of the universe descended in His partial expansion [as Balarāma] and in His original personal form [as Kṛṣṇa]."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे विद्वान गुरुदेव, आपने भगवान विष्णु की महिमामयी लीलाओं का भी वर्णन किया है। उन वृत्तांतों में, ब्रह्मांड के स्वामी भगवान ने अपने अंश (बलरामजी) और अपने मूल स्वरूप (श्रीकृष्ण) के रूप में अवतार लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે વિદ્વાન ગુરુદેવ, આપે ભગવાન વિષ્ણુની મહિમાવંત લીલાઓનું પણ વર્ણન કર્યું છે. તે વૃત્તાંતોમાં, બ્રહ્માંડના સ્વામી ભગવાને પોતાના અંશ (બલરામજી) અને પોતાના મૂળ સ્વરૂપ (શ્રીકૃષ્ણ) તરીકે અવતાર ધારણ કર્યો."
            }
        }
    },
    {
        "id": 100104,
        "sloka": "10.1.4",
        "verse_id": 100104,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Glorification of the Supreme Lord is sung by those who are completely free from material desires. It is the medicine for the disease of birth and death, and it is pleasing to both the ear and the mind. Therefore, who but a killer of animals (or a killer of his own soul) would avoid hearing such glorification?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान के गुणों का गान वे लोग करते हैं जो भौतिक इच्छाओं से पूर्णतः मुक्त हैं। यह जन्म-मृत्यु के रोग की औषधि है और कानों तथा मन को परम सुखद है। अतः, पशु के समान (अथवा आत्मघाती) व्यक्ति को छोड़कर कौन ऐसा होगा जो इस गुणगान को सुनने से विमुख रहे?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાનના ગુણોનું ગાન તેઓ કરે છે જેઓ ભૌતિક ઈચ્છાઓથી પૂર્ણતઃ મુક્ત છે. આ જન્મ-મૃત્યુના રોગની ઔષધિ છે અને કાન તથા મનને પરમ સુખદ છે. આથી, પશુ સમાન (અથવા આત્મઘાતી) વ્યક્તિને છોડીને બીજું કોણ એવું હશે જે આ ગુણગાનને સાંભળવાથી વિમુખ રહે?"
            }
        }
    },
    {
        "id": 100105,
        "sloka": "10.1.5-7",
        "verse_id": 100105,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My grandfathers [the Pāṇḍavas] were able to cross the insurmountable ocean of the Kaurava army, which was filled with great chariot fighters like Bhīṣma who were like timiṅgila ocean monsters, because they took shelter of the boat of Kṛṣṇa's lotus feet, easily crossing as if it were a calf's hoofprint."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे दादाजी (पांडव) भीष्म जैसे महान योद्धाओं रूपी तिमिंगिल (विशाल जलजीवों) से भरे कौरव-सेना के दुर्गम महासागर को आसानी से पार कर गए, जैसे बछड़े के खुर के गड्ढे को पार किया जाता है, क्योंकि उन्होंने भगवान श्रीकृष्ण के चरणकमलों रूपी नौका का आश्रय लिया था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા દાદાજીઓ (પાંડવો) ભીષ્મ જેવા મહાન યોદ્ધાઓ રૂપી તિમિંગિલ (વિશાળ જળજીવો) થી ભરેલા કૌરવ-સેનાના દુર્ગમ મહાસાગરને સરળતાથી પાર કરી ગયા, જેમ વાછરડાના ખરીના ખાડાને પાર કરાય છે, કારણ કે તેમણે ભગવાન શ્રીકૃષ્ણના ચરણકમળ રૂપી નૌકાનો આશ્રય લીધો હતો."
            }
        }
    },
    {
        "id": 100108,
        "sloka": "10.1.8",
        "verse_id": 100108,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My dear Śukadeva Gosvāmī, you have already explained that Saṅkarṣaṇa, who belongs to the second quadruple, appeared as the son of Rohiṇī named Balarāma. If Balarāma was not transferred from one body to another, how is it possible that He was first in the womb of Devakī and then in the womb of Rohiṇī? Kindly explain this to me."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रिय शुकदेव गोस्वामी, आप पहले ही बता चुके हैं कि संकर्षण, जो चतुर्व्यूह के द्वितीय पुरुष हैं, रोहिणी के पुत्र के रूप में प्रकट हुए। यदि बलरामजी एक शरीर से दूसरे शरीर में स्थानांतरित नहीं हुए थे, तो यह कैसे संभव है कि वे पहले देवकी के गर्भ में थे और फिर रोहिणी के गर्भ में आए? कृपया मुझे यह समझाइए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા પ્રિય શુકદેવ ગોસ્વામી, તમે પહેલા જ જણાવી ચૂક્યા છો કે સંકર્ષણ, જે ચતુર્વ્યૂહના દ્વિતીય પુરુષ છે, રોહિણીના પુત્ર તરીકે પ્રગટ થયા હતા. જો બલરામજી એક શરીરમાંથી બીજા શરીરમાં સ્થાનાંતરિત નહોતા થયા, તો તે કેવી રીતે શક્ય છે કે તેઓ પહેલા દેવકીના ગર્ભમાં હતા અને પછી રોહિણીના ગર્ભમાં આવ્યા? કૃપા કરીને મને આ સમજાવો."
            }
        }
    },
    {
        "id": 100109,
        "sloka": "10.1.9",
        "verse_id": 100109,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Why did Kṛṣṇa, the Supreme Personality of Godhead, leave the house of His father, Vasudeva, and transfer Himself to the house of Nanda in Vṛndāvana? Where did the Lord, the master of the Yadu dynasty, live with His relatives in Vṛndāvana?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान श्रीकृष्ण ने अपने पिता वासुदेव का घर क्यों छोड़ा और स्वयं को वृन्दावन में नन्द महाराज के घर में क्यों स्थानांतरित किया? यदुवंश के स्वामी भगवान अपने संबंधियों के साथ वृन्दावन में कहाँ रहते थे?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન શ્રીકૃષ્ણે તેમના પિતા વાસુદેવનું ઘર કેમ છોડ્યું અને સ્વયંને વૃંદાવનમાં નંદ મહારાજના ઘરે કેમ સ્થાનાંતરિત કર્યા? યાદવકુળના સ્વામી ભગવાન તેમના સંબંધીઓ સાથે વૃંદાવનમાં ક્યાં રહેતા હતા?"
            }
        }
    },
    {
        "id": 100110,
        "sloka": "10.1.10",
        "verse_id": 100110,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Kṛṣṇa lived both in Vṛndāvana and in Mathurā. What did He do there? Why did He kill Kaṁsa, His mother’s brother? Such killing is not at all sanctioned in the śāstras."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान श्रीकृष्ण वृन्दावन और मथुरा, दोनों स्थानों पर रहे। वहाँ उन्होंने क्या लीलाएं कीं? उन्होंने अपनी माता के भाई कंस का वध क्यों किया? शास्त्रों में ऐसी हिंसा का कहीं भी अनुमोदन नहीं है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન શ્રીકૃષ્ણ વૃંદાવન અને મથુરા, બંને સ્થાનો પર રહ્યા. ત્યાં તેમણે કઈ લીલાઓ કરી? તેમણે તેમની માતાના ભાઈ કંસનો વધ કેમ કર્યો? શાસ્ત્રોમાં આવી હિંસાનું ક્યાંય અનુમોદન નથી."
            }
        }
    },
    {
        "id": 100111,
        "sloka": "10.1.11",
        "verse_id": 100111,
        "verseNumber": 11,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kṛṣṇa, the Supreme Personality of Godhead, has no material body, yet He appears as a human being. For how many years did He live with the descendants of Vṛṣṇi? How many wives did He marry, and for how many years did He live in Dvārakā?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान श्रीकृष्ण का कोई भौतिक शरीर नहीं है, फिर भी वे मनुष्य के रूप में प्रकट होते हैं। वे वृष्णि वंश के लोगों के साथ कितने वर्षों तक रहे? उन्होंने कितनी पत्नियों से विवाह किया और वे द्वारका में कितने वर्षों तक रहे?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન શ્રીકૃષ્ણને કોઈ ભૌતિક શરીર નથી, તેમ છતાં તેઓ મનુષ્યના રૂપમાં પ્રગટ થાય છે. તેઓ વૃષ્ણિ વંશના લોકો સાથે કેટલા વર્ષો સુધી રહ્યા? તેમણે કેટલી પત્નીઓ સાથે લગ્ન કર્યા અને તેઓ દ્વારકામાં કેટલા વર્ષો સુધી રહ્યા?"
            }
        }
    },
    {
        "id": 100112,
        "sloka": "10.1.12",
        "verse_id": 100112,
        "verseNumber": 12,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O great sage, who know everything about Kṛṣṇa, please describe in detail all the activities of which I have inquired and also those of which I have not, for I have full faith and am very eager to hear of them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे महान ऋषि, जो श्रीकृष्ण के विषय में सब कुछ जानते हैं, कृपया उन सभी क्रियाकलापों का विस्तार से वर्णन करें जिनके बारे में मैंने पूछा है और उन गतिविधियों का भी जिनके बारे में मैंने नहीं पूछा है, क्योंकि मुझे आप पर पूर्ण विश्वास है और मैं इन्हें सुनने के लिए अति उत्सुक हूँ।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે મહાન ઋષિ, જેઓ શ્રીકૃષ્ણના વિષયમાં બધું જ જાણે છે, કૃપા કરીને તે તમામ ક્રિયાકલાપોનું વિસ્તારપૂર્વક વર્ણન કરો જેમના વિશે મેં પૂછ્યું છે અને તે પ્રવૃત્તિઓનું પણ જેમના વિશે મેં નથી પૂછ્યું, કારણ કે મને તમારા પર પૂર્ણ વિશ્વાસ છે અને હું તેમને સાંભળવા માટે અતિ ઉત્સુક છું."
            }
        }
    },
    {
        "id": 100113,
        "sloka": "10.1.13",
        "verse_id": 100113,
        "verseNumber": 13,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Because of my vow on the verge of death, I have given up even drinking water, yet because I am drinking the nectar of topics about Kṛṣṇa, which is flowing from the lotus mouth of your Lordship, my hunger and thirst, which are extremely difficult to bear, cannot hinder me."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मृत्यु के कगार पर ली गई अपनी प्रतिज्ञा के कारण मैंने जल का त्याग कर दिया है, फिर भी चूँकि मैं भगवान श्रीकृष्ण के अमृतमयी विषयों का पान कर रहा हूँ, जो आपके मुख-कमल से प्रवाहित हो रहे हैं, अतः मेरी भूख और प्यास, जो सहन करनी अत्यंत कठिन हैं, मुझे बाधा नहीं पहुँचा पा रही हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મૃત્યુના આરે મારી પ્રતિજ્ઞાને લીધે, મેં પાણીનો પણ ત્યાગ કર્યો છે, તેમ છતાં હું શ્રીકૃષ્ણના અમૃતમય વિષયોનું પાન કરી રહ્યો છું, જે તમારા મુખારવિંદમાંથી વહી રહ્યા છે, તેથી મારી અત્યંત કષ્ટદાયક ભૂખ અને તરસ મને રોકી શકતી નથી."
            }
        }
    },
    {
        "id": 100114,
        "sloka": "10.1.14",
        "verse_id": 100114,
        "verseNumber": 14,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Sūta Gosvāmī said: O son of Bhṛgu, after Śukadeva Gosvāmī, the most respectable devotee, the son of Vyāsadeva, heard the pious questions of Mahārāja Parīkṣit, he thanked the King with great respect. Then he began to discourse on topics concerning Kṛṣṇa, which are the remedy for all sufferings in this Age of Kali."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सूत गोस्वामी ने कहा: हे भृगु-नंदन, जब व्यासदेव के पुत्र, परम आदरणीय भक्त शुकदेव गोस्वामी ने महाराज परीक्षित के पवित्र प्रश्न सुने, तो उन्होंने महाराज का बड़े आदर के साथ अभिनन्दन किया। तत्पश्चात उन्होंने भगवान श्रीकृष्ण से संबंधित विषयों पर प्रवचन देना प्रारम्भ किया, जो इस कलियुग के समस्त कष्टों का एकमात्र उपचार है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "સૂત ગોસ્વામીએ કહ્યું: હે ભૃગુનંદન, જ્યારે વ્યાસદેવના પુત્ર, પરમ આદરણીય ભક્ત શુકદેવ ગોસ્વામીએ મહારાજ પરીક્ષિતના પવિત્ર પ્રશ્નો સાંભળ્યા, ત્યારે તેમણે મહારાજનો મોટા આદર સાથે આભાર માન્યો. ત્યારબાદ તેમણે શ્રીકૃષ્ણને લગતા વિષયો પર પ્રવચન આપવાનું શરૂ કર્યું, જે આ કલિયુગના તમામ દુઃખોનો ઉપાય છે."
            }
        }
    },
    {
        "id": 100115,
        "sloka": "10.1.15",
        "verse_id": 100115,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śrīla Śukadeva Gosvāmī said: O Your Majesty, best of all saintly kings, because you are greatly attracted to topics of Vāsudeva, it is certain that your intelligence is firmly fixed in spiritual understanding, which is the only true goal for humanity. Because that attraction is unceasing, it is certainly sublime."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "श्रील शुकदेव गोस्वामी ने कहा: हे महाराज, सभी संत-नरेशों में सर्वश्रेष्ठ! चूँकि आप भगवान वासुदेव के विषयों में अत्यधिक आसक्त हैं, यह निश्चित है कि आपकी बुद्धि आध्यात्मिक बोध में दृढ़तापूर्वक स्थित है, जो मानव जीवन का एकमात्र वास्तविक लक्ष्य है। चूँकि आपका यह आकर्षण अनवरत है, अतः यह निश्चित रूप से अत्यंत उदात्त है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શ્રીલ શુકદેવ ગોસ્વામીએ કહ્યું: હે મહારાજ, સર્વ સંત-નરેશોમાં શ્રેષ્ઠ! કારણ કે તમે ભગવાન વાસુદેવના વિષયોમાં અત્યંત આસક્ત છો, તે નિશ્ચિત છે કે તમારી બુદ્ધિ આધ્યાત્મિક જ્ઞાનમાં દ્રઢપણે સ્થિર છે, જે માનવ જીવનનું એકમાત્ર સાચું લક્ષ્ય છે. કારણ કે આ આકર્ષણ અવિરત છે, તે ચોક્કસપણે ઉત્કૃષ્ટ છે."
            }
        }
    },
    {
        "id": 100116,
        "sloka": "10.1.16",
        "verse_id": 100116,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The Ganges, emanating from the toe of Lord Viṣṇu, purifies the three worlds, the upper, middle and lower planetary systems. Similarly, when one asks questions about the pastimes and characteristics of Lord Vāsudeva, Kṛṣṇa, three varieties of men are purified: the speaker or preacher, he who inquires, and the people in general who listen."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान विष्णु के चरण-कमलों से निकलने वाली गंगाजी तीनों लोकों—ऊर्ध्व, मध्य और अधो लोकों—को शुद्ध करती हैं। इसी प्रकार, जब कोई भगवान वासुदेव श्रीकृष्ण की लीलाओं और उनके गुणों के विषय में प्रश्न पूछता है, तो तीन प्रकार के व्यक्ति शुद्ध हो जाते हैं: वक्ता, जिज्ञासु और सुनने वाले जनसामान्य।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન વિષ્ણુના ચરણકમળમાંથી નીકળતી ગંગા ત્રણેય લોક—ઉર્ધ્વ, મધ્ય અને અધો લોક—ને શુદ્ધ કરે છે. તેવી જ રીતે, જ્યારે કોઈ ભગવાન વાસુદેવ શ્રીકૃષ્ણની લીલાઓ અને તેમના ગુણો વિશે પ્રશ્ન પૂછે છે, ત્યારે ત્રણ પ્રકારના લોકો શુદ્ધ થાય છે: વક્તા, જિજ્ઞાસુ અને સાંભળનાર સામાન્ય જન."
            }
        }
    },
    {
        "id": 100117,
        "sloka": "10.1.17",
        "verse_id": 100117,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Once when mother earth was overburdened by hundreds of thousands of military phalanxes of various conceited demons dressed like kings, she approached Lord Brahmā for relief."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक समय जब पृथ्वी माता राजाओं का वेष धारण करने वाले अनेक अहंकारी असुरों की विशाल सेनाओं के भार से अत्यधिक पीड़ित हो गई थीं, तो वे राहत पाने के लिए भगवान ब्रह्मा के पास गईं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક સમયે જ્યારે પૃથ્વી માતા રાજાઓનો વેશ ધારણ કરનારા અનેક અહંકારી અસુરોની વિશાળ સેનાઓના ભારથી અત્યંત પીડિત થઈ ગઈ હતી, ત્યારે તે રાહત મેળવવા માટે ભગવાન બ્રહ્મા પાસે ગઈ."
            }
        }
    },
    {
        "id": 100118,
        "sloka": "10.1.18",
        "verse_id": 100118,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Mother earth assumed the form of a cow. Very much distressed, with tears in her eyes, she appeared before Lord Brahmā and told him about her misfortune."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "पृथ्वी माता ने गौ का रूप धारण किया। अत्यंत व्यथित होकर और नेत्रों में आँसू भरकर, वे भगवान ब्रह्मा के समक्ष उपस्थित हुईं और उन्हें अपने दुर्भाग्य के विषय में बताया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પૃથ્વી માતાએ ગાયનું રૂપ ધારણ કર્યું. અત્યંત વ્યથિત થઈને અને આંખોમાં આંસુ ભરીને, તે ભગવાન બ્રહ્મા સમક્ષ ઉપસ્થિત થઈ અને તેમને પોતાના દુર્ભાગ્ય વિશે જણાવ્યું."
            }
        }
    },
    {
        "id": 100119,
        "sloka": "10.1.19",
        "verse_id": 100119,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Thereafter, having heard of the distress of mother earth, Lord Brahmā, with mother earth, Lord Śiva and all the other demigods, approached the shore of the Ocean of Milk."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तदनन्तर, पृथ्वी माता की व्यथा सुनकर, भगवान ब्रह्मा पृथ्वी देवी, भगवान शिव और अन्य समस्त देवताओं के साथ क्षीर सागर के तट पर पहुँचे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ત્યારબાદ, પૃથ્વી માતાની વ્યથા સાંભળીને, ભગવાન બ્રહ્મા, પૃથ્વી દેવી, ભગવાન શિવ અને અન્ય તમામ દેવતાઓ સાથે ક્ષીરસાગરના તટ પર પહોંચ્યા."
            }
        }
    },
    {
        "id": 100120,
        "sloka": "10.1.20",
        "verse_id": 100120,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After reaching the shore of the Ocean of Milk, the demigods worshiped the Supreme Personality of Godhead, Lord Viṣṇu, the master of the whole universe, the supreme God of all gods, who provides for everyone and diminishes everyone’s suffering. With great attention, they worshiped Lord Viṣṇu, who lies on the Ocean of Milk, by reciting the Vedic mantras known as the Puruṣa-sūkta."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "क्षीर सागर के तट पर पहुँचकर, देवताओं ने समस्त ब्रह्मांड के स्वामी, सभी देवों के सर्वोच्च आराध्य, भगवान विष्णु की स्तुति की, जो सबका भरण-पोषण करते हैं और सबके दुःखों का निवारण करते हैं। बड़े ध्यानपूर्वक उन्होंने क्षीरशायी भगवान विष्णु की 'पुरुष-सूक्त' नामक वैदिक मंत्रों द्वारा वंदना की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ક્ષીરસાગરના તટ પર પહોંચીને, દેવતાઓએ સમગ્ર બ્રહ્માંડના સ્વામી, સર્વ દેવોના સર્વોચ્ચ આરાધ્ય, ભગવાન વિષ્ણુની સ્તુતિ કરી, જે સૌનું ભરણપોષણ કરે છે અને સૌના દુઃખનું નિવારણ કરે છે. ખૂબ જ ધ્યાનપૂર્વક તેમણે ક્ષીરશાયી ભગવાન વિષ્ણુની 'પુરુષ-સૂક્ત' નામના વૈદિક મંત્રો દ્વારા વંદના કરી."
            }
        }
    },
    {
        "id": 100121,
        "sloka": "10.1.21",
        "verse_id": 100121,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "While in trance, Lord Brahmā heard the words of Lord Viṣṇu vibrating in the sky. Thus he told the demigods: O demigods, hear from me the order of Kṣīrodakaśāyī Viṣṇu, the Supreme Person, and execute it attentively without delay."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "समाधि की अवस्था में, भगवान ब्रह्मा ने आकाशवाणी के रूप में भगवान विष्णु के शब्दों को सुना। तत्पश्चात उन्होंने देवताओं से कहा: हे देवताओं, क्षीरोदकशायी भगवान विष्णु, जो परम पुरुष हैं, उनका आदेश मुझसे सुनो और बिना किसी विलंब के ध्यानपूर्वक उसका पालन करो।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "સમાધિની અવસ્થામાં, ભગવાન બ્રહ્માએ આકાશવાણીના રૂપમાં ભગવાન વિષ્ણુના શબ્દો સાંભળ્યા. ત્યારબાદ તેમણે દેવતાઓને કહ્યું: હે દેવતાઓ, ક્ષીરોદકશાયી ભગવાન વિષ્ણુ, જે પરમ પુરુષ છે, તેમનો આદેશ મારી પાસેથી સાંભળો અને વિના વિલંબે ધ્યાનપૂર્વક તેનું પાલન કરો."
            }
        }
    },
    {
        "id": 100122,
        "sloka": "10.1.22",
        "verse_id": 100122,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Brahmā informed the demigods: Before we submitted our petition to the Lord, He was already aware of the distress on earth. Consequently, for as long as the Lord moves on earth to diminish its burden by His own potency in the form of time, all of you demigods should appear through plenary portions as sons and grandsons in the family of the Yadus."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान ब्रह्मा ने देवताओं को सूचित किया: हमारे भगवान के समक्ष याचना प्रस्तुत करने से पूर्व ही वे पृथ्वी के कष्टों से अवगत थे। अतः, जब तक भगवान काल के रूप में अपनी शक्ति द्वारा पृथ्वी का भार कम करने के लिए यहाँ विद्यमान हैं, आप सभी देवता यदुवंश में पुत्रों और पौत्रों के रूप में अपने अंशावतारों के साथ प्रकट हों।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બ્રહ્માએ દેવતાઓને સૂચિત કર્યા: આપણા ભગવાન સમક્ષ યાચના પ્રસ્તુત કરતા પહેલા જ તેઓ પૃથ્વીના કષ્ટોથી વાકેફ હતા. અતઃ, જ્યાં સુધી ભગવાન કાળના રૂપમાં પોતાની શક્તિ દ્વારા પૃથ્વીનો ભાર ઓછો કરવા માટે અહીં વિદ્યમાન છે, તમે બધા દેવતાઓ યદુવંશમાં પુત્રો અને પૌત્રોના રૂપમાં તમારા અંશાવતારો સાથે પ્રગટ થાઓ."
            }
        }
    },
    {
        "id": 100123,
        "sloka": "10.1.23",
        "verse_id": 100123,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The Supreme Personality of Godhead, Śrī Kṛṣṇa, who has full potency, will personally appear as the son of Vasudeva. Therefore all the wives of the demigods should also appear in order to satisfy Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान श्रीकृष्ण, जो पूर्ण ऐश्वर्य से युक्त हैं, व्यक्तिगत रूप से वासुदेव के पुत्र के रूप में प्रकट होंगे। अतः देवताओं की सभी पत्नियों को भी उन्हें संतुष्ट करने के लिए प्रकट होना चाहिए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન શ્રીકૃષ્ણ, જેઓ પૂર્ણ ઐશ્વર્યથી યુક્ત છે, તેઓ વ્યક્તિગત રીતે વાસુદેવના પુત્ર તરીકે પ્રગટ થશે. તેથી દેવતાઓની તમામ પત્નીઓએ પણ તેમને સંતુષ્ટ કરવા માટે પ્રગટ થવું જોઈએ."
            }
        }
    },
    {
        "id": 100124,
        "sloka": "10.1.24",
        "verse_id": 100124,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The foremost manifestation of Kṛṣṇa is Saṅkarṣaṇa, who is known as Ananta. He is the origin of all incarnations within this material world. Previous to the appearance of Lord Kṛṣṇa, this original Saṅkarṣaṇa will appear as Baladeva, just to please the Supreme Lord Kṛṣṇa in His transcendental pastimes."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण की आदि अभिव्यक्ति संकर्षण हैं, जिन्हें अनंत के नाम से जाना जाता है। वे इस भौतिक संसार के समस्त अवतारों के मूल हैं। भगवान श्रीकृष्ण के प्रकट होने से पूर्व, यह मूल संकर्षण, भगवान श्रीकृष्ण की दिव्य लीलाओं में उन्हें प्रसन्न करने हेतु, बलदेव के रूप में प्रकट होंगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણનું આદિ સ્વરૂપ સંકર્ષણ છે, જેમને અનંત તરીકે ઓળખવામાં આવે છે. તેઓ આ ભૌતિક જગતના તમામ અવતારોના મૂળ છે. ભગવાન શ્રીકૃષ્ણના પ્રાગટ્ય પૂર્વે, આ મૂળ સંકર્ષણ, ભગવાન શ્રીકૃષ્ણની દિવ્ય લીલાઓમાં તેમને પ્રસન્ન કરવા માટે, બલદેવ તરીકે પ્રગટ થશે."
            }
        }
    },
    {
        "id": 100125,
        "sloka": "10.1.25",
        "verse_id": 100125,
        "verseNumber": 25,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The potency of the Lord, known as viṣṇu-māyā, who is as good as the Supreme Personality of Godhead, will also appear with Lord Kṛṣṇa. This potency, acting in different capacities, captivates all the worlds, both material and spiritual. At the request of her master, she will appear with her different potencies in order to execute the work of the Lord."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान की शक्ति, जो विष्णु-माया के नाम से जानी जाती है और जो साक्षात् भगवान के समान ही दिव्य है, वे भी भगवान श्रीकृष्ण के साथ प्रकट होंगी। यह शक्ति, विभिन्न क्षमताओं में कार्य करते हुए, भौतिक और आध्यात्मिक दोनों ही संसारों को मोहित करती है। अपने स्वामी के अनुरोध पर, वे भगवान के कार्यों को संपन्न करने के लिए अपनी विभिन्न शक्तियों के साथ प्रकट होंगी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાનની શક્તિ, જે વિષ્ણુ-માયા તરીકે ઓળખાય છે અને જે સાક્ષાત્ ભગવાનના સમાન જ દિવ્ય છે, તેઓ પણ ભગવાન શ્રીકૃષ્ણની સાથે પ્રગટ થશે. આ શક્તિ, વિવિધ ક્ષમતાઓમાં કાર્ય કરીને, ભૌતિક અને આધ્યાત્મિક બંને વિશ્વને મોહિત કરે છે. પોતાના સ્વામીના આદેશ અનુસાર, તેઓ ભગવાનના કાર્યને સિદ્ધ કરવા માટે પોતાની વિવિધ શક્તિઓ સાથે પ્રગટ થશે."
            }
        }
    },
    {
        "id": 100126,
        "sloka": "10.1.26",
        "verse_id": 100126,
        "verseNumber": 26,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī continued: After thus advising the demigods and pacifying mother earth, the very powerful Lord Brahmā, who is the master of all other Prajāpatis and is therefore known as Prajāpati-pati, returned to his own abode, Brahmaloka."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: देवताओं को इस प्रकार परामर्श देने और पृथ्वी माता को सांत्वना प्रदान करने के पश्चात, अत्यंत शक्तिशाली भगवान ब्रह्मा, जो अन्य समस्त प्रजापतियों के स्वामी हैं और इसलिए प्रजापति-पति कहलाते हैं, अपने निवास स्थान ब्रह्मलोक लौट गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: દેવતાઓને આ પ્રમાણે પરામર્શ આપ્યા પછી અને પૃથ્વી માતાને સાંત્વના આપ્યા બાદ, અત્યંત શક્તિશાળી ભગવાન બ્રહ્મા, જેઓ અન્ય તમામ પ્રજાપતિઓના સ્વામી છે અને તેથી પ્રજાપતિ-પતિ તરીકે ઓળખાય છે, તેઓ પોતાના નિવાસસ્થાન બ્રહ્મલોક પાછા ફર્યા."
            }
        }
    },
    {
        "id": 100127,
        "sloka": "10.1.27",
        "verse_id": 100127,
        "verseNumber": 27,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Formerly, Śūrasena, the chief of the Yadu dynasty, had gone to live in the city of Mathurā. There he enjoyed the places known as Māthura and Śūrasena."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "पूर्व काल में, यदु वंश के प्रमुख शूरसेन, मथुरा नगर में निवास करने गए थे। वहाँ उन्होंने मथुरा और शूरसेन नामक प्रदेशों का शासन किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પૂર્વ કાળમાં, યદુ વંશના મુખ્ય શૂરસેન મથુરા નગરમાં નિવાસ કરવા ગયા હતા. ત્યાં તેમણે મથુરા અને શૂરસેન નામના પ્રદેશોનું શાસન કર્યું હતું."
            }
        }
    },
    {
        "id": 100128,
        "sloka": "10.1.28",
        "verse_id": 100128,
        "verseNumber": 28,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Since that time, the city of Mathurā had been the capital of all the kings of the Yadu dynasty. The city and district of Mathurā are very intimately connected with Kṛṣṇa, for Lord Kṛṣṇa lives there eternally."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उस समय से मथुरा नगर यदु वंश के समस्त राजाओं की राजधानी रही है। मथुरा नगर और वह क्षेत्र भगवान श्रीकृष्ण से अत्यंत घनिष्ठता से जुड़े हुए हैं, क्योंकि भगवान श्रीकृष्ण वहाँ शाश्वत रूप से निवास करते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે સમયથી મથુરા નગર યદુ વંશના તમામ રાજાઓની રાજધાની રહી છે. મથુરા નગર અને તે ક્ષેત્ર ભગવાન શ્રીકૃષ્ણ સાથે અત્યંત ગાઢ રીતે જોડાયેલા છે, કારણ કે ભગવાન શ્રીકૃષ્ણ ત્યાં સદૈવ નિવાસ કરે છે."
            }
        }
    },
    {
        "id": 100129,
        "sloka": "10.1.29",
        "verse_id": 100129,
        "verseNumber": 29,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Some time ago, Vasudeva, who belonged to the demigod family [or to the Śūra dynasty], married Devakī. After the marriage, he mounted his chariot to return home with his newly married wife."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कुछ समय पूर्व, वासुदेव ने, जो देवतुल्य परिवार (अथवा शूर वंश) से थे, देवकी से विवाह किया। विवाह के उपरांत, वे अपनी नवविवाहिता पत्नी के साथ घर लौटने के लिए रथ पर आरूढ़ हुए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "થોડા સમય પૂર્વે, વાસુદેવે, જેઓ દેવતુલ્ય પરિવાર (અથવા શૂર વંશ) ના હતા, તેમણે દેવકી સાથે લગ્ન કર્યા. લગ્ન બાદ, તેઓ પોતાની નવવધૂ સાથે ઘરે પરત ફરવા માટે રથમાં સવાર થયા."
            }
        }
    },
    {
        "id": 100130,
        "sloka": "10.1.30",
        "verse_id": 100130,
        "verseNumber": 30,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kaṁsa, the son of King Ugrasena, in order to please his sister Devakī on the occasion of her marriage, took charge of the reins of the horses and became the chariot driver. He was surrounded by hundreds of golden chariots."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "राजा उग्रसेन के पुत्र कंस ने, अपनी बहन देवकी को उनके विवाह के अवसर पर प्रसन्न करने हेतु, घोड़ों की लगाम थाम ली और स्वयं सारथी बन गया। वह सैकड़ों स्वर्ण रथों से घिरा हुआ था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "રાજા ઉગ્રસેનનો પુત્ર કંસ, પોતાની બહેન દેવકીને તેના વિવાહના અવસરે પ્રસન્ન કરવા માટે, ઘોડાની લગામ પોતાના હાથમાં લઈ રથનો સારથી બન્યો. તે સમયે તે સેંકડો સુવર્ણ રથોથી ઘેરાયેલો હતો."
            }
        }
    },
    {
        "id": 100131,
        "sloka": "10.1.31-32",
        "verse_id": 100131,
        "verseNumber": 31,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Devakī’s father, King Devaka, was very much affectionate to his daughter. Therefore, while she and her husband were leaving home, he gave her a dowry of four hundred elephants nicely decorated with golden garlands. He also gave ten thousand horses, eighteen hundred chariots, and two hundred very beautiful young maidservants, fully decorated with ornaments."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "देवकी के पिता, राजा देवक, अपनी पुत्री से अत्यंत स्नेह करते थे। अतः जब वह और उसका पति घर के लिए प्रस्थान कर रहे थे, तो उन्होंने उसे दहेज के रूप में स्वर्ण मालाओं से सुसज्जित चार सौ हाथी दिए। उन्होंने दस हजार घोड़े, अठारह सौ रथ और आभूषणों से पूर्णतः अलंकृत दो सौ अत्यंत सुंदर युवतियाँ (दासियाँ) भी प्रदान कीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "દેવકીના પિતા, રાજા દેવક, પોતાની પુત્રી પર અત્યંત સ્નેહ રાખતા હતા. તેથી જ્યારે દેવકી અને તેમના પતિ ઘરે જવા માટે પ્રસ્થાન કરી રહ્યા હતા, ત્યારે તેમણે દહેજમાં સુવર્ણ માળાઓથી સુશોભિત ચારસો હાથી આપ્યા. તેમણે દસ હજાર ઘોડા, અઢારસો રથ અને આભૂષણોથી સંપૂર્ણ અલંકૃત એવી બેસો અત્યંત સુંદર યુવતીઓ (દાસીઓ) પણ આપી હતી."
            }
        }
    },
    {
        "id": 100133,
        "sloka": "10.1.33",
        "verse_id": 100133,
        "verseNumber": 33,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O beloved son, Mahārāja Parīkṣit, when the bride and bridegroom were ready to start, conchshells, bugles, drums and kettledrums all vibrated in concert for their auspicious departure."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे प्रिय पुत्र, महाराज परीक्षित, जब वर और वधू प्रस्थान करने के लिए तैयार हुए, तो उनके मंगलमय प्रस्थान के लिए शंख, बिगुल, ढोल और नगाड़े एक साथ बज उठे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે પ્રિય પુત્ર, મહારાજા પરીક્ષિત, જ્યારે વર અને વધૂ પ્રસ્થાન કરવા માટે તૈયાર થયા, ત્યારે તેમના મંગલમય પ્રસ્થાનના અવસરે શંખ, રણશિંગા, ઢોલ અને નગારા એકસાથે ગુંજી ઉઠ્યા."
            }
        }
    },
    {
        "id": 100134,
        "sloka": "10.1.34",
        "verse_id": 100134,
        "verseNumber": 34,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "While Kaṁsa, controlling the reins of the horses, was driving the chariot along the way, an unembodied voice addressed him, “You foolish rascal, the eighth child of the woman you are carrying will kill you!”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब कंस रास्ते में घोड़ों की लगाम थामे हुए रथ चला रहा था, तभी एक अशरीरी आकाशवाणी ने उसे संबोधित किया, \"हे मूर्ख दुष्ट! जिस स्त्री को तू ले जा रहा है, उसी की आठवीं संतान तेरा वध करेगी!\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે કંસ રસ્તામાં ઘોડાઓની લગામ કાબૂમાં રાખીને રથ ચલાવી રહ્યો હતો, ત્યારે એક અશરીરી આકાશવાણીએ તેને સંબોધતા કહ્યું, \"હે મૂર્ખ દુષ્ટ! તું જે સ્ત્રીને લઈ જઈ રહ્યો છે, તેની આઠમી સંતાન તને મારી નાખશે!\""
            }
        }
    },
    {
        "id": 100135,
        "sloka": "10.1.35",
        "verse_id": 100135,
        "verseNumber": 35,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kaṁsa was a condemned personality in the Bhoja dynasty because he was envious and sinful. Therefore, upon hearing this omen from the sky, he caught hold of his sister’s hair with his left hand and took up his sword with his right hand to sever her head from her body."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कंस भोज वंश में एक निंदित व्यक्ति था क्योंकि वह ईर्ष्यालु और पापी था। अतः, आकाश से यह भविष्यवाणी सुनकर, उसने अपने बाएं हाथ से अपनी बहन के बाल पकड़ लिए और अपने दाहिने हाथ से उसका सिर धड़ से अलग करने के लिए तलवार उठा ली।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભોજ વંશમાં કંસ એક નિંદિત વ્યક્તિત્વ હતું કારણ કે તે અત્યંત ઈર્ષાળુ અને પાપી હતો. તેથી, આકાશમાંથી આ ભવિષ્યવાણી સાંભળીને, તેણે પોતાના ડાબા હાથથી પોતાની બહેનના વાળ પકડ્યા અને તેના શરીરથી મસ્તક અલગ કરવા માટે જમણા હાથથી તલવાર ઉપાડી."
            }
        }
    },
    {
        "id": 100136,
        "sloka": "10.1.36",
        "verse_id": 100136,
        "verseNumber": 36,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Wanting to pacify Kaṁsa, who was so cruel and envious that he was shamelessly ready to kill his sister, the great soul Vasudeva, who was to be the father of Kṛṣṇa, spoke to him in the following words."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कंस को शांत करने के उद्देश्य से, जो इतना क्रूर और ईर्ष्यालु था कि वह निर्लज्जतापूर्वक अपनी बहन की हत्या करने के लिए उद्यत हो गया था, महान आत्मा वासुदेव ने, जो भगवान श्रीकृष्ण के पिता बनने वाले थे, उनसे निम्नलिखित शब्द कहे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કંસને શાંત કરવાના ઉદ્દેશ્યથી, જે એટલો ક્રૂર અને ઈર્ષાળુ હતો કે તે નિર્લજ્જતાપૂર્વક પોતાની બહેનની હત્યા કરવા તૈયાર થઈ ગયો હતો, મહાન આત્મા વાસુદેવે, જે ભગવાન શ્રીકૃષ્ણના પિતા બનવાના હતા, તેને નીચે મુજબના શબ્દો કહ્યા."
            }
        }
    },
    {
        "id": 100137,
        "sloka": "10.1.37",
        "verse_id": 100137,
        "verseNumber": 37,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Vasudeva said: My dear brother-in-law Kaṁsa, you are the pride of your family, the Bhoja dynasty, and great heroes praise your qualities. How could such a qualified person as you kill a woman, your own sister, especially on the occasion of her marriage?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वासुदेव ने कहा: मेरे प्रिय बहनोई कंस, आप अपने भोज वंश का गौरव हैं और महान वीर आपके गुणों की प्रशंसा करते हैं। आप जैसा योग्य व्यक्ति किसी स्त्री की, अपनी ही बहन की, हत्या कैसे कर सकता है, विशेषकर उसके विवाह के अवसर पर?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વાસુદેવે કહ્યું: મારા પ્રિય ભાણેજ (મિત્ર) કંસ, તમે તમારા પરિવાર, ભોજ વંશનું ગૌરવ છો અને મહાન વીરો તમારા ગુણોની પ્રશંસા કરે છે. તમારા જેવી લાયક વ્યક્તિ એક સ્ત્રીની, તમારી પોતાની બહેનની, હત્યા કેવી રીતે કરી શકે, ખાસ કરીને તેના લગ્ન પ્રસંગે?"
            }
        }
    },
    {
        "id": 100138,
        "sloka": "10.1.38",
        "verse_id": 100138,
        "verseNumber": 38,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O great hero, one who takes birth is sure to die, for death is born with the body. One may die today or after hundreds of years, but death is sure for every living entity."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे महाबली, जिसका जन्म हुआ है उसकी मृत्यु निश्चित है, क्योंकि मृत्यु जन्म के साथ ही उत्पन्न हो जाती है। कोई आज मरे या सौ वर्षों के बाद, प्रत्येक जीव की मृत्यु निश्चित है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે મહાન વીર, જેનો જન્મ થયો છે તેનું મૃત્યુ નિશ્ચિત છે, કારણ કે મૃત્યુ જન્મની સાથે જ જન્મે છે. કોઈ આજે મૃત્યુ પામે કે સો વર્ષ પછી, દરેક જીવ માટે મૃત્યુ નિશ્ચિત છે."
            }
        }
    },
    {
        "id": 100139,
        "sloka": "10.1.39",
        "verse_id": 100139,
        "verseNumber": 39,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When the present body turns to dust and is again reduced to five elements — earth, water, fire, air and ether — the proprietor of the body, the living being, automatically receives another body of material elements according to his fruitive activities. When the next body is obtained, he gives up the present body."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब वर्तमान शरीर धूल में मिल जाता है और पुनः पृथ्वी, जल, अग्नि, वायु तथा आकाश—इन पांच तत्वों में विलीन हो जाता है, तब शरीर का स्वामी, यह जीव, अपनी सकाम गतिविधियों के अनुसार स्वतः ही भौतिक तत्वों का एक नया शरीर प्राप्त कर लेता है। जब अगला शरीर मिल जाता है, तब वह वर्तमान शरीर को त्याग देता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે વર્તમાન શરીર ધૂળમાં મળી જાય છે અને ફરીથી પૃથ્વી, જળ, અગ્નિ, વાયુ તથા આકાશ—એ પાંચ તત્વોમાં વિલીન થઈ જાય છે, ત્યારે શરીરનો સ્વામી, જીવ, પોતાની સકામ પ્રવૃત્તિઓ અનુસાર આપમેળે ભૌતિક તત્વોનું નવું શરીર પ્રાપ્ત કરે છે. જ્યારે આગલું શરીર મળે છે, ત્યારે તે વર્તમાન શરીરનો ત્યાગ કરે છે."
            }
        }
    },
    {
        "id": 100140,
        "sloka": "10.1.40",
        "verse_id": 100140,
        "verseNumber": 40,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Just as a person traveling on the road rests one foot on the ground and then lifts the other, or as a worm on a vegetable transfers itself to one leaf and then gives up the previous one, the conditioned soul takes shelter of another body and then gives up the one he had before."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जिस प्रकार मार्ग पर चलने वाला व्यक्ति एक पैर जमीन पर टिकाकर दूसरा पैर आगे बढ़ाता है, अथवा जैसे किसी वनस्पति पर चलने वाला कीड़ा एक पत्ते को पकड़कर ही दूसरे पत्ते को छोड़ता है, उसी प्रकार बद्ध जीव दूसरे शरीर का आश्रय प्राप्त करने के पश्चात ही अपना पूर्व शरीर त्यागता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જેમ રસ્તા પર મુસાફરી કરનાર વ્યક્તિ એક પગ જમીન પર રાખીને બીજો પગ આગળ વધારે છે, અથવા જેમ શાકભાજી પર ચાલતો કીડો એક પાન પકડીને જ પાછલા પાનને છોડે છે, તેવી જ રીતે બદ્ધ જીવ બીજા શરીરનો આશ્રય પ્રાપ્ત કર્યા પછી જ પોતાનું પૂર્વ શરીર છોડે છે."
            }
        }
    },
    {
        "id": 100141,
        "sloka": "10.1.41",
        "verse_id": 100141,
        "verseNumber": 41,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Having experienced a situation by seeing or hearing about it, one contemplates and speculates about that situation, and thus one surrenders to it, not considering his present body. Similarly, by mental adjustments one dreams at night of living under different circumstances, in different bodies, and forgets his actual position. Under this same process, one gives up his present body and accepts another [tathā dehāntara-prāptiḥ]."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "किसी स्थिति को देखकर या सुनकर उसका अनुभव करने के पश्चात, व्यक्ति उसी के बारे में चिंतन और कल्पना करने लगता है और इस प्रकार वह अपने वर्तमान शरीर की सुध खोकर उसी के प्रति समर्पित हो जाता है। इसी प्रकार, मन की चंचलता के कारण व्यक्ति रात में स्वप्न में विभिन्न परिस्थितियों में अलग-अलग शरीरों में रहने की कल्पना करता है और अपनी वास्तविक स्थिति को भूल जाता है। इसी प्रक्रिया के अंतर्गत, जीव अपने वर्तमान शरीर को त्याग कर दूसरा शरीर स्वीकार कर लेता है [तथा देहांतर-प्राप्तिः]।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કોઈ પરિસ્થિતિને જોઈને કે સાંભળીને તેનો અનુભવ કર્યા પછી, વ્યક્તિ તે જ બાબતે ચિંતન અને કલ્પના કરવા લાગે છે અને આમ તે પોતાના વર્તમાન શરીરને વિસરીને તેના પ્રત્યે સમર્પિત થઈ જાય છે. તેવી જ રીતે, મનની ચંચળતાને કારણે વ્યક્તિ રાત્રે સ્વપ્નમાં વિવિધ પરિસ્થિતિઓમાં અલગ-અલગ શરીરોમાં રહેવાની કલ્પના કરે છે અને પોતાની વાસ્તવિક સ્થિતિ ભૂલી જાય છે. આ જ પ્રક્રિયા અંતર્ગત, જીવ પોતાનું વર્તમાન શરીર ત્યાગીને બીજું શરીર સ્વીકારી લે છે [તથા દેહાંતર-પ્રાપ્તિઃ]."
            }
        }
    },
    {
        "id": 100142,
        "sloka": "10.1.42",
        "verse_id": 100142,
        "verseNumber": 42,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "At the time of death, according to the thinking, feeling and willing of the mind, which is involved in fruitive activities, one receives a particular body. In other words, the body develops according to the activities of the mind. Changes of body are due to the flickering of the mind, for otherwise the soul could remain in its original, spiritual body."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मृत्यु के समय, सकाम कर्मों में लिप्त मन के चिंतन, भावनाओं और इच्छाओं के अनुरूप जीव को एक विशिष्ट शरीर प्राप्त होता है। दूसरे शब्दों में, शरीर का विकास मन की गतिविधियों के अनुसार होता है। शरीर में परिवर्तन मन की चंचलता के कारण ही होते हैं, अन्यथा आत्मा तो अपने मूल, आध्यात्मिक स्वरूप में ही स्थित रहती है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મૃત્યુના સમયે, સકામ કર્મોમાં લિપ્ત મનના ચિંતન, ભાવનાઓ અને ઈચ્છાઓને અનુરૂપ જીવને એક વિશિષ્ટ શરીર પ્રાપ્ત થાય છે. બીજા શબ્દોમાં કહીએ તો, શરીરનો વિકાસ મનની પ્રવૃત્તિઓ અનુસાર થાય છે. શરીરમાં પરિવર્તન મનની ચંચળતાને કારણે જ થાય છે, અન્યથા આત્મા તો પોતાના મૂળ, આધ્યાત્મિક સ્વરૂપમાં જ સ્થિત રહે છે."
            }
        }
    },
    {
        "id": 100143,
        "sloka": "10.1.43",
        "verse_id": 100143,
        "verseNumber": 43,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When the luminaries in the sky, such as the moon, the sun and the stars, are reflected in liquids like oil or water, they appear to be of different shapes — sometimes round, sometimes long, and so on — because of the movements of the wind. Similarly, when the living entity, the soul, is absorbed in materialistic thoughts, he accepts various manifestations as his own identity because of ignorance. In other words, one is bewildered by mental concoctions because of agitation from the material modes of nature."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब आकाश में चंद्रमा, सूर्य तथा तारे तेल या जल जैसे तरल पदार्थों में प्रतिबिंबित होते हैं, तो वे वायु की गति के कारण भिन्न-भिन्न आकारों के दिखाई देते हैं - कभी गोल, कभी लंबे, आदि। इसी प्रकार, जब जीवात्मा भौतिकवादी विचारों में लीन हो जाता है, तो अज्ञानता के कारण वह विभिन्न भौतिक शरीरों को ही अपनी वास्तविक पहचान मान लेता है। दूसरे शब्दों में, प्रकृति के गुणों के प्रभाव से मन की चंचलता के कारण व्यक्ति भ्रमित हो जाता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે આકાશમાં ચંદ્ર, સૂર્ય તથા તારાઓ તેલ કે જળ જેવા પ્રવાહીમાં પ્રતિબિંબિત થાય છે, ત્યારે તેઓ વાયુની ગતિને કારણે ભિન્ન-ભિન્ન આકારના દેખાય છે - ક્યારેક ગોળ, ક્યારેક લાંબા, વગેરે. તેવી જ રીતે, જ્યારે જીવાત્મા ભૌતિકવાદી વિચારોમાં લીન થઈ જાય છે, ત્યારે અજ્ઞાનને કારણે તે વિવિધ ભૌતિક શરીરોને જ પોતાની વાસ્તવિક ઓળખ માની લે છે. બીજા શબ્દોમાં કહીએ તો, પ્રકૃતિના ગુણોના પ્રભાવથી મનની ચંચળતાને કારણે વ્યક્તિ ભ્રમિત થઈ જાય છે."
            }
        }
    },
    {
        "id": 100144,
        "sloka": "10.1.44",
        "verse_id": 100144,
        "verseNumber": 44,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Therefore, since envious, impious activities cause a body in which one suffers in the next life, why should one act impiously? Considering one’s welfare, one should not envy anyone, for an envious person must always fear harm from his enemies, either in this life or in the next."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इसलिए, चूंकि ईर्ष्यापूर्ण और अधर्मपूर्ण कर्म ऐसे शरीर का कारण बनते हैं जिसमें व्यक्ति को अगले जन्म में कष्ट भोगना पड़ता है, तो फिर किसी को अधर्म क्यों करना चाहिए? अपने कल्याण को ध्यान में रखते हुए, किसी को भी ईर्ष्या नहीं करनी चाहिए, क्योंकि ईर्ष्यालु व्यक्ति को हमेशा अपने शत्रुओं से हानि का भय बना रहता है, चाहे इस जीवन में या अगले जीवन में।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેથી, કારણ કે ઈર્ષ્યા અને અશુદ્ધ પ્રવૃત્તિઓ એવા શરીરનું કારણ બને છે જેમાં વ્યક્તિ આગામી જન્મમાં પીડાય છે, તો પછી શા માટે વ્યક્તિએ દુષ્ટતા આચરવી જોઈએ? પોતાના કલ્યાણને ધ્યાનમાં રાખીને, વ્યક્તિએ કોઈની ઈર્ષ્યા ન કરવી જોઈએ, કારણ કે ઈર્ષ્યા કરનાર વ્યક્તિએ હંમેશા તેના શત્રુઓથી નુકસાનનો ડર રાખવો પડે છે, આ જીવનમાં અથવા પછીના જીવનમાં।"
            }
        }
    },
    {
        "id": 100145,
        "sloka": "10.1.45",
        "verse_id": 100145,
        "verseNumber": 45,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As your younger sister, this poor girl Devakī is like your own daughter and deserves to be affectionately maintained. You are merciful, and therefore you should not kill her. Indeed, she deserves your affection."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "आपकी छोटी बहन होने के नाते, यह बेचारी देवकी आपकी अपनी बेटी के समान है और स्नेहपूर्वक पालन-पोषण के योग्य है। आप दयालु हैं, अतः आपको उसका वध नहीं करना चाहिए। वास्तव में, वह आपके स्नेह की पात्र है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તમારી નાની બહેન હોવાને કારણે, આ બિચારી દેવકી તમારી પોતાની પુત્રી સમાન છે અને તે સ્નેહપૂર્વક પાલન-પોષણને પાત્ર છે. તમે દયાળુ છો, તેથી તમારે તેનો વધ ન કરવો જોઈએ. ખરેખર, તે તમારા સ્નેહને પાત્ર છે."
            }
        }
    },
    {
        "id": 100146,
        "sloka": "10.1.46",
        "verse_id": 100146,
        "verseNumber": 46,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī continued: O best of the Kuru dynasty, Kaṁsa was fiercely cruel and was actually a follower of the Rākṣasas. Therefore he could be neither pacified nor terrified by the good instructions given by Vasudeva. He did not care about the results of sinful activities, either in this life or in the next."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने आगे कहा: हे कुरु वंश के सर्वश्रेष्ठ! कंस अत्यंत क्रूर था और वास्तव में राक्षसों का अनुयायी था। इसलिए वासुदेव द्वारा दिए गए सदाचार पूर्ण निर्देशों से न तो उसे शांत किया जा सकता था और न ही उसे भयभीत किया जा सकता था। उसे इस जीवन अथवा परलोक में पाप कर्मों के परिणामों की कोई परवाह नहीं थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ આગળ કહ્યું: હે કુરુ વંશમાં શ્રેષ્ઠ! કંસ અત્યંત ક્રૂર હતો અને વાસ્તવમાં રાક્ષસોનો અનુયાયી હતો. તેથી વાસુદેવ દ્વારા આપવામાં આવેલી સદાચારપૂર્ણ સૂચનાઓથી તેને ન તો શાંત કરી શકાતો હતો કે ન તો તેને ભયભીત કરી શકાતો હતો. તેને આ જીવન કે પરલોકમાં પાપ કર્મનાં પરિણામોની કોઈ પરવા નહોતી."
            }
        }
    },
    {
        "id": 100147,
        "sloka": "10.1.47",
        "verse_id": 100147,
        "verseNumber": 47,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When Vasudeva saw that Kaṁsa was determined to kill his sister Devakī, he thought to himself very deeply. Considering the imminent danger of death, he thought of another plan to stop Kaṁsa."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब वसुदेव ने देखा कि कंस अपनी बहन देवकी का वध करने के लिए आमादा है, तो उन्होंने मन ही मन गहराई से विचार किया। मृत्यु के आसन्न खतरे को देखते हुए, उन्होंने कंस को रोकने के लिए एक अन्य योजना के बारे में सोचा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે વસુદેવે જોયું કે કંસ તેની બહેન દેવકીનો વધ કરવા માટે મક્કમ છે, ત્યારે તેમણે મનમાં ઊંડો વિચાર કર્યો. મૃત્યુના નિકટવર્તી ભયને ધ્યાનમાં રાખીને, તેમણે કંસને રોકવા માટે બીજી એક યોજના વિચારી."
            }
        }
    },
    {
        "id": 100148,
        "sloka": "10.1.48",
        "verse_id": 100148,
        "verseNumber": 48,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As long as he has intelligence and bodily strength, an intelligent person must try to avoid death. This is the duty of every embodied person. But if death cannot be avoided in spite of one’s endeavors, a person facing death commits no offense."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब तक किसी के पास बुद्धि और शारीरिक शक्ति है, एक बुद्धिमान व्यक्ति को मृत्यु से बचने का प्रयास करना चाहिए। यह प्रत्येक देहधारी जीव का कर्तव्य है। किंतु यदि किसी के प्रयासों के बावजूद मृत्यु को टाला न जा सके, तो मृत्यु का सामना करने वाला व्यक्ति कोई अपराध नहीं करता।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યાં સુધી કોઈની પાસે બુદ્ધિ અને શારીરિક શક્તિ છે, ત્યાં સુધી બુદ્ધિશાળી વ્યક્તિએ મૃત્યુથી બચવાનો પ્રયત્ન કરવો જોઈએ. આ દરેક દેહધારી જીવનું કર્તવ્ય છે. પરંતુ જો કોઈના પ્રયત્નો છતાં મૃત્યુને ટાળી ન શકાય, તો મૃત્યુનો સામનો કરનાર વ્યક્તિ કોઈ અપરાધ કરતી નથી."
            }
        }
    },
    {
        "id": 100149,
        "sloka": "10.1.49-50",
        "verse_id": 100149,
        "verseNumber": 49,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Vasudeva considered: By delivering all my sons to Kaṁsa, who is death personified, I shall save the life of Devakī. Perhaps Kaṁsa will die before my sons take birth, or, since he is already destined to die at the hands of my son, one of my sons may kill him. For the time being, let me promise to hand over my sons so that Kaṁsa will give up this immediate threat, and if in due course of time Kaṁsa dies, I shall have nothing to fear."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वसुदेव ने विचार किया: अपने सभी पुत्रों को कंस को सौंपकर, जो साक्षात मृत्यु के समान है, मैं देवकी का जीवन बचा लूंगा। शायद मेरे पुत्रों के जन्म से पूर्व ही कंस की मृत्यु हो जाए, अथवा, चूंकि उसका मेरे पुत्र के हाथों मरना निश्चित है, तो मेरा कोई पुत्र ही उसका वध कर दे। फिलहाल, मैं अपने पुत्रों को सौंपने का वचन देता हूं ताकि कंस इस तात्कालिक क्रोध को त्याग दे, और यदि समय के साथ कंस की मृत्यु हो जाती है, तो मुझे तनिक भी भय नहीं रहेगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વસુદેવે વિચાર્યું: મારા બધા પુત્રોને કંસને સોંપીને, જે સાક્ષાત્ મૃત્યુ સમાન છે, હું દેવકીનો જીવ બચાવી લઈશ. કદાચ મારા પુત્રોના જન્મ પહેલાં કંસ મૃત્યુ પામે, અથવા, કારણ કે તે મારા પુત્રના હાથે મૃત્યુ પામશે તે નિશ્ચિત છે, તો મારો કોઈ પુત્ર જ તેનો વધ કરી નાખે. અત્યારે, હું મારા પુત્રોને સોંપવાનું વચન આપું છું જેથી કંસ આ તાત્કાલિક ક્રોધને ત્યજી દે, અને જો સમય જતાં કંસનું મૃત્યુ થાય, તો મારે ડરવાની કોઈ આવશ્યકતા નહીં રહે."
            }
        }
    },
    {
        "id": 100151,
        "sloka": "10.1.51",
        "verse_id": 100151,
        "verseNumber": 51,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When a fire, for some unseen reason, leaps over one piece of wood and sets fire to the next, the reason is destiny. Similarly, when a living being accepts one kind of body and leaves aside another, there is no other reason than unseen destiny."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब किसी अदृश्य कारण से अग्नि लकड़ी के एक टुकड़े को छोड़कर दूसरे टुकड़े में लग जाती है, तो इसका कारण नियति ही होती है। इसी प्रकार, जब कोई जीव एक शरीर को त्यागकर दूसरा शरीर धारण करता है, तो इसके पीछे अदृश्य नियति के अतिरिक्त और कोई कारण नहीं होता।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે કોઈ અદૃશ્ય કારણસર અગ્નિ લાકડાના એક ટુકડાને છોડીને બીજા ટુકડામાં લાગે છે, ત્યારે તેનું કારણ નિયતિ જ હોય છે. તેવી જ રીતે, જ્યારે કોઈ જીવ એક શરીરને ત્યજીને બીજું શરીર ધારણ કરે છે, ત્યારે તેની પાછળ અદૃશ્ય નિયતિ સિવાય બીજું કોઈ કારણ હોતું નથી."
            }
        }
    },
    {
        "id": 100152,
        "sloka": "10.1.52",
        "verse_id": 100152,
        "verseNumber": 52,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After thus considering the matter as far as his knowledge would allow, Vasudeva submitted his proposal to the sinful Kaṁsa with great respect."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार, अपनी बुद्धि के अनुसार मामले पर गहराई से विचार करने के उपरांत, वसुदेव ने बड़े सम्मान के साथ पापी कंस के समक्ष अपना प्रस्ताव रखा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે, પોતાની બુદ્ધિ અનુસાર બાબત પર ઊંડાણપૂર્વક વિચાર કર્યા પછી, વસુદેવે ખૂબ જ આદર સાથે પાપી કંસની સમક્ષ પોતાનો પ્રસ્તાવ મૂક્યો."
            }
        }
    },
    {
        "id": 100153,
        "sloka": "10.1.53",
        "verse_id": 100153,
        "verseNumber": 53,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Vasudeva’s mind was full of anxiety because his wife was facing danger, but in order to please the cruel, shameless and sinful Kaṁsa, he externally smiled and spoke to him as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वसुदेव का मन गहरी चिंता से भरा था क्योंकि उनकी पत्नी संकट में थी, किंतु उस क्रूर, निर्लज्ज और पापी कंस को प्रसन्न करने के लिए, उन्होंने बाहर से मुस्कुराते हुए उससे इस प्रकार कहा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વસુદેવનું મન ગંભીર ચિંતાથી ભરેલું હતું કારણ કે તેમની પત્ની સંકટમાં હતી, પરંતુ તે ક્રૂર, નિર્લજ્જ અને પાપી કંસને પ્રસન્ન કરવા માટે, તેમણે બહારથી સ્મિત કરતા તેની સાથે આ પ્રમાણે વાત કરી."
            }
        }
    },
    {
        "id": 100154,
        "sloka": "10.1.54",
        "verse_id": 100154,
        "verseNumber": 54,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Vasudeva said: O best of the sober, you have nothing to fear from your sister Devakī because of what you have heard from the unseen omen. The cause of death will be her sons. Therefore I promise that when she gives birth to the sons from whom your fear has arisen, I shall deliver them all unto your hands."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वसुदेव ने कहा: हे संयमी जनों में श्रेष्ठ! आकाशवाणी से तुमने जो सुना है, उसके कारण तुम्हें अपनी बहन देवकी से भयभीत होने की कोई आवश्यकता नहीं है। तुम्हारी मृत्यु का कारण तो उसके पुत्र होंगे। अतः मैं वचन देता हूं कि जब वह उन पुत्रों को जन्म देगी जिनसे तुम्हें भय उत्पन्न हुआ है, तो मैं उन सबको तुम्हारे हाथों सौंप दूंगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વસુદેવે કહ્યું: હે સંયમી જનોમાં શ્રેષ્ઠ! આકાશવાણી દ્વારા તમે જે સાંભળ્યું છે, તેના કારણે તમારે તમારી બહેન દેવકીથી ડરવાની કોઈ જરૂર નથી. તમારા મૃત્યુનું કારણ તો તેના પુત્રો હશે. તેથી હું વચન આપું છું કે જ્યારે તે એવા પુત્રોને જન્મ આપશે જેનાથી તમને ભય પેદા થયો છે, ત્યારે હું તે બધાને તમારા હાથમાં સોંપી દઈશ."
            }
        }
    },
    {
        "id": 100155,
        "sloka": "10.1.55",
        "verse_id": 100155,
        "verseNumber": 55,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śrīla Śukadeva Gosvāmī continued: Kaṁsa agreed to the logical arguments of Vasudeva, and, having full faith in Vasudeva’s words, he refrained from killing his sister. Vasudeva, being pleased with Kaṁsa, pacified him further and entered his own house."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "श्रील शुकदेव गोस्वामी ने आगे कहा: कंस वासुदेव के तार्किक तर्कों से सहमत हो गया, और, वासुदेव के शब्दों पर पूरा विश्वास करते हुए, वह अपनी बहन को मारने से बच गया। वासुदेव ने कंस से प्रसन्न होकर उसे शांत किया और अपने घर में प्रवेश किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શ્રીલ શુકદેવ ગોસ્વામીએ ચાલુ રાખ્યું: કંસ વાસુદેવની તાર્કિક દલીલો સાથે સંમત થયા, અને, વાસુદેવના શબ્દોમાં સંપૂર્ણ વિશ્વાસ રાખીને, તેણે તેની બહેનની હત્યા કરવાનું ટાળ્યું. વાસુદેવ, કંસ પર પ્રસન્ન થઈને, તેને વધુ શાંત કરી અને પોતાના ઘરમાં પ્રવેશ્યા."
            }
        }
    },
    {
        "id": 100156,
        "sloka": "10.1.56",
        "verse_id": 100156,
        "verseNumber": 56,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Each year thereafter, in due course of time, Devakī, the mother of God and all the demigods, gave birth to a child. Thus she bore eight sons, one after another, and a daughter named Subhadrā."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उसके बाद प्रत्येक वर्ष, उचित समय पर, भगवान और सभी देवताओं की माता देवकी ने एक बच्चे को जन्म दिया। इस प्रकार उसके एक के बाद एक आठ पुत्र और सुभद्रा नामक एक पुत्री उत्पन्न हुई।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ત્યાર પછી દર વર્ષે, સમયાંતરે, દેવકી, ભગવાનની માતા અને તમામ દેવતાઓએ એક બાળકને જન્મ આપ્યો. આમ તેણીએ એક પછી એક આઠ પુત્રો અને સુભદ્રા નામની પુત્રીને જન્મ આપ્યો."
            }
        }
    },
    {
        "id": 100157,
        "sloka": "10.1.57",
        "verse_id": 100157,
        "verseNumber": 57,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Vasudeva was very much disturbed by fear of becoming a liar by breaking his promise. Thus with great pain he delivered his first-born son, named Kīrtimān, into the hands of Kaṁsa."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वासुदेव अपने वचन को तोड़कर झूठे बनने के डर से बहुत परेशान थे। इस प्रकार बड़े कष्ट के साथ उन्होंने कीर्तिमान नामक अपने पहले जन्मे पुत्र को कंस के हाथों में सौंप दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વચનનો ભંગ કરીને જૂઠો બની જવાના ભયથી વાસુદેવ ખૂબ જ વ્યથિત હતા. આ રીતે ભારે પીડા સાથે તેણે પોતાના પ્રથમ જન્મેલા પુત્ર કીર્તિમાનને કંસના હાથમાં સોંપી દીધો."
            }
        }
    },
    {
        "id": 100158,
        "sloka": "10.1.58",
        "verse_id": 100158,
        "verseNumber": 58,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "What is painful for saintly persons who strictly adhere to the truth? How could there not be independence for pure devotees who know the Supreme Lord as the substance? What deeds are forbidden for persons of the lowest character? And what cannot be given up for the sake of Lord Kṛṣṇa by those who have fully surrendered at His lotus feet?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सत्य का कठोरता से पालन करने वाले साधु पुरुषों को दुःख क्या होता है? उन शुद्ध भक्तों के लिए स्वतंत्रता कैसे नहीं हो सकती जो परमेश्वर को तत्व के रूप में जानते हैं? निम्नतम चरित्र वाले व्यक्तियों के लिए कौन से कार्य वर्जित हैं? और जो लोग पूरी तरह से उनके चरणकमलों में समर्पित हो गए हैं, वे भगवान कृष्ण के लिए क्या नहीं त्याग सकते?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "સત્યને ચુસ્તપણે વળગી રહેલા સંતપુરુષો માટે શું દુઃખદાયક છે? પરમ ભગવાનને દ્રવ્ય તરીકે જાણનારા શુદ્ધ ભક્તો માટે સ્વતંત્રતા કેવી રીતે ન હોઈ શકે? સૌથી નીચા પાત્રની વ્યક્તિઓ માટે કયા કાર્યો પ્રતિબંધિત છે? અને જેઓ તેમના કમળના ચરણોમાં સંપૂર્ણ સમર્પણ થયા છે તેઓ દ્વારા ભગવાન કૃષ્ણની ખાતર શું છોડી શકાય નહીં?"
            }
        }
    },
    {
        "id": 100159,
        "sloka": "10.1.59",
        "verse_id": 100159,
        "verseNumber": 59,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My dear King Parīkṣit, when Kaṁsa saw that Vasudeva, being situated in truthfulness, was completely equipoised in giving him the child, he was very happy. Therefore, with a smiling face, he spoke as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रिय राजा परीक्षित, जब कंस ने देखा कि वासुदेव, सत्य में स्थित होकर, उसे बच्चा देने में पूरी तरह से तैयार हैं, तो वह बहुत खुश हुआ। अत: वे हँसते हुए मुख से इस प्रकार बोले।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા પ્રિય રાજા પરીક્ષિત, જ્યારે કંસ એ જોયું કે વાસુદેવ, સત્યતામાં સ્થિત છે, તેમને બાળક આપવા માટે સંપૂર્ણ રીતે સજ્જ છે, ત્યારે તેઓ ખૂબ જ ખુશ થયા. તેથી, હસતા ચહેરા સાથે, તેણે નીચે મુજબ વાત કરી."
            }
        }
    },
    {
        "id": 100160,
        "sloka": "10.1.60",
        "verse_id": 100160,
        "verseNumber": 60,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Vasudeva, you may take back your child and go home. I have no fear of your first child. It is the eighth child of you and Devakī I am concerned with because that is the child by whom I am destined to be killed."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे वासुदेव, आप अपने बच्चे को वापस ले सकते हैं और घर जा सकते हैं। मुझे आपके पहले बच्चे से कोई डर नहीं है. यह तुम्हारी और देवकी की आठवीं संतान है जिसकी मुझे चिंता है क्योंकि यही वह संतान है जिसके द्वारा मेरी मृत्यु निश्चित है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે વાસુદેવ, તમે તમારા બાળકને પાછા લઈ જાઓ અને ઘરે જાઓ. મને તમારા પહેલા બાળકનો ડર નથી. તે તમારું અને દેવકીનું આઠમું સંતાન છે જેનાથી હું ચિંતિત છું કારણ કે તે બાળક છે જેના દ્વારા મારી હત્યા થવાનું નક્કી છે."
            }
        }
    },
    {
        "id": 100161,
        "sloka": "10.1.61",
        "verse_id": 100161,
        "verseNumber": 61,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Vasudeva agreed and took his child back home, but because Kaṁsa had no character and no self-control, Vasudeva knew that he could not rely on Kaṁsa’s word."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वासुदेव सहमत हो गए और अपने बच्चे को वापस घर ले गए, लेकिन क्योंकि कंस के पास कोई चरित्र नहीं था और कोई आत्म-नियंत्रण नहीं था, वासुदेव जानते थे कि वह कंस के शब्दों पर भरोसा नहीं कर सकते।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વાસુદેવ સંમત થયા અને તેમના બાળકને ઘરે પાછા લઈ ગયા, પરંતુ કંસ પાસે કોઈ પાત્ર અને કોઈ આત્મ-નિયંત્રણ ન હોવાને કારણે, વાસુદેવ જાણતા હતા કે તે કંસના વચન પર વિશ્વાસ કરી શકતા નથી."
            }
        }
    },
    {
        "id": 100162,
        "sloka": "10.1.62-63",
        "verse_id": 100162,
        "verseNumber": 62,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The inhabitants of Vṛndāvana, headed by Nanda Mahārāja and including his associate cowherd men and their wives, were none but denizens of the heavenly planets, O Mahārāja Parīkṣit, best of the descendants of Bharata, and so too were the descendants of the Vṛṣṇi dynasty, headed by Vasudeva and Devakī and the other women of the dynasty of Yadu. The friends, relatives and well-wishers of both Nanda Mahārāja and Vasudeva and even those who externally appeared to be followers of Kaṁsa were all demigods."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वृन्दावन के निवासी, जिनमें नन्द महाराज और उनके सहयोगी ग्वाले और उनकी पत्नियाँ शामिल थे, स्वर्गीय ग्रहों के निवासी थे, हे महाराज परीक्षित, भरत के सर्वोत्तम वंशज थे, और इसी तरह वृष्णि वंश के वंशज भी थे, जिनके मुखिया वासुदेव और देवकी और यदु वंश की अन्य महिलाएँ थीं। नंद महाराज और वासुदेव दोनों के मित्र, रिश्तेदार और शुभचिंतक और यहां तक ​​कि जो लोग बाह्य रूप से कंस के अनुयायी प्रतीत होते थे, वे सभी देवता थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વૃંદાવનના રહેવાસીઓ, નંદ મહારાજના નેતૃત્વમાં અને તેમના સહયોગી ગોવાળો પુરુષો અને તેમની પત્નીઓ સહિત, સ્વર્ગીય ગ્રહોના રહેવાસીઓ સિવાય બીજું કોઈ નહોતા, હે મહારાજ પરિક્ષિત, ભરતના વંશજોમાં શ્રેષ્ઠ, અને તે જ રીતે વૈષ્ણનના વંશજો પણ હતા. વાસુદેવ અને દેવકી અને યદુના વંશની અન્ય સ્ત્રીઓ. નંદ મહારાજ અને વાસુદેવ બંનેના મિત્રો, સંબંધીઓ અને શુભેચ્છકો અને જેઓ બહારથી કંસના અનુયાયીઓ તરીકે દેખાતા હતા તે બધા દેવતાઓ હતા."
            }
        }
    },
    {
        "id": 100164,
        "sloka": "10.1.64",
        "verse_id": 100164,
        "verseNumber": 64,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Once the great saint Nārada approached Kaṁsa and informed him of how the demoniac persons who were a great burden on the earth were going to be killed. Thus Kaṁsa was placed into great fear and doubt."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक बार महान संत नारद कंस के पास पहुंचे और उसे बताया कि कैसे राक्षसी व्यक्तियों को मारा जाएगा जो पृथ्वी पर एक बड़ा बोझ थे। इस प्रकार कंस बड़े भय और संदेह में पड़ गया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એકવાર મહાન સંત નારદ કંસ પાસે આવ્યા અને તેમને જાણ કરી કે કેવી રીતે આસુરી વ્યક્તિઓ કે જેઓ પૃથ્વી પરનો મોટો બોજ છે તેઓને મારી નાખવામાં આવશે. આ રીતે કંસને ભારે ભય અને શંકામાં મૂકવામાં આવ્યો."
            }
        }
    },
    {
        "id": 100165,
        "sloka": "10.1.65-66",
        "verse_id": 100165,
        "verseNumber": 65,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After the departure of the great saint Nārada, Kaṁsa thought that all the members of the Yadu dynasty were demigods and that any of the children born from the womb of Devakī might be Viṣṇu. Fearing his death, Kaṁsa arrested Vasudeva and Devakī and chained them with iron shackles. Suspecting each of the children to be Viṣṇu, Kaṁsa killed them one after another because of the prophecy that Viṣṇu would kill him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "महान संत नारद के जाने के बाद, कंस ने सोचा कि यदु वंश के सभी सदस्य देवता थे और देवकी के गर्भ से पैदा हुए बच्चों में से कोई भी विष्णु हो सकता है। अपनी मृत्यु के डर से, कंस ने वासुदेव और देवकी को गिरफ्तार कर लिया और उन्हें लोहे की बेड़ियों से जकड़ दिया। प्रत्येक बच्चे के विष्णु होने का संदेह करते हुए, कंस ने उन्हें एक के बाद एक मार डाला क्योंकि भविष्यवाणी थी कि विष्णु उसे मार देंगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મહાન સંત નારદના વિદાય પછી, કંસ વિચાર્યું કે યદુ વંશના તમામ સભ્યો દેવતાઓ હતા અને દેવકીના ગર્ભમાંથી જન્મેલા કોઈપણ બાળકો વિષ્ણુ હોઈ શકે છે. તેમના મૃત્યુના ડરથી, કંસએ વાસુદેવ અને દેવકીની ધરપકડ કરી અને તેમને લોખંડની બેડીઓથી બાંધી દીધા. દરેક બાળકો વિષ્ણુ હોવાની શંકા કરીને, વિષ્ણુ તેને મારી નાખશે તેવી ભવિષ્યવાણીને કારણે કંસે તેમને એક પછી એક મારી નાખ્યા."
            }
        }
    },
    {
        "id": 100167,
        "sloka": "10.1.67",
        "verse_id": 100167,
        "verseNumber": 67,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kings greedy for sense gratification on this earth almost always kill their enemies indiscriminately. To satisfy their own whims, they may kill anyone, even their mothers, fathers, brothers or friends."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस पृथ्वी पर इंद्रियतृप्ति के लालची राजा प्रायः अपने शत्रुओं को अंधाधुंध मार डालते हैं। अपनी सनक पूरी करने के लिए, वे किसी को भी मार सकते हैं, यहाँ तक कि अपनी माँ, पिता, भाई या दोस्तों को भी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ પૃથ્વી પર ઇન્દ્રિય તૃપ્તિ માટે લોભી રાજાઓ લગભગ હંમેશા તેમના દુશ્મનોને આડેધડ મારી નાખે છે. પોતાની ધૂન સંતોષવા માટે, તેઓ કોઈની પણ હત્યા કરી શકે છે, તેમની માતા, પિતા, ભાઈ કે મિત્રોને પણ."
            }
        }
    },
    {
        "id": 100168,
        "sloka": "10.1.68",
        "verse_id": 100168,
        "verseNumber": 68,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In his previous birth, Kaṁsa had been a great demon named Kālanemi and been killed by Viṣṇu. Upon learning this information from Nārada, Kaṁsa became envious of everyone connected with the Yadu dynasty."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपने पिछले जन्म में, कंस कालनेमि नामक एक महान राक्षस था और विष्णु द्वारा मारा गया था। नारद से यह जानकारी जानने के बाद, कंस को यदु वंश से जुड़े सभी लोगों से ईर्ष्या होने लगी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેના પાછલા જન્મમાં, કંસ કાલનેમી નામનો એક મહાન રાક્ષસ હતો અને તેને વિષ્ણુએ મારી નાખ્યો હતો. નારદ પાસેથી આ માહિતી જાણ્યા પછી, કંસ યદુ વંશ સાથે જોડાયેલા દરેકની ઈર્ષ્યા કરવા લાગ્યા."
            }
        }
    },
    {
        "id": 100169,
        "sloka": "10.1.69",
        "verse_id": 100169,
        "verseNumber": 69,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kaṁsa, the most powerful son of Ugrasena, even imprisoned his own father, the King of the Yadu, Bhoja and Andhaka dynasties, and personally ruled the states known as Śūrasena."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उग्रसेन के सबसे शक्तिशाली पुत्र कंस ने अपने पिता, यदु, भोज और अंधक राजवंशों के राजा को भी कैद कर लिया और शूरसेन नामक राज्यों पर व्यक्तिगत रूप से शासन किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કંસ, ઉગ્રસેનનો સૌથી શક્તિશાળી પુત્ર, તેણે પોતાના પિતા, યદુ, ભોજ અને અંધક વંશના રાજાને પણ કેદ કર્યા અને શૂરસેન તરીકે ઓળખાતા રાજ્યો પર વ્યક્તિગત રીતે શાસન કર્યું."
            }
        }
    }
]