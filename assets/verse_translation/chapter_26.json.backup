[
    {
        "id": 102601,
        "sloka": "10.26.1",
        "verse_id": 102601,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: The cowherd men were astonished when they saw Kṛṣṇa’s activities, such as lifting Govardhana Hill. Unable to understand His transcendental potency, they approached Nanda Mahārāja and spoke as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: जब चरवाहे लोगों ने कृष्ण की गतिविधियों, जैसे कि गोवर्धन पर्वत को उठाने, को देखा तो आश्चर्यचकित रह गए। उनकी दिव्य शक्ति को समझने में असमर्थ, वे नंद महाराज के पास पहुंचे और इस प्रकार बात की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: ગોવાળિયાઓ આશ્ચર્યચકિત થઈ ગયા જ્યારે તેઓએ કૃષ્ણની પ્રવૃત્તિઓ, જેમ કે ગોવર્ધન પર્વત ઉપાડવો જોયો. તેમની દિવ્ય શક્તિને સમજવામાં અસમર્થ, તેઓ નંદ મહારાજ પાસે ગયા અને નીચે પ્રમાણે વાત કરી."
            }
        }
    },
    {
        "id": 102602,
        "sloka": "10.26.2",
        "verse_id": 102602,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[The cowherd men said:] Since this boy performs such extraordinary activities, how could He warrant a birth among worldly men like us — a birth that for Him would seem contemptible?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[ग्वालों ने कहा:] चूँकि यह लड़का इतनी असाधारण गतिविधियाँ करता है, तो वह हम जैसे सांसारिक लोगों के बीच जन्म की गारंटी कैसे दे सकता है - एक ऐसा जन्म जो उसके लिए अपमानजनक प्रतीत होगा?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ગોવાળ માણસોએ કહ્યું:] આ છોકરો આવી અસાધારણ પ્રવૃત્તિઓ કરે છે, તેથી તે આપણા જેવા દુન્યવી પુરુષોમાં જન્મ કેવી રીતે આપી શકે - જે જન્મ તેના માટે ધિક્કારપાત્ર લાગે?"
            }
        }
    },
    {
        "id": 102603,
        "sloka": "10.26.3",
        "verse_id": 102603,
        "verseNumber": 3,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "How could this seven-year-old boy playfully hold up the great hill Govardhana with one hand, just as a mighty elephant holds up a lotus flower?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यह सात वर्षीय बालक कैसे खेल-खेल में एक हाथ से विशाल पर्वत गोवर्धन को पकड़ सकता है, जैसे एक शक्तिशाली हाथी कमल के फूल को उठाता है?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ સાત વર્ષનો છોકરો રમતિયાળ રીતે ગોવર્ધન પર્વતને એક હાથે કેવી રીતે પકડી શકે છે, જેમ એક શક્તિશાળી હાથી કમળના ફૂલને પકડી રાખે છે?"
            }
        }
    },
    {
        "id": 102604,
        "sloka": "10.26.4",
        "verse_id": 102604,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As a mere infant who had hardly yet opened His eyes, He drank the breast milk of the powerful demoness Pūtanā and then sucked out her very life air as well, just as the force of time sucks out the youth of one’s body."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक मात्र शिशु के रूप में, जिसने अभी तक अपनी आँखें नहीं खोली थीं, उसने शक्तिशाली राक्षसी पूतना का स्तन का दूध पिया और फिर उसकी प्राण वायु को भी सोख लिया, जैसे समय की ताकत किसी के शरीर के यौवन को सोख लेती है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "માત્ર એક શિશુ તરીકે કે જેણે તેની આંખો ભાગ્યે જ ખોલી હતી, તેણે શક્તિશાળી રાક્ષસી પૂતનાનું સ્તન દૂધ પીધું અને પછી તેના જીવનની હવા પણ ચૂસી લીધી, જેમ સમયનું બળ વ્યક્તિના શરીરની યુવાનીને ચૂસી લે છે."
            }
        }
    },
    {
        "id": 102605,
        "sloka": "10.26.5",
        "verse_id": 102605,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Once, when only three months old, little Kṛṣṇa was crying and kicking up His feet as He lay beneath a huge cart. Then the cart fell and turned upside-down simply because it was struck by the tip of His toe."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक बार, जब केवल तीन महीने के थे, छोटे कृष्ण रो रहे थे और एक बड़ी गाड़ी के नीचे लेटकर अपने पैर उछाल रहे थे। तभी गाड़ी गिर गई और उलटी हो गई, सिर्फ इसलिए कि वह उसके पैर के अंगूठे की नोक से टकराई थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એકવાર, જ્યારે માત્ર ત્રણ મહિનાનો હતો, નાના કૃષ્ણ રડતા હતા અને તેમના પગને લાત મારતા હતા કારણ કે તેઓ એક વિશાળ ગાડીની નીચે પડેલા હતા. પછી ગાડી પડી અને ઊંધી વળી ગઈ કારણ કે તે તેના અંગૂઠાની ટોચ પર અથડાઈ હતી."
            }
        }
    },
    {
        "id": 102606,
        "sloka": "10.26.6",
        "verse_id": 102606,
        "verseNumber": 6,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "At the age of one, while sitting peacefully He was taken up into the sky by the demon Tṛṇāvarta. But baby Kṛṣṇa grabbed the demon’s neck, causing him great pain, and thus killed him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक वर्ष की आयु में, जब वे शांति से बैठे थे, तो उन्हें राक्षस तृणावर्त ने आकाश में उठा लिया। लेकिन शिशु कृष्ण ने राक्षस की गर्दन पकड़ ली, जिससे उसे बहुत दर्द हुआ और इस तरह उसे मार डाला।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક વર્ષની ઉંમરે, જ્યારે શાંતિથી બેઠા હતા ત્યારે રાક્ષસ તૃણાવર્ત દ્વારા તેમને આકાશમાં લઈ જવામાં આવ્યા હતા. પરંતુ બાળક કૃષ્ણએ રાક્ષસની ગરદન પકડી લીધી, તેને ખૂબ જ પીડા થઈ, અને આ રીતે તેને મારી નાખ્યો."
            }
        }
    },
    {
        "id": 102607,
        "sloka": "10.26.7",
        "verse_id": 102607,
        "verseNumber": 7,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Once, His mother tied Him with ropes to a mortar because she had caught Him stealing butter. Then, crawling on His hands, He dragged the mortar between a pair of arjuna trees and pulled them down."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक बार, उनकी माँ ने उन्हें रस्सियों से ओखली से बाँध दिया था क्योंकि उन्होंने उन्हें मक्खन चुराते हुए पकड़ लिया था। फिर, अपने हाथों पर रेंगते हुए, उन्होंने मोर्टार को अर्जुन के एक जोड़े के पेड़ों के बीच खींच लिया और उन्हें नीचे खींच लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એકવાર, તેની માતાએ તેને મોર્ટાર સાથે દોરડા વડે બાંધી દીધો કારણ કે તેણીએ તેને માખણ ચોરી કરતા પકડ્યો હતો. પછી, તેમના હાથ પર રખડતા, તેમણે અર્જુન વૃક્ષોની જોડી વચ્ચે મોર્ટાર ખેંચી અને તેમને નીચે ખેંચ્યા."
            }
        }
    },
    {
        "id": 102608,
        "sloka": "10.26.8",
        "verse_id": 102608,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Another time, when Kṛṣṇa was tending the calves in the forest together with Balarāma and the cowherd boys, the demon Bakāsura came with the intention of killing Kṛṣṇa. But Kṛṣṇa seized this inimical demon by the mouth and tore him apart."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "दूसरी बार, जब कृष्ण बलराम और ग्वालों के साथ जंगल में बछड़ों की देखभाल कर रहे थे, तो राक्षस बकासुर कृष्ण को मारने के इरादे से आया। लेकिन कृष्ण ने इस शत्रु राक्षस का मुँह पकड़ लिया और उसे फाड़ डाला।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બીજી વખત, જ્યારે કૃષ્ણ બલરામ અને ગોવાળિયા છોકરાઓ સાથે જંગલમાં વાછરડાંની સંભાળ રાખતા હતા, ત્યારે રાક્ષસ બકાસુર કૃષ્ણને મારવાના ઈરાદાથી આવ્યો હતો. પરંતુ કૃષ્ણએ આ દુશ્મન રાક્ષસને મોંથી પકડીને તેને ફાડી નાખ્યો."
            }
        }
    },
    {
        "id": 102609,
        "sloka": "10.26.9",
        "verse_id": 102609,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Desiring to kill Kṛṣṇa, the demon Vatsa disguised himself as a calf and entered among Kṛṣṇa’s calves. But Kṛṣṇa killed the demon and, using his body, enjoyed the sport of knocking kapittha fruits down from the trees."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण को मारने की इच्छा से राक्षस वत्स ने एक बछड़े का रूप धारण किया और कृष्ण के बछड़ों के बीच में घुस गया। लेकिन कृष्ण ने राक्षस को मार डाला और, अपने शरीर का उपयोग करके, पेड़ों से कपित्थ फलों को तोड़ने के खेल का आनंद लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણને મારવા ઈચ્છતા, રાક્ષસ વત્સે વાછરડાનો વેશ ધારણ કર્યો અને કૃષ્ણના વાછરડાઓમાં પ્રવેશ કર્યો. પરંતુ કૃષ્ણએ રાક્ષસને માર્યો અને, તેના શરીરનો ઉપયોગ કરીને, કપિત્થાના ફળોને ઝાડ પરથી નીચે પછાડવાની રમતનો આનંદ માણ્યો."
            }
        }
    },
    {
        "id": 102610,
        "sloka": "10.26.10",
        "verse_id": 102610,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Together with Lord Balarāma, Kṛṣṇa killed the jackass demon and all his friends, thereby securing the safety of the Tālavana forest, which abounded with fully ripened palm fruits."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान बलराम के साथ मिलकर, कृष्ण ने गधा राक्षस और उसके सभी दोस्तों को मार डाला, जिससे तालवन जंगल की सुरक्षा सुरक्षित हो गई, जो पूरी तरह से पके ताड़ के फलों से भरपूर था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બલરામ સાથે મળીને, કૃષ્ણએ શિયાળના રાક્ષસ અને તેના તમામ મિત્રોને મારી નાખ્યા, જેનાથી તાલાવના જંગલની સુરક્ષા થઈ, જે સંપૂર્ણ પાકેલા તાડના ફળોથી ભરપૂર છે."
            }
        }
    },
    {
        "id": 102611,
        "sloka": "10.26.11",
        "verse_id": 102611,
        "verseNumber": 11,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After arranging for the mighty Lord Balarāma to kill the terrible demon Pralamba, Kṛṣṇa saved Vraja’s cowherd boys and their animals from a forest fire."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भयानक राक्षस प्रलंब को मारने के लिए शक्तिशाली भगवान बलराम की व्यवस्था करने के बाद, कृष्ण ने व्रज के चरवाहे लड़कों और उनके जानवरों को जंगल की आग से बचाया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભયંકર રાક્ષસ પ્રલંબાને મારવા માટે શક્તિશાળી ભગવાન બલરામની ગોઠવણ કર્યા પછી, કૃષ્ણએ વ્રજના ગોવાળિયા છોકરાઓ અને તેમના પ્રાણીઓને જંગલની આગમાંથી બચાવ્યા."
            }
        }
    },
    {
        "id": 102612,
        "sloka": "10.26.12",
        "verse_id": 102612,
        "verseNumber": 12,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kṛṣṇa chastised the most poisonous serpent, Kāliya, and after humbling him He drove him forcibly from the lake of the Yamunā. In this way the Lord made the water of that river free of the snake’s powerful poison."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण ने सबसे जहरीले नाग, कालिया को दंडित किया और उसे अपमानित करने के बाद उसे यमुना की झील से बलपूर्वक बाहर निकाल दिया। इस प्रकार भगवान ने उस नदी के पानी को साँप के शक्तिशाली जहर से मुक्त कर दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણે સૌથી ઝેરી સર્પ, કાલિયાને શિક્ષા કરી, અને તેને નમ્ર કર્યા પછી તેણે તેને યમુના તળાવમાંથી બળજબરીથી ભગાડ્યો. આ રીતે ભગવાને તે નદીના પાણીને સાપના શક્તિશાળી ઝેરથી મુક્ત કરી દીધું."
            }
        }
    },
    {
        "id": 102613,
        "sloka": "10.26.13",
        "verse_id": 102613,
        "verseNumber": 13,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Dear Nanda, how is it that we and all the other residents of Vraja cannot give up our constant affection for your son? And how is it that He is so spontaneously attracted to us?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "प्रिय नंदा, ऐसा कैसे है कि हम और व्रज के अन्य सभी निवासी आपके पुत्र के प्रति अपना निरंतर स्नेह नहीं छोड़ सकते? और ऐसा कैसे है कि वह अनायास ही हमारी ओर आकर्षित हो जाता है?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પ્રિય નંદા, અમે અને વ્રજના અન્ય તમામ રહેવાસીઓ તમારા પુત્ર પ્રત્યેનો અમારો સતત પ્રેમ છોડી શકતા નથી તે કેવી રીતે છે? અને તે આટલું સહજપણે આપણા તરફ કેવી રીતે આકર્ષાય છે?"
            }
        }
    },
    {
        "id": 102614,
        "sloka": "10.26.14",
        "verse_id": 102614,
        "verseNumber": 14,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "On the one hand this boy is only seven years old, and on the other we see that He has lifted the great hill Govardhana. Therefore, O King of Vraja, a doubt about your son arises within us."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक ओर यह बालक केवल सात वर्ष का है, और दूसरी ओर हम देखते हैं कि उसने विशाल पर्वत गोवर्धन को उठा लिया है। इसलिए, हे व्रजराज, आपके पुत्र के प्रति हमारे मन में संदेह पैदा हो गया है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક તરફ આ છોકરો માત્ર સાત વર્ષનો છે, અને બીજી તરફ આપણે જોઈએ છીએ કે તેણે ગોવર્ધનની મહાન ટેકરી ઉપાડી છે. તેથી હે વ્રજના રાજા, તમારા પુત્ર વિશે અમારી અંદર સંશય ઉત્પન્ન થાય છે."
            }
        }
    },
    {
        "id": 102615,
        "sloka": "10.26.15",
        "verse_id": 102615,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Nanda Mahārāja replied: O cowherd men, just hear my words and let all your doubts concerning my son be gone. Some time ago Garga Muni spoke to me as follows about this boy."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "नंद महाराज ने उत्तर दिया: हे चरवाहों, बस मेरी बातें सुनो और मेरे पुत्र के संबंध में आपके सभी संदेह दूर हो जाएं। कुछ समय पहले गर्ग मुनि ने मुझसे इस बालक के विषय में इस प्रकार बात की थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "નંદ મહારાજે જવાબ આપ્યો: હે ગોવાળો, મારી વાત સાંભળો અને મારા પુત્ર વિશે તમારી બધી શંકાઓ દૂર કરો. થોડા સમય પહેલા ગર્ગ મુનિએ મારી સાથે આ છોકરા વિશે નીચે મુજબ વાત કરી હતી."
            }
        }
    },
    {
        "id": 102616,
        "sloka": "10.26.16",
        "verse_id": 102616,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Garga Muni had said:] Your son Kṛṣṇa appears as an incarnation in every millennium. In the past He assumed three different colors — white, red and yellow — and now He has appeared in a blackish color."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[गर्ग मुनि ने कहा था:] आपके पुत्र कृष्ण हर सहस्राब्दी में एक अवतार के रूप में प्रकट होते हैं। अतीत में उन्होंने तीन अलग-अलग रंग धारण किए थे - सफेद, लाल और पीला - और अब वह काले रंग में प्रकट हुए हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ગર્ગ મુનિએ કહ્યું હતું:] તમારા પુત્ર કૃષ્ણ દરેક સહસ્ત્રાબ્દીમાં અવતાર તરીકે દેખાય છે. ભૂતકાળમાં તેણે ત્રણ અલગ અલગ રંગો ધારણ કર્યા હતા - સફેદ, લાલ અને પીળો - અને હવે તે કાળા રંગમાં દેખાયા છે."
            }
        }
    },
    {
        "id": 102617,
        "sloka": "10.26.17",
        "verse_id": 102617,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "For many reasons, this beautiful son of yours sometimes appeared previously as the son of Vasudeva. Therefore, those who are learned sometimes call this child Vāsudeva."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अनेक कारणों से आपका यह सुन्दर पुत्र कभी-कभी वासुदेव के पुत्र के रूप में प्रकट होता था। इसलिए, जो विद्वान हैं वे कभी-कभी इस बालक को वासुदेव कहते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ઘણા કારણોસર, તમારો આ સુંદર પુત્ર ક્યારેક વાસુદેવના પુત્ર તરીકે અગાઉ દેખાયો. તેથી, જેઓ વિદ્વાન છે તેઓ ક્યારેક આ બાળકને વાસુદેવ કહે છે."
            }
        }
    },
    {
        "id": 102618,
        "sloka": "10.26.18",
        "verse_id": 102618,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "For this son of yours there are many forms and names according to His transcendental qualities and activities. These are known to me, but people in general do not understand them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "आपके इस पुत्र के दिव्य गुणों और गतिविधियों के अनुसार कई रूप और नाम हैं। ये मुझे ज्ञात हैं, लेकिन आम तौर पर लोग इन्हें नहीं समझते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તમારા આ પુત્ર માટે તેમના દિવ્ય ગુણો અને કાર્યો અનુસાર અનેક રૂપ અને નામ છે. આ મારા માટે જાણીતા છે, પરંતુ સામાન્ય રીતે લોકો તેમને સમજી શકતા નથી."
            }
        }
    },
    {
        "id": 102619,
        "sloka": "10.26.19",
        "verse_id": 102619,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "To increase the transcendental bliss of the cowherd men of Gokula, this child will always act auspiciously for you. And by His grace only, you will surpass all difficulties."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "गोकुल के ग्वालों के दिव्य आनंद को बढ़ाने के लिए यह बालक सदैव आपके लिए शुभ कार्य करेगा। और उनकी कृपा से ही आप सभी कठिनाइयों को पार कर जायेंगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ગોકુળના ગોવાળિયાઓના દિવ્ય આનંદને વધારવા માટે, આ બાળક હંમેશા તમારા માટે શુભ કાર્ય કરશે. અને તેમની કૃપાથી જ તમે બધી મુશ્કેલીઓને પાર કરી શકશો."
            }
        }
    },
    {
        "id": 102620,
        "sloka": "10.26.20",
        "verse_id": 102620,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Nanda Mahārāja, as recorded in history, when there was an irregular, incapable government, Indra having been dethroned, and when honest people were being harassed and disturbed by thieves, this child appeared in order to curb the rogues and to protect the people and enable them to flourish."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे नंद महाराज, जैसा कि इतिहास में दर्ज है, जब एक अनियमित, अक्षम सरकार थी, इंद्र को गद्दी से उतार दिया गया था, और जब ईमानदार लोगों को चोरों द्वारा परेशान किया जा रहा था, तो यह बच्चा दुष्टों पर अंकुश लगाने और लोगों की रक्षा करने और उन्हें फलने-फूलने में सक्षम बनाने के लिए प्रकट हुआ था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે નંદ મહારાજ, ઈતિહાસમાં નોંધ્યા મુજબ, જ્યારે એક અનિયમિત, અસમર્થ સરકાર હતી, ઈન્દ્રને પદભ્રષ્ટ કરવામાં આવ્યો હતો, અને જ્યારે પ્રામાણિક લોકો ચોરો દ્વારા હેરાન-પરેશાન થઈ રહ્યા હતા, ત્યારે આ બાળક બદમાશોને કાબૂમાં રાખવા અને લોકોની સુરક્ષા કરવા અને તેમને વિકાસ કરવા સક્ષમ બનાવવા માટે પ્રગટ થયો."
            }
        }
    },
    {
        "id": 102621,
        "sloka": "10.26.21",
        "verse_id": 102621,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Demons cannot harm the demigods, who always have Lord Viṣṇu on their side. Similarly, any person or group attached to all-auspicious Kṛṣṇa cannot be defeated by enemies."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "राक्षस उन देवताओं को नुकसान नहीं पहुँचा सकते, जिनके पक्ष में सदैव भगवान विष्णु हैं। इसी प्रकार, सर्व-मंगलकारी कृष्ण से जुड़ा कोई भी व्यक्ति या समूह शत्रुओं से पराजित नहीं हो सकता।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "રાક્ષસો દેવતાઓને નુકસાન પહોંચાડી શકતા નથી, જેમની પાસે હંમેશા ભગવાન વિષ્ણુ હોય છે. તેવી જ રીતે, સર્વ-શુભ કૃષ્ણ સાથે જોડાયેલ કોઈપણ વ્યક્તિ અથવા સમૂહને દુશ્મનોથી હરાવી શકાય નહીં."
            }
        }
    },
    {
        "id": 102622,
        "sloka": "10.26.22",
        "verse_id": 102622,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Therefore, O Nanda Mahārāja, this child of yours is as good as Nārāyaṇa. In His transcendental qualities, opulence, name, fame and influence, He is exactly like Nārāyaṇa. Thus you should not be astonished by His activities."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इसलिए, हे नंद महाराज, आपका यह बच्चा नारायण के समान अच्छा है। अपने दिव्य गुणों, ऐश्वर्य, नाम, प्रसिद्धि और प्रभाव में, वह बिल्कुल नारायण के समान हैं। अत: तुम्हें उसकी गतिविधियों से आश्चर्यचकित नहीं होना चाहिए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેથી, હે નંદ મહારાજ, તમારું આ બાળક નારાયણ જેટલું સારું છે. તેમના દિવ્ય ગુણો, ઐશ્વર્ય, નામ, કીર્તિ અને પ્રભાવમાં, તેઓ બિલકુલ નારાયણ જેવા છે. તેથી તમારે તેમની પ્રવૃત્તિઓથી આશ્ચર્ય ન થવું જોઈએ."
            }
        }
    },
    {
        "id": 102623,
        "sloka": "10.26.23",
        "verse_id": 102623,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Nanda Mahārāja continued:] After Garga Ṛṣi spoke these words to me and returned home, I began to consider that Kṛṣṇa, who keeps us free from trouble, is actually an expansion of Lord Nārāyaṇa."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[नंद महाराज ने आगे कहा:] जब गर्ग ऋषि ने मुझसे ये शब्द कहे और घर लौट आए, तो मैंने विचार करना शुरू कर दिया कि कृष्ण, जो हमें परेशानी से मुक्त रखते हैं, वास्तव में भगवान नारायण का विस्तार हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[નંદ મહારાજે ચાલુ રાખ્યું:] ગર્ગ ઋષિએ મને આ શબ્દો કહ્યા અને ઘરે પાછા ફર્યા પછી, મેં વિચારવાનું શરૂ કર્યું કે કૃષ્ણ, જે આપણને મુશ્કેલીમાંથી મુક્ત રાખે છે, તે વાસ્તવમાં ભગવાન નારાયણનું વિસ્તરણ છે."
            }
        }
    },
    {
        "id": 102624,
        "sloka": "10.26.24",
        "verse_id": 102624,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Śukadeva Gosvāmī continued:] Having heard Nanda Mahārāja relate the statements of Garga Muni, the residents of Vṛndāvana became enlivened. Their perplexity was gone, and they worshiped Nanda and Lord Kṛṣṇa with great respect."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[शुकदेव गोस्वामी ने आगे कहा:] नंद महाराज को गर्ग मुनि के कथन सुनाकर, वृन्दावन के निवासी उत्साहित हो गए। उनकी घबराहट दूर हो गई और उन्होंने बड़े आदर के साथ नंद और भगवान कृष्ण की पूजा की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[શુકદેવ ગોસ્વામીએ ચાલુ રાખ્યું:] નંદ મહારાજને ગર્ગ મુનિના નિવેદનો કહેતા સાંભળ્યા પછી, વૃંદાવનના રહેવાસીઓ જીવંત બન્યા. તેમની મૂંઝવણ દૂર થઈ ગઈ, અને તેઓએ નંદ અને ભગવાન કૃષ્ણની ખૂબ આદર સાથે પૂજા કરી."
