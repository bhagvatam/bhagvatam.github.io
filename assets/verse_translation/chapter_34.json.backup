[
    {
        "id": 103401,
        "sloka": "10.34.1",
        "verse_id": 103401,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: One day the cowherd men, eager to take a trip to worship Lord Śiva, traveled by bullock carts to the Ambikā forest."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: एक दिन चरवाहे लोग, भगवान शिव की पूजा करने के लिए यात्रा करने के लिए उत्सुक थे, बैलगाड़ियों से अंबिका वन की ओर यात्रा की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: એક દિવસ ગોવાળિયાઓ, ભગવાન શિવની આરાધના કરવા પ્રવાસ કરવા આતુર, બળદગાડામાં અંબિકા જંગલમાં ગયા."
            }
        }
    },
    {
        "id": 103402,
        "sloka": "10.34.2",
        "verse_id": 103402,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, after arriving there, they bathed in the Sarasvatī and then devotedly worshiped with various paraphernalia the powerful Lord Paśupati and his consort, goddess Ambikā."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, वहां पहुंचने के बाद, उन्होंने सरस्वती में स्नान किया और फिर विभिन्न सामग्रियों से शक्तिशाली भगवान पशुपति और उनकी पत्नी देवी अंबिका की भक्तिपूर्वक पूजा की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, ત્યાં પહોંચ્યા પછી, તેઓએ સરસ્વતીમાં સ્નાન કર્યું અને પછી શક્તિશાળી ભગવાન પશુપતિ અને તેમની પત્ની, દેવી અંબિકાની વિવિધ સામગ્રી સાથે ભક્તિપૂર્વક પૂજા કરી."
            }
        }
    },
    {
        "id": 103403,
        "sloka": "10.34.3",
        "verse_id": 103403,
        "verseNumber": 3,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The cowherd men gave the brāhmaṇas gifts of cows, gold, clothing and cooked grains mixed with honey. Then the cowherds prayed, “May the lord be pleased with us.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "चरवाहों ने ब्राह्मणों को गायें, सोना, कपड़े और शहद के साथ पकाया हुआ अनाज का उपहार दिया। तब ग्वालों ने प्रार्थना की, \"भगवान् हम पर प्रसन्न हों।\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ગોવાળોએ બ્રાહ્મણોને ગાય, સોનું, વસ્ત્રો અને મધ મિશ્રિત રાંધેલા અનાજની ભેટ આપી. પછી ગોવાળિયાઓએ પ્રાર્થના કરી, \"ભગવાન અમારા પર પ્રસન્ન થાઓ.\""
            }
        }
    },
    {
        "id": 103404,
        "sloka": "10.34.4",
        "verse_id": 103404,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Nanda, Sunanda and the other greatly fortunate cowherds spent that night on the bank of the Sarasvatī, strictly observing their vows. They fasted, taking only water."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "नंदा, सुनंदा और अन्य अत्यंत भाग्यशाली ग्वालों ने अपनी प्रतिज्ञाओं का कड़ाई से पालन करते हुए, वह रात सरस्वती के तट पर बिताई। उन्होंने केवल जल ग्रहण कर उपवास किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "નંદા, સુનંદા અને અન્ય મોટા ભાગ્યશાળી ગોવાળોએ તે રાત સરસ્વતીના કિનારે વિતાવી, તેમની પ્રતિજ્ઞાઓનું કડક પાલન કર્યું. તેઓએ ઉપવાસ કર્યા, માત્ર પાણી લીધું."
            }
        }
    },
    {
        "id": 103405,
        "sloka": "10.34.5",
        "verse_id": 103405,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "During the night a huge and extremely hungry snake appeared in that thicket. Slithering on his belly up to the sleeping Nanda Mahārāja, the snake began swallowing him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "रात के समय उस झुरमुट में एक विशाल और अत्यंत भूखा साँप दिखाई दिया। सोते हुए नंद महाराज के पेट पर सरकते हुए सांप ने उन्हें निगलना शुरू कर दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "રાત્રિ દરમિયાન તે ઝાડીમાં એક વિશાળ અને અત્યંત ભૂખ્યો સાપ દેખાયો. તેમના પેટ પર સૂતેલા નંદ મહારાજ તરફ લપસીને, સાપ તેમને ગળી જવા લાગ્યો."
            }
        }
    },
    {
        "id": 103406,
        "sloka": "10.34.6",
        "verse_id": 103406,
        "verseNumber": 6,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In the clutches of the snake, Nanda Mahārāja cried out, “Kṛṣṇa, Kṛṣṇa, my dear boy! This huge serpent is swallowing me! Please save me, who am surrendered to You!”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सांप के चंगुल में, नंद महाराज चिल्लाए, \"कृष्ण, कृष्ण, मेरे प्यारे लड़के! यह विशाल सांप मुझे निगल रहा है! कृपया मुझे बचाएं, जो आपके प्रति समर्पित हूं!\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "સાપની પકડમાં, નંદ મહારાજે બૂમ પાડી, \"કૃષ્ણ, કૃષ્ણ, મારા પ્રિય છોકરા! આ વિશાળ સર્પ મને ગળી રહ્યો છે! કૃપા કરીને મને બચાવો, જે તમને શરણે છું!\""
            }
        }
    },
    {
        "id": 103407,
        "sloka": "10.34.7",
        "verse_id": 103407,
        "verseNumber": 7,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When the cowherd men heard the cries of Nanda, they immediately rose up and saw that he was being swallowed. Distraught, they beat the serpent with blazing torches."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब चरवाहों ने नंदा की चीख सुनी तो वे तुरंत उठे और देखा कि उन्हें निगला जा रहा है। व्याकुल होकर, उन्होंने जलती हुई मशालों से साँप को पीटा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે ગોવાળિયાઓએ નંદાની બૂમો સાંભળી, તેઓ તરત જ ઉભા થયા અને જોયું કે તે ગળી રહ્યો હતો. પરેશાન થઈને, તેઓએ સળગતી મશાલો વડે સર્પને માર્યો."
            }
        }
    },
    {
        "id": 103408,
        "sloka": "10.34.8",
        "verse_id": 103408,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "But even though the firebrands were burning him, the serpent would not release Nanda Mahārāja. Then the Supreme Lord Kṛṣṇa, master of His devotees, came to the spot and touched the snake with His foot."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "लेकिन भले ही आग की लपटें उन्हें जला रही थीं, फिर भी सांप ने नंद महाराज को नहीं छोड़ा। तब अपने भक्तों के स्वामी भगवान कृष्ण उस स्थान पर आये और उन्होंने साँप को अपने पैर से छुआ।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પરંતુ અગ્નિદાળો તેમને બાળી રહ્યા હોવા છતાં, નાગ નંદ મહારાજને છોડશે નહીં. પછી પરમ ભગવાન કૃષ્ણ, તેમના ભક્તોના ગુરુ, સ્થળ પર આવ્યા અને તેમના પગથી સાપને સ્પર્શ કર્યો."
            }
        }
    },
    {
        "id": 103409,
        "sloka": "10.34.9",
        "verse_id": 103409,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The snake had all his sinful reactions destroyed by the touch of the Supreme Lord’s divine foot, and thus he gave up his serpent body and appeared in the form of a worshipable Vidyādhara."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान के दिव्य चरण के स्पर्श से साँप के सभी पाप नष्ट हो गए, और इस प्रकार उसने अपना साँप शरीर त्याग दिया और एक पूजनीय विद्याधर के रूप में प्रकट हुआ।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પરમ ભગવાનના દૈવી પગના સ્પર્શથી સાપે તેની બધી પાપી પ્રતિક્રિયાઓનો નાશ કર્યો, અને આ રીતે તેણે તેના સર્પ શરીરનો ત્યાગ કર્યો અને પૂજાપાત્ર વિદ્યાધરાના રૂપમાં પ્રગટ થયો."
            }
        }
    },
    {
        "id": 103410,
        "sloka": "10.34.10",
        "verse_id": 103410,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The Supreme Lord Hṛṣīkeśa then questioned this personality, who was standing before Him with his head bowed, his brilliantly effulgent body bedecked with golden necklaces."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तब परम भगवान हृषीकेश ने इस व्यक्तित्व से प्रश्न किया, जो उनके सामने सिर झुकाए खड़ा था, उसका तेजस्वी शरीर स्वर्ण हारों से सुसज्जित था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પરમ ભગવાન હૃષિકેશએ પછી આ વ્યક્તિત્વને પ્રશ્ન કર્યો, જેઓ તેમની સામે માથું નમાવીને ઊભા હતા, તેમના તેજસ્વી તેજસ્વી શરીરને સોનાના હારથી શણગારેલું હતું."
            }
        }
    },
    {
        "id": 103411,
        "sloka": "10.34.11",
        "verse_id": 103411,
        "verseNumber": 11,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Lord Kṛṣṇa said:] My dear sir, you appear so wonderful, glowing with such great beauty. Who are you? And who forced you to assume this terrible body of a snake?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[भगवान कृष्ण ने कहा:] मेरे प्रिय महोदय, आप इतने अद्भुत, इतनी महान सुंदरता से चमकते हुए दिखाई देते हैं। आप कौन हैं? और तुम्हें सर्प का यह भयानक शरीर धारण करने के लिए किसने बाध्य किया?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ભગવાન કૃષ્ણએ કહ્યું:] મારા પ્રિય સાહેબ, તમે ખૂબ જ અદ્ભુત દેખાશો, આટલી મહાન સુંદરતાથી ઝળહળી રહ્યાં છો. તમે કોણ છો? અને તમને સાપનું આ ભયંકર શરીર ધારણ કરવા કોણે મજબૂર કર્યું?"
            }
        }
    },
    {
        "id": 103412,
        "sloka": "10.34.12-13",
        "verse_id": 103412,
        "verseNumber": 12,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The serpent replied: I am the well-known Vidyādhara named Sudarśana. I was very opulent and beautiful, and I used to wander freely in all directions in my airplane. Once I saw some homely sages of the lineage of Aṅgirā Muni. Proud of my beauty, I ridiculed them, and because of my sin they made me assume this lowly form."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सर्प ने उत्तर दिया: मैं सुदर्शन नाम का प्रसिद्ध विद्याधर हूं। मैं अत्यंत ऐश्वर्यशाली तथा सुन्दर था तथा अपने विमान पर सवार होकर सभी दिशाओं में स्वच्छन्द विचरण करता था। एक बार मैंने अंगिरा मुनि के वंश के कुछ घरेलू ऋषियों को देखा। मैंने अपनी सुंदरता पर गर्व करके उनका उपहास किया और मेरे पाप के कारण उन्होंने मुझे यह नीच रूप धारण कराया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "સર્પે જવાબ આપ્યો: હું સુદર્શન નામની જાણીતી વિદ્યાધારા છું. હું ખૂબ જ વૈભવી અને સુંદર હતો, અને હું મારા વિમાનમાં બધી દિશાઓમાં મુક્તપણે ભટકતો હતો. એકવાર મેં અંગીરા મુનિના વંશના કેટલાક ગૃહસ્થ મુનિઓને જોયા. મારી સુંદરતા પર ગર્વ કરીને, મેં તેમની મજાક ઉડાવી, અને મારા પાપને લીધે તેઓએ મને આ નીચ સ્વરૂપ ધારણ કર્યું."
            }
        }
    },
    {
        "id": 103414,
        "sloka": "10.34.14",
        "verse_id": 103414,
        "verseNumber": 14,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "It was actually for my benefit that those merciful sages cursed me, since now I have been touched by the foot of the supreme spiritual master of all the worlds and have thus been relieved of all inauspiciousness."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यह वास्तव में मेरे लाभ के लिए था कि उन दयालु ऋषियों ने मुझे शाप दिया, क्योंकि अब मुझे सभी संसारों के सर्वोच्च आध्यात्मिक गुरु के चरण का स्पर्श मिला है और इस प्रकार सभी अशुभताओं से छुटकारा मिल गया है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વાસ્તવમાં તે દયાળુ ઋષિમુનિઓએ મને શ્રાપ આપ્યો તે મારા લાભ માટે હતું, કારણ કે હવે હું સર્વ જગતના પરમ આધ્યાત્મિક ગુરુના ચરણસ્પર્શ પામ્યો છું અને આ રીતે તમામ અશુભતામાંથી મુક્ત થયો છું."
            }
        }
    },
    {
        "id": 103415,
        "sloka": "10.34.15",
        "verse_id": 103415,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My Lord, You destroy all fear for those who, fearing this material world, take shelter of You. By the touch of Your feet I am now freed from the curse of the sages. O destroyer of distress, please let me return to my planet."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे प्रभु, आप उन लोगों के सभी भय को नष्ट कर देते हैं, जो इस भौतिक संसार से डरकर आपकी शरण लेते हैं। आपके चरणों के स्पर्श से अब मैं ऋषियों के श्राप से मुक्त हो गया हूँ। हे संकट विनाशक, कृपया मुझे मेरे ग्रह पर लौटने दो।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે પ્રભુ, જેઓ આ ભૌતિક જગતથી ડરીને તમારો આશ્રય લે છે તેમના માટે તમે બધા ભયનો નાશ કરો છો. તમારા ચરણસ્પર્શથી હું હવે ઋષિઓના શ્રાપમાંથી મુક્ત થયો છું. હે સંકટનો નાશ કરનાર, કૃપા કરીને મને મારા ગ્રહ પર પાછા ફરવા દો."
            }
        }
    },
    {
        "id": 103416,
        "sloka": "10.34.16",
        "verse_id": 103416,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O master of mystic power, O great personality, O Lord of the devotees, I surrender to You. Please command me as You will, O supreme God, Lord of all lords of the universe."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे रहस्यमय शक्ति के स्वामी, हे महान व्यक्तित्व, हे भक्तों के भगवान, मैं आपके प्रति समर्पण करता हूं। कृपया मुझे अपनी इच्छानुसार आज्ञा दें, हे सर्वोच्च ईश्वर, ब्रह्मांड के सभी प्रभुओं के स्वामी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રહસ્યમય શક્તિના માલિક, હે મહાન વ્યક્તિત્વ, હે ભક્તોના ભગવાન, હું તમને શરણે છું. બ્રહ્માંડના સર્વ અધિપતિઓના પ્રભુ, હે સર્વોપરી ભગવાન, તમારી ઈચ્છા મુજબ મને આજ્ઞા કરો."
            }
        }
    },
    {
        "id": 103417,
        "sloka": "10.34.17",
        "verse_id": 103417,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O infallible one, I was immediately freed from the brāhmaṇas’ punishment simply by seeing You. Anyone who chants Your name purifies all who hear his chanting, as well as himself. How much more beneficial, then, is the touch of Your lotus feet?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे अच्युत, आपके दर्शन मात्र से मैं तुरंत ब्राह्मणों के दंड से मुक्त हो गया। जो कोई आपके नाम का जप करता है, वह उसका जप सुनने वाले सभी लोगों को, साथ ही स्वयं को भी शुद्ध कर लेता है। तो फिर आपके चरणकमलों का स्पर्श कितना अधिक लाभदायक है?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે અચૂક, તમને જોઈને જ હું બ્રાહ્મણોની સજામાંથી તરત જ મુક્ત થઈ ગયો. જે કોઈ તમારા નામનો જપ કરે છે તે તેના જપ સાંભળનારા બધાને તેમજ પોતાની જાતને શુદ્ધ કરે છે. તો પછી, તમારા કમળના ચરણોનો સ્પર્શ કેટલો વધુ ફાયદાકારક છે?"
            }
        }
    },
    {
        "id": 103418,
        "sloka": "10.34.18",
        "verse_id": 103418,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Thus receiving the permission of Lord Kṛṣṇa, the demigod Sudarśana circumambulated Him, bowed down to offer Him homage and then returned to his heavenly planet. Nanda Mahārāja was thus delivered from peril."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार भगवान कृष्ण की अनुमति प्राप्त करने पर, देवता सुदर्शन ने उनकी परिक्रमा की, उन्हें प्रणाम करने के लिए झुके और फिर अपने स्वर्गीय ग्रह पर लौट आए। इस प्रकार नंद महाराज को संकट से मुक्ति मिली।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે ભગવાન કૃષ્ણની અનુમતિ મેળવીને, દેવતા સુદર્શને તેમની પ્રદક્ષિણા કરી, તેમને અંજલિ આપવા માટે પ્રણામ કર્યા અને પછી તેમના સ્વર્ગીય ગ્રહ પર પાછા ફર્યા. આ રીતે નંદ મહારાજ સંકટમાંથી મુક્ત થયા."
            }
        }
    },
    {
        "id": 103419,
        "sloka": "10.34.19",
        "verse_id": 103419,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The inhabitants of Vraja were astonished to see the mighty power of Śrī Kṛṣṇa. Dear King, they then completed their worship of Lord Śiva and returned to Vraja, along the way respectfully describing Kṛṣṇa’s powerful acts."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "व्रजवासी श्रीकृष्ण की शक्ति देखकर आश्चर्यचकित रह गये। प्रिय राजा, फिर उन्होंने भगवान शिव की पूजा पूरी की और व्रज लौट आए, और रास्ते में सम्मानपूर्वक कृष्ण के शक्तिशाली कृत्यों का वर्णन किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "વ્રજના રહેવાસીઓ શ્રી કૃષ્ણની પરાક્રમી શક્તિ જોઈને આશ્ચર્યચકિત થઈ ગયા. પ્રિય રાજા, પછી તેઓએ ભગવાન શિવની તેમની પૂજા પૂર્ણ કરી અને વ્રજમાં પાછા ફર્યા, રસ્તામાં કૃષ્ણના શક્તિશાળી કાર્યોનું આદરપૂર્વક વર્ણન કર્યું."
            }
        }
    },
    {
        "id": 103420,
        "sloka": "10.34.20",
        "verse_id": 103420,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Once Lord Govinda and Lord Rāma, the performers of wonderful feats, were playing in the forest at night with the young girls of Vraja."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक बार अद्भुत करतब दिखाने वाले भगवान गोविंद और भगवान राम, व्रज की युवा लड़कियों के साथ रात में जंगल में खेल रहे थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એકવાર ભગવાન ગોવિંદ અને ભગવાન રામ, અદ્ભુત પરાક્રમો કરનારા, વ્રજની યુવતીઓ સાથે રાત્રે જંગલમાં રમતા હતા."
            }
        }
    },
    {
        "id": 103421,
        "sloka": "10.34.21",
        "verse_id": 103421,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kṛṣṇa and Balarāma wore flower garlands and spotless garments, and Their limbs were beautifully decorated and anointed. The women sang Their glories in a charming way, bound to Them by affection."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण और बलराम ने फूलों की माला और बेदाग वस्त्र पहने थे, और उनके अंगों को खूबसूरती से सजाया और अभिषेक किया गया था। स्त्रियों ने स्नेह से बँधकर उनकी महिमा का गान मनमोहक ढंग से किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણ અને બલરામે ફૂલોની માળા અને નિષ્કલંક વસ્ત્રો પહેર્યા હતા, અને તેમના અંગો સુંદર રીતે શણગારેલા અને અભિષેક કરવામાં આવ્યા હતા. સ્ત્રીઓએ તેમના મહિમાને મોહક રીતે ગાયું, તેમને સ્નેહથી બંધાઈ."
            }
        }
    },
    {
        "id": 103422,
        "sloka": "10.34.22",
        "verse_id": 103422,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The two Lords praised the nightfall, signaled by the rising of the moon and the appearance of stars, a lotus-scented breeze and bees intoxicated by the fragrance of jasmine flowers."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "दोनों भगवानों ने रात होने की प्रशंसा की, जो चंद्रमा के उदय और सितारों की उपस्थिति, कमल-सुगंधित हवा और चमेली के फूलों की सुगंध से मदहोश मधुमक्खियों द्वारा संकेत दिया गया था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ચંદ્રના ઉદય અને તારાઓના દેખાવ, કમળ-સુગંધી પવનની લહેરો અને જાસ્મિનના ફૂલોની સુગંધથી નશામાં મધમાખીઓ દ્વારા સંકેત આપવામાં આવતા બંને ભગવાનોએ રાત્રિના સમયની પ્રશંસા કરી."
            }
        }
    },
    {
        "id": 103423,
        "sloka": "10.34.23",
        "verse_id": 103423,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kṛṣṇa and Balarāma sang, producing the entire range of musical sounds simultaneously. Their singing brought happiness to the ears and minds of all living beings."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण और बलराम ने एक साथ संपूर्ण संगीत ध्वनियाँ उत्पन्न करते हुए गाया। उनके गायन से सभी प्राणियों के कानों और मन को खुशी मिलती थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણ અને બલરામે ગાયું, સંગીતના અવાજોની સમગ્ર શ્રેણી એકસાથે ઉત્પન્ન કરી. તેમના ગાયનથી તમામ જીવોના કાન અને મનમાં ખુશીઓ આવી."
            }
        }
    },
    {
        "id": 103424,
        "sloka": "10.34.24",
        "verse_id": 103424,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The gopīs became stunned when they heard that song. Forgetting themselves, O King, they did not notice that their fine garments were becoming loose and their hair and garlands disheveled."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वह गीत सुनकर गोपियाँ दंग रह गईं। हे राजा, वे अपने आप को भूलकर ध्यान ही नहीं दे रहे थे कि उनके सुन्दर वस्त्र ढीले हो रहे हैं और उनके बाल तथा मालाएँ अस्त-व्यस्त हो गयी हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એ ગીત સાંભળીને ગોપીઓ સ્તબ્ધ થઈ ગઈ. હે રાજા, પોતાની જાતને ભૂલીને, તેઓએ જોયું નહીં કે તેમના સુંદર વસ્ત્રો ઢીલા થઈ રહ્યા છે અને તેમના વાળ અને માળા વિખરાયેલા છે."
            }
        }
    },
    {
        "id": 103425,
        "sloka": "10.34.25",
        "verse_id": 103425,
        "verseNumber": 25,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "While Lord Kṛṣṇa and Lord Balarāma thus played according to Their own sweet will and sang to the point of apparent intoxication, a servant of Kuvera named Śaṅkhacūḍa came upon the scene."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब भगवान कृष्ण और भगवान बलराम इस प्रकार अपनी मधुर इच्छा के अनुसार खेल रहे थे और नशे की हद तक गा रहे थे, शंखचूड़ नामक कुवेर का एक सेवक वहां आया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે ભગવાન કૃષ્ણ અને ભગવાન બલરામ આ રીતે તેમની પોતાની મીઠી ઇચ્છા મુજબ રમ્યા અને દેખીતી નશાની જગ્યાએ ગાયા, ત્યારે કુવેરનો એક સેવક શંખચૂડ દ્રશ્ય પર આવ્યો."
            }
        }
    },
    {
        "id": 103426,
        "sloka": "10.34.26",
        "verse_id": 103426,
        "verseNumber": 26,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, even as the two Lords looked on, Śaṅkhacūḍa brazenly began driving the women off toward the north. The women, who had accepted Kṛṣṇa and Balarāma as their Lords, began to cry out to Them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, जब दोनों भगवान देखते रहे, शंखचूड़ ने बेशर्मी से महिलाओं को उत्तर की ओर भगाना शुरू कर दिया। वे स्त्रियाँ, जिन्होंने कृष्ण और बलराम को अपना भगवान मान लिया था, उन्हें पुकारने लगीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, બે ભગવાને જોતાં જ, શંખચૂડાએ નિર્લજ્જતાથી સ્ત્રીઓને ઉત્તર તરફ ભગાડવાનું શરૂ કર્યું. સ્ત્રીઓ, જેમણે કૃષ્ણ અને બલરામને તેમના ભગવાન તરીકે સ્વીકાર્યા હતા, તેઓને બૂમો પાડવા લાગી."
            }
        }
    },
    {
        "id": 103427,
        "sloka": "10.34.27",
        "verse_id": 103427,
        "verseNumber": 27,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Hearing Their devotees crying out “Kṛṣṇa! Rāma!” and seeing that they were just like cows being stolen by a thief, Kṛṣṇa and Balarāma began to run after the demon."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपने भक्तों को \"कृष्ण! राम!\" चिल्लाते हुए सुनना। और यह देखकर कि वे चोर द्वारा चुराई जा रही गायों के समान हैं, कृष्ण और बलराम राक्षस के पीछे भागने लगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમના ભક્તોને \"કૃષ્ણ! રામ!\" પોકારતા સાંભળીને. અને તે જોઈને કે તેઓ ગાયોની જેમ ચોર ચોરી કરે છે, કૃષ્ણ અને બલરામ રાક્ષસની પાછળ દોડવા લાગ્યા."
            }
        }
    },
    {
        "id": 103428,
        "sloka": "10.34.28",
        "verse_id": 103428,
        "verseNumber": 28,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The Lords called out in reply, “Do not fear!” Then They picked up logs of the śala tree and quickly pursued that lowest of Guhyakas, who swiftly ran away."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यहोवा ने उत्तर में कहा, “डरो मत!” फिर उन्होंने शाल वृक्ष की लकड़ियाँ उठाईं और तेजी से सबसे निचले गुह्यकों का पीछा किया, जो तेजी से भाग गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પ્રભુએ જવાબમાં બૂમ પાડી, \"ડરશો નહિ!\" પછી તેઓએ શલાના ઝાડના લોગ ઉપાડ્યા અને ઝડપથી ગુહ્યકના સૌથી નીચલા ભાગનો પીછો કર્યો, જેઓ ઝડપથી ભાગી ગયા."
            }
        }
    },
    {
        "id": 103429,
        "sloka": "10.34.29",
        "verse_id": 103429,
        "verseNumber": 29,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When Śaṅkhacūḍa saw the two of Them coming toward him like the personified forces of Time and Death, he was filled with anxiety. Confused, he abandoned the women and fled for his life."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब शंखचूड़ ने उन दोनों को समय और मृत्यु की साक्षात शक्तियों की तरह अपनी ओर आते देखा, तो वह चिंता से भर गया। भ्रमित होकर, उसने महिलाओं को छोड़ दिया और अपनी जान बचाने के लिए भाग गया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે શંખચૂડાએ તે બંનેને સમય અને મૃત્યુના મૂર્તિમંત દળોની જેમ પોતાની તરફ આવતા જોયા, ત્યારે તે ચિંતાથી ભરાઈ ગયો. મૂંઝવણમાં, તેણે મહિલાઓને છોડી દીધી અને તેના જીવન માટે ભાગી ગયો."
            }
        }
    },
    {
        "id": 103430,
        "sloka": "10.34.30",
        "verse_id": 103430,
        "verseNumber": 30,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Govinda chased the demon wherever he ran, eager to take his crest jewel. Meanwhile Lord Balarāma stayed with the women to protect them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान गोविंदा ने राक्षस का पीछा किया, जहां भी वह भागता था, उसकी शिखा मणि लेने के लिए उत्सुक था। इस बीच भगवान बलराम महिलाओं की रक्षा के लिए उनके साथ रहे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન ગોવિંદે રાક્ષસનો પીછો કર્યો જ્યાં તેઓ દોડ્યા, તેમના શિખર રત્ન લેવા આતુર હતા. આ દરમિયાન ભગવાન બલરામ મહિલાઓની રક્ષા માટે તેમની સાથે રહ્યા."
            }
        }
    },
    {
        "id": 103431,
        "sloka": "10.34.31",
        "verse_id": 103431,
        "verseNumber": 31,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The mighty Lord overtook Śaṅkhacūḍa from a great distance as if from nearby, my dear King, and then with His fist the Lord removed the wicked demon’s head, together with his crest jewel."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रिय राजा, शक्तिशाली भगवान ने बड़ी दूरी से शंखचूड़ को पकड़ लिया, जैसे कि पास से, और फिर अपनी मुट्ठी से भगवान ने दुष्ट राक्षस के सिर को उसकी शिखा मणि सहित हटा दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પરાક્રમી ભગવાન શંખચૂડને ખૂબ દૂરથી પછાડ્યા જાણે નજીકના, મારા પ્રિય રાજા, અને પછી ભગવાને તેમની મુઠ્ઠી વડે દુષ્ટ રાક્ષસનું માથું કાઢી નાખ્યું, સાથે સાથે તેમના શિખર રત્ન પણ."
            }
        }
    },
    {
        "id": 103432,
        "sloka": "10.34.32",
        "verse_id": 103432,
        "verseNumber": 32,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Having thus killed the demon Śaṅkhacūḍa and taken away his shining jewel, Lord Kṛṣṇa gave it to His elder brother with great satisfaction as the gopīs watched."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार राक्षस शंखचूड़ को मारकर और उसका चमकता हुआ आभूषण छीनकर, भगवान कृष्ण ने गोपियों के देखते-देखते बड़ी संतुष्टि के साथ उसे अपने बड़े भाई को दे दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે રાક્ષસ શંખચૂડને મારી નાખ્યા અને તેનું ચમકતું રત્ન લઈ લીધું, ભગવાન કૃષ્ણએ તે તેમના મોટા ભાઈને ખૂબ જ સંતોષ સાથે આપ્યું કારણ કે ગોપીઓ જોઈ રહી હતી."
            }
        }
    }
]