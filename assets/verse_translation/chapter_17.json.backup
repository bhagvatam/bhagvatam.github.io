[
    {
        "id": 101701,
        "sloka": "10.17.1",
        "verse_id": 101701,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Having thus heard how Lord Kṛṣṇa chastised Kāliya,] King Parīkṣit inquired: Why did Kāliya leave Ramaṇaka Island, the abode of the serpents, and why did Garuḍa become so antagonistic toward him alone?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[इस प्रकार यह सुनकर कि भगवान कृष्ण ने कालिया को कैसे दंडित किया,] राजा परीक्षित ने पूछा: कालिया ने नागों के निवास रमणक द्वीप को क्यों छोड़ दिया, और गरुड़ अकेले उसके प्रति इतना विरोधी क्यों हो गया?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[આ રીતે સાંભળીને કે ભગવાન કૃષ્ણએ કાલિયાને કેવી રીતે શિક્ષા કરી હતી,] રાજા પરીક્ષિતે પૂછ્યું: કાલિયાએ શા માટે રામાણક ટાપુ, સર્પોનું નિવાસસ્થાન છોડી દીધું, અને શા માટે ગરુડ એકલા તેના પ્રત્યે આટલા વિરોધી બન્યા?"
            }
        }
    },
    {
        "id": 101702,
        "sloka": "10.17.2-3",
        "verse_id": 101702,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: To avoid being eaten by Garuḍa, the serpents had previously made an arrangement with him whereby they would each make a monthly offering of tribute at the base of a tree. Thus every month on schedule, O mighty-armed King Parīkṣit, each serpent would duly make his offering to that powerful carrier of Viṣṇu as a purchase of protection."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: गरुड़ द्वारा खाए जाने से बचने के लिए, नागों ने पहले उसके साथ एक व्यवस्था की थी जिसके तहत वे प्रत्येक पेड़ के आधार पर मासिक श्रद्धांजलि अर्पित करेंगे। इस प्रकार हर महीने निर्धारित समय पर, हे महाबाहु राजा परीक्षित, प्रत्येक सर्प सुरक्षा की खरीद के रूप में विष्णु के उस शक्तिशाली वाहक को विधिवत अपनी भेंट देगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: ગરુડ દ્વારા ખાવામાં ન આવે તે માટે, સર્પોએ અગાઉ તેમની સાથે એક વ્યવસ્થા કરી હતી જેમાં તેઓ દરેક એક વૃક્ષના પાયા પર માસિક અર્પણ કરશે. આ રીતે દર મહિને સમયપત્રક પર, હે શક્તિશાળી-શસ્ત્રધારી રાજા પરીક્ષિત, દરેક સર્પ સંરક્ષણની ખરીદી તરીકે વિષ્ણુના તે શક્તિશાળી વાહકને વિધિવત રીતે પોતાનો અર્પણ કરશે."
            }
        }
    },
    {
        "id": 101704,
        "sloka": "10.17.4",
        "verse_id": 101704,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Although all the other serpents were dutifully making offerings to Garuḍa, one serpent — the arrogant Kāliya, son of Kadru — would eat all these offerings before Garuḍa could claim them. Thus Kāliya directly defied the carrier of Lord Viṣṇu."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हालाँकि अन्य सभी साँप कर्तव्यपूर्वक गरुड़ को प्रसाद चढ़ा रहे थे, एक साँप - कद्रू का पुत्र अभिमानी कालिया - गरुड़ के दावा करने से पहले इन सभी प्रसादों को खा जाता था। इस प्रकार कालिया ने सीधे तौर पर भगवान विष्णु के वाहक को ललकारा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "અન્ય તમામ સર્પો ગરુડને કર્તવ્યપૂર્વક અર્પણ કરતા હોવા છતાં, એક સર્પ - કદ્રુનો પુત્ર ઘમંડી કાલિયા - ગરુડ તેમના પર દાવો કરે તે પહેલાં આ તમામ પ્રસાદ ખાશે. આ રીતે કાલિયાએ ભગવાન વિષ્ણુના વાહકનો સીધો અવમાન કર્યો."
            }
        }
    },
    {
        "id": 101705,
        "sloka": "10.17.5",
        "verse_id": 101705,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, the greatly powerful Garuḍa, who is very dear to the Supreme Lord, became angry when he heard of this. Desiring to kill Kāliya, he rushed toward the serpent with tremendous speed."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, अत्यंत शक्तिशाली गरुड़, जो परम भगवान को बहुत प्रिय हैं, यह सुनकर क्रोधित हो गए। कालिया को मारने की इच्छा से वह अत्यंत वेग से नाग की ओर झपटा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, મહાન શક્તિશાળી ગરુડ, જે પરમ ભગવાનને ખૂબ જ પ્રિય છે, તે સાંભળીને ગુસ્સે થઈ ગયા. કાલિયાને મારવાની ઈચ્છા રાખીને, તે પ્રચંડ ઝડપે સર્પ તરફ ધસી ગયો."
            }
        }
    },
    {
        "id": 101706,
        "sloka": "10.17.6",
        "verse_id": 101706,
        "verseNumber": 6,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As Garuḍa swiftly fell upon him, Kāliya, who had the weapon of poison, raised his numerous heads to counterattack. Showing his ferocious tongues and expanding his horrible eyes, Kāliya then bit Garuḍa with the weapons of his fangs."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जैसे ही गरुड़ तेजी से उस पर गिरा, कालिया, जिसके पास जहर का हथियार था, ने जवाबी हमला करने के लिए अपने कई सिर उठाए। तब कालिया ने अपनी क्रूर जीभ दिखाते हुए और अपनी भयानक आँखें फैलाते हुए गरुड़ को अपने नुकीले हथियारों से काट डाला।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જેમ જેમ ગરુડ ઝડપથી તેના પર પડ્યો, કાલિયા, જેની પાસે ઝેરનું શસ્ત્ર હતું, તેણે વળતો હુમલો કરવા માટે તેના અસંખ્ય માથા ઉભા કર્યા. તેની વિકરાળ જીભ બતાવીને અને તેની ભયાનક આંખોને વિસ્તૃત કરીને, કાલિયાએ પછી ગરુડને તેની ફેણના શસ્ત્રોથી ડંખ માર્યો."
            }
        }
    },
    {
        "id": 101707,
        "sloka": "10.17.7",
        "verse_id": 101707,
        "verseNumber": 7,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The angry son of Tārkṣya moved with overwhelming speed in repelling Kāliya’s attack. That terribly powerful carrier of Lord Madhusūdana struck the son of Kadru with his left wing, which shone like gold."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तार्क्ष्य का क्रोधित पुत्र कालिया के आक्रमण को विफल करने के लिए तीव्र गति से आगे बढ़ा। भगवान मधुसूदन के उस अत्यंत शक्तिशाली वाहक ने अपने बाएं पंख से कद्रू के पुत्र पर प्रहार किया, जो सोने के समान चमक उठा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તારક્યનો ક્રોધિત પુત્ર કાલિયાના હુમલાને નિવારવા માટે અતિશય ઝડપે આગળ વધ્યો. ભગવાન મધુસૂદનના તે ભયંકર શક્તિશાળી વાહકે કદ્રુના પુત્રને તેની ડાબી પાંખ વડે પ્રહાર કર્યો, જે સોનાની જેમ ચમકતી હતી."
            }
        }
    },
    {
        "id": 101708,
        "sloka": "10.17.8",
        "verse_id": 101708,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Beaten by Garuḍa’s wing, Kāliya was extremely distraught, and thus he took shelter of a lake adjoining the river Yamunā. Garuḍa could not enter this lake. Indeed, he could not even approach it."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "गरुड़ के पंख से मारा गया कालिया अत्यंत व्याकुल था, और इस प्रकार उसने यमुना नदी से सटे एक झील में शरण ली। गरुड़ इस झील में प्रवेश नहीं कर सकते थे। दरअसल, वह इसके करीब भी नहीं पहुंच सका।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ગરુડની પાંખથી માર મારવાથી, કાલિયા અત્યંત વિચલિત થઈ ગયો હતો, અને આ રીતે તેણે યમુના નદીને અડીને આવેલા તળાવનો આશરો લીધો હતો. ગરુડ આ સરોવરમાં પ્રવેશી શક્યા ન હતા. ખરેખર, તે તેની નજીક પણ જઈ શક્યો નહીં."
            }
        }
    },
    {
        "id": 101709,
        "sloka": "10.17.9",
        "verse_id": 101709,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In that very lake Garuḍa had once desired to eat a fish — fish being, after all, his normal food. Although forbidden by the sage Saubhari, who was meditating there within the water, Garuḍa took courage and, feeling hungry, seized the fish."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उसी झील में गरुड़ को एक बार मछली खाने की इच्छा हुई - मछली, आखिरकार, उनका सामान्य भोजन थी। हालाँकि पानी के भीतर ध्यान कर रहे ऋषि सौभरि ने मना किया था, फिर भी गरुड़ ने साहस दिखाया और भूख लगने पर मछली पकड़ ली।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે જ તળાવમાં ગરુડને એકવાર માછલી ખાવાની ઈચ્છા થઈ હતી - માછલી, છેવટે, તેનો સામાન્ય ખોરાક. ઋષિ સૌભારી દ્વારા પ્રતિબંધિત હોવા છતાં, જે ત્યાં પાણીની અંદર ધ્યાન કરી રહ્યા હતા, ગરુડએ હિંમત બતાવી અને, ભૂખ લાગતા, માછલી પકડી લીધી."
            }
        }
    },
    {
        "id": 101710,
        "sloka": "10.17.10",
        "verse_id": 101710,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Seeing how the unfortunate fish in that lake had become most unhappy at the death of their leader, Saubhari uttered the following curse under the impression that he was mercifully acting for the benefit of the lake’s residents."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यह देखकर कि उस झील की दुर्भाग्यपूर्ण मछलियाँ अपने नेता की मृत्यु से सबसे अधिक दुखी हो गई थीं, सौभरि ने इस धारणा के तहत निम्नलिखित श्राप दिया कि वह झील के निवासियों के लाभ के लिए दयापूर्वक कार्य कर रहा था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે તળાવની કમનસીબ માછલીઓ તેમના નેતાના મૃત્યુથી કેવી રીતે સૌથી વધુ દુ:ખી થઈ ગઈ તે જોઈને, સૌભારીએ નીચેનો શ્રાપ એવો અભિપ્રાય આપ્યો કે તે તળાવના રહેવાસીઓના હિત માટે દયાળુ વર્તન કરી રહ્યો છે."
            }
        }
    },
    {
        "id": 101711,
        "sloka": "10.17.11",
        "verse_id": 101711,
        "verseNumber": 11,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "If Garuḍa ever again enters this lake and eats the fish here, he will immediately lose his life. What I am saying is the truth."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यदि गरुड़ फिर कभी इस झील में प्रवेश करेगा और यहाँ की मछलियाँ खाएगा, तो वह तुरंत अपनी जान गँवा देगा। मैं जो कह रहा हूं वह सत्य है."
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જો ગરુડ ફરી ક્યારેય આ તળાવમાં પ્રવેશ કરે છે અને અહીંની માછલીઓ ખાય છે, તો તે તરત જ પોતાનો જીવ ગુમાવશે. હું જે કહું છું તે સત્ય છે."
            }
        }
    },
    {
        "id": 101712,
        "sloka": "10.17.12",
        "verse_id": 101712,
        "verseNumber": 12,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Of all the serpents, only Kāliya came to know of this affair, and in fear of Garuḍa he took up residence in that Yamunā lake. Later Lord Kṛṣṇa drove him out."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सभी नागों में से केवल कालिया को ही इस बात का पता चला और उसने गरुड़ के डर से उस यमुना झील में निवास करना शुरू कर दिया। बाद में भगवान कृष्ण ने उसे बाहर निकाल दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બધા સર્પોમાંથી, ફક્ત કાલિયાને જ આ બાબતની જાણ થઈ, અને ગરુડના ડરથી તેણે તે યમુના તળાવમાં નિવાસ કર્યો. પાછળથી ભગવાન કૃષ્ણે તેને બહાર કાઢી મૂક્યો."
            }
        }
    },
    {
        "id": 101713,
        "sloka": "10.17.13-14",
        "verse_id": 101713,
        "verseNumber": 13,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Resuming his description of Kṛṣṇa’s chastisement of Kāliya, Śukadeva Gosvāmī continued:] Kṛṣṇa rose up out of the lake wearing divine garlands, fragrances and garments, covered with many fine jewels, and decorated with gold. When the cowherds saw Him they all stood up immediately, just like an unconscious person’s senses coming back to life. Filled with great joy, they affectionately embraced Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[कृष्ण द्वारा कालिया को दंडित करने के अपने वर्णन को फिर से शुरू करते हुए, शुकदेव गोस्वामी ने आगे कहा:] कृष्ण दिव्य मालाएं, सुगंधियां और वस्त्र पहने हुए, कई बेहतरीन रत्नों से ढंके हुए और सोने से सजाए गए झील से बाहर निकले। जब चरवाहों ने उन्हें देखा तो वे सभी तुरंत उठ खड़े हुए, जैसे एक बेहोश व्यक्ति की इंद्रियां वापस जीवित हो जाती हैं। अत्यंत प्रसन्नता से भरकर उन्होंने प्रेमपूर्वक उसे गले लगा लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[કૃષ્ણની કાલિયાની શિક્ષાનું તેમનું વર્ણન ફરી શરૂ કરીને, શુકદેવ ગોસ્વામીએ ચાલુ રાખ્યું:] કૃષ્ણ દિવ્ય માળા, સુગંધ અને વસ્ત્રો પહેરીને સરોવરમાંથી બહાર નીકળ્યા, જેમાં ઘણા સુંદર સુશોભિત ઝવેરાત અને સોનાથી મઢેલા હતા. જ્યારે ગોવાળોએ તેને જોયો ત્યારે તેઓ બધા તરત જ ઉભા થઈ ગયા, જેમ કે બેભાન વ્યક્તિની ઇન્દ્રિયો જીવંત થઈ જાય છે. ખૂબ જ આનંદથી ભરપૂર, તેઓ પ્રેમથી તેને ભેટી પડ્યા."
            }
        }
    },
    {
        "id": 101715,
        "sloka": "10.17.15",
        "verse_id": 101715,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Having regained their vital functions, Yaśodā, Rohiṇī, Nanda and all the other cowherd women and men went up to Kṛṣṇa. O descendant of Kuru, even the dried-up trees came back to life."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपने महत्वपूर्ण कार्यों को पुनः प्राप्त करने के बाद, यशोदा, रोहिणी, नंद और अन्य सभी चरवाहे महिलाएं और पुरुष कृष्ण के पास गए। हे कुरु के वंशज, सूखे हुए पेड़ भी फिर से जीवित हो गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમના મહત્વપૂર્ણ કાર્યોને પુનઃપ્રાપ્ત કર્યા પછી, યશોદા, રોહિણી, નંદ અને અન્ય તમામ ગોવાળિયા સ્ત્રીઓ અને પુરુષો કૃષ્ણ પાસે ગયા. હે કુરુના વંશજ, સુકાઈ ગયેલા વૃક્ષો પણ જીવંત થયા."
            }
        }
    },
    {
        "id": 101716,
        "sloka": "10.17.16",
        "verse_id": 101716,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Balarāma embraced His infallible brother and laughed, knowing well the extent of Kṛṣṇa’s potency. Out of great feelings of love, Balarāma lifted Kṛṣṇa up on His lap and repeatedly looked at Him. The cows, bulls and young female calves also achieved the highest pleasure."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान बलराम ने अपने अचूक भाई को गले लगाया और कृष्ण की शक्ति की सीमा को अच्छी तरह से जानते हुए हँसे। प्रेम की महान भावनाओं के कारण, बलराम ने कृष्ण को अपनी गोद में उठा लिया और बार-बार उनकी ओर देखा। गाय, बैल और युवा मादा बछड़ों ने भी सर्वोच्च आनंद प्राप्त किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બલરામે તેમના અચૂક ભાઈને આલિંગન આપ્યું અને કૃષ્ણની શક્તિની મર્યાદાને સારી રીતે જાણીને હસ્યા. પ્રેમની મહાન લાગણીઓમાંથી, બલરામે કૃષ્ણને તેમના ખોળામાં ઉઠાવ્યા અને વારંવાર તેમની તરફ જોયા. ગાય, બળદ અને યુવાન માદા વાછરડાઓએ પણ સૌથી વધુ આનંદ મેળવ્યો."
            }
        }
    },
    {
        "id": 101717,
        "sloka": "10.17.17",
        "verse_id": 101717,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "All the respectable brāhmaṇas, together with their wives, came forward to greet Nanda Mahārāja. They said to him, “Your son was in the grips of Kāliya, but by the grace of Providence He is now free.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सभी सम्मानित ब्राह्मण, अपनी पत्नियों के साथ, नंद महाराज का स्वागत करने के लिए आगे आए। उन्होंने उससे कहा, \"आपका पुत्र कालिया की पकड़ में था, लेकिन भगवान की कृपा से वह अब मुक्त है।\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બધા આદરણીય બ્રાહ્મણો, તેમની પત્નીઓ સાથે, નંદ મહારાજનું અભિવાદન કરવા આગળ આવ્યા. તેઓએ તેને કહ્યું, \"તારો પુત્ર કાલિયાની પકડમાં હતો, પરંતુ પ્રોવિડન્સની કૃપાથી તે હવે મુક્ત છે.\""
            }
        }
    },
    {
        "id": 101718,
        "sloka": "10.17.18",
        "verse_id": 101718,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The brāhmaṇas then advised Nanda Mahārāja, “To assure that your son Kṛṣṇa will always be free from danger, you should give charity to the brāhmaṇas.” With a satisfied mind, O King, Nanda Mahārāja then very gladly gave them gifts of cows and gold."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तब ब्राह्मणों ने नंद महाराज को सलाह दी, \"यह सुनिश्चित करने के लिए कि आपका पुत्र कृष्ण हमेशा खतरे से मुक्त रहेगा, आपको ब्राह्मणों को दान देना चाहिए।\" संतुष्ट मन से, हे राजन, नंद महाराज ने बहुत खुशी से उन्हें गायों और सोने का उपहार दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બ્રાહ્મણોએ પછી નંદ મહારાજને સલાહ આપી, \"તમારા પુત્ર કૃષ્ણ હંમેશા સંકટથી મુક્ત રહેશે તેની ખાતરી કરવા માટે, તમારે બ્રાહ્મણોને દાન આપવું જોઈએ.\" સંતુષ્ટ મન સાથે, હે રાજા, નંદ મહારાજે પછી ખૂબ જ પ્રસન્નતાથી તેમને ગાય અને સોનાની ભેટ આપી."
            }
        }
    },
    {
        "id": 101719,
        "sloka": "10.17.19",
        "verse_id": 101719,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The greatly fortunate mother Yaśodā, having lost her son and then regained Him, placed Him on her lap. That chaste lady cried constant torrents of tears as she repeatedly embraced Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अत्यंत भाग्यशाली माँ यशोदा ने, अपने पुत्र को खो दिया था और फिर उसे पुनः प्राप्त किया, उसे अपनी गोद में रखा। वह पतिव्रता स्त्री बार-बार उन्हें गले लगाते हुए लगातार आँसुओं की धारा बहाती रही।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ખૂબ જ ભાગ્યશાળી માતા યશોદાએ, પોતાનો પુત્ર ગુમાવ્યો અને પછી તેને પાછો મેળવ્યો, તેને તેના ખોળામાં બેસાડ્યો. તે પવિત્ર મહિલા સતત આંસુના પ્રવાહમાં રડતી હતી કારણ કે તેણી વારંવાર તેને ભેટી રહી હતી."
            }
        }
    },
    {
        "id": 101720,
        "sloka": "10.17.20",
        "verse_id": 101720,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O best of kings [Parīkṣit], because the residents of Vṛndāvana were feeling very weak from hunger, thirst and fatigue, they and the cows spent the night where they were, lying down near the bank of the Kālindī."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजाओं में श्रेष्ठ [परीक्षित], चूँकि वृन्दावन के निवासी भूख, प्यास और थकान से बहुत कमज़ोर महसूस कर रहे थे, इसलिए उन्होंने और गायों ने जहाँ वे थे, कालिन्दी के तट के पास लेटकर रात बिताई।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે શ્રેષ્ઠ રાજાઓ [પરિક્ષિત], કારણ કે વૃંદાવનના રહેવાસીઓ ભૂખ, તરસ અને થાકથી ખૂબ જ નબળાઈ અનુભવતા હતા, તેઓ અને ગાયોએ કાલિંદીના કિનારે સૂઈને તેઓ જ્યાં હતા ત્યાં રાત વિતાવી."
            }
        }
    },
    {
        "id": 101721,
        "sloka": "10.17.21",
        "verse_id": 101721,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "During the night, while all the people of Vṛndāvana were asleep, a great fire blazed up within the dry summer forest. The fire surrounded the inhabitants of Vraja on all sides and began to scorch them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "रात के समय, जब वृन्दावन के सभी लोग सो रहे थे, ग्रीष्म ऋतु के शुष्क वन में भीषण आग भड़क उठी। आग ने व्रजवासियों को चारों ओर से घेर लिया और झुलसाना शुरू कर दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "રાત્રિના સમયે, જ્યારે વૃંદાવનના તમામ લોકો ઊંઘી રહ્યા હતા, ત્યારે ઉનાળાના સૂકા જંગલમાં એક મહાન આગ ભભૂકી ઉઠી હતી. અગ્નિએ વ્રજના રહેવાસીઓને ચારે બાજુથી ઘેરી લીધા અને તેમને ભસ્મીભૂત કરવા લાગ્યા."
            }
        }
    },
    {
        "id": 101722,
        "sloka": "10.17.22",
        "verse_id": 101722,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Then the residents of Vṛndāvana woke up, extremely disturbed by the great fire threatening to burn them. Thus they took shelter of Kṛṣṇa, the Supreme Lord, who by His spiritual potency appeared like an ordinary human being."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तब वृन्दावन के निवासी जाग उठे, वे उस भीषण आग से अत्यंत व्याकुल हो गये जो उन्हें जलाने की धमकी दे रही थी। इस प्रकार उन्होंने परम भगवान कृष्ण की शरण ली, जो अपनी आध्यात्मिक शक्ति से एक सामान्य मनुष्य की तरह दिखाई देते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પછી વૃંદાવનના રહેવાસીઓ જાગી ગયા, તેઓને બાળી નાખવાની ધમકી આપતી મહાન અગ્નિથી અત્યંત વ્યગ્ર. આ રીતે તેઓએ કૃષ્ણ, પરમ ભગવાનનો આશ્રય લીધો, જેઓ તેમની આધ્યાત્મિક શક્તિ દ્વારા એક સામાન્ય મનુષ્યની જેમ દેખાયા."
            }
        }
    },
    {
        "id": 101723,
        "sloka": "10.17.23",
        "verse_id": 101723,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Vṛndāvana’s residents said:] Kṛṣṇa, Kṛṣṇa, O Lord of all opulence! O Rāma, possessor of unlimited power! This most terrible fire is about to devour us, Your devotees!"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[वृंदावन के निवासियों ने कहा:] कृष्ण, कृष्ण, हे समस्त ऐश्वर्य के स्वामी! हे राम, असीमित शक्ति के स्वामी! आपके भक्तों, यह अत्यंत भयानक अग्नि हम लोगों को भस्म करने वाली है!"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[વૃંદાવનના રહેવાસીઓએ કહ્યું:] કૃષ્ણ, કૃષ્ણ, હે સર્વ ઐશ્વર્યના ભગવાન! હે રામ, અમર્યાદિત શક્તિના માલિક! આ સૌથી ભયંકર અગ્નિ અમને ભસ્મ કરી નાખવાની છે, તમારા ભક્તો!"
            }
        }
    },
    {
        "id": 101724,
        "sloka": "10.17.24",
        "verse_id": 101724,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Lord, we are Your true friends and devotees. Please protect us from this insurmountable fire of death. We can never give up Your lotus feet, which drive away all fear."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे प्रभु, हम आपके सच्चे मित्र और भक्त हैं। कृपया मृत्यु की इस दुर्लंघनीय आग से हमारी रक्षा करें। हम आपके चरणकमलों को कभी नहीं छोड़ सकते, जो समस्त भय को दूर कर देते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે પ્રભુ, અમે તમારા સાચા મિત્ર અને ભક્ત છીએ. કૃપા કરીને અમને મૃત્યુની આ અદમ્ય આગથી બચાવો. અમે તમારા કમળના ચરણ ક્યારેય છોડી શકતા નથી, જે તમામ ભયને દૂર કરે છે."
            }
        }
    },
