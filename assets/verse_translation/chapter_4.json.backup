[
    {
        "id": 100401,
        "sloka": "10.4.1",
        "verse_id": 100401,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī continued: My dear King Parīkṣit, the doors inside and outside the house closed as before. Thereafter, the inhabitants of the house, especially the watchmen, heard the crying of the newborn child and thus awakened from their beds."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने आगे कहा: मेरे प्रिय राजा परीक्षित, घर के अंदर और बाहर के दरवाजे पहले की तरह बंद हो गए। इसके बाद, घर के निवासियों, विशेषकर चौकीदारों ने नवजात बच्चे के रोने की आवाज़ सुनी और इस तरह अपने बिस्तरों से जाग गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ આગળ કહ્યું: મારા વ્હાલા રાજા પરિક્ષિત, ઘરની અંદર અને બહારના દરવાજા પહેલાની જેમ બંધ હતા. ત્યારબાદ, ઘરના રહેવાસીઓ, ખાસ કરીને ચોકીદાર, નવજાત બાળકના રડવાનો અવાજ સાંભળીને તેમના પથારીમાંથી જાગી ગયા."
            }
        }
    },
    {
        "id": 100402,
        "sloka": "10.4.2",
        "verse_id": 100402,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Thereafter, all the watchmen very quickly approached King Kaṁsa, the ruler of the Bhoja dynasty, and submitted the news of the birth of Devakī’s child. Kaṁsa, who had awaited this news very anxiously, immediately took action."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इसके बाद, सभी पहरेदार तुरंत भोज वंश के शासक राजा कंस के पास पहुंचे और देवकी के बच्चे के जन्म की खबर दी। कंस, जो बहुत उत्सुकता से इस समाचार का इंतजार कर रहा था, ने तुरंत कार्रवाई की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ત્યારબાદ, બધા ચોકીદારો ખૂબ જ ઝડપથી ભોજ વંશના શાસક રાજા કંસ પાસે પહોંચ્યા અને દેવકીના બાળકના જન્મના સમાચાર આપ્યા. કંસ, જે આ સમાચારની ખૂબ જ આતુરતાથી રાહ જોઈ રહ્યો હતો, તેણે તરત જ પગલાં લીધા."
            }
        }
    },
    {
        "id": 100403,
        "sloka": "10.4.3",
        "verse_id": 100403,
        "verseNumber": 3,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kaṁsa immediately got up from bed, thinking, “Here is Kāla, the supreme time factor, which has taken birth to kill me!” Thus overwhelmed, Kaṁsa, his hair scattered on his head, at once approached the place where the child had been born."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कंस तुरंत बिस्तर से उठ गया, उसने सोचा, \"यहाँ काल है, सर्वोच्च समय कारक, जिसने मुझे मारने के लिए जन्म लिया है!\" इस प्रकार अभिभूत कंस, अपने सिर के बाल बिखेरते हुए, तुरंत उस स्थान के पास पहुंचा, जहां बच्चे का जन्म हुआ था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કંસ તરત જ પથારીમાંથી ઊભો થયો, વિચાર્યું, \"અહીં છે કાલા, સર્વોચ્ચ સમય પરિબળ, જેણે મને મારવા માટે જન્મ લીધો છે!\" આ રીતે અભિભૂત થઈને, કંસ, તેના માથા પર વિખરાયેલા વાળ, તરત જ તે સ્થાનની નજીક પહોંચ્યા જ્યાં બાળકનો જન્મ થયો હતો."
            }
        }
    },
    {
        "id": 100404,
        "sloka": "10.4.4",
        "verse_id": 100404,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Devakī helplessly, piteously appealed to Kaṁsa: My dear brother, all good fortune unto you. Don’t kill this girl. She will be your daughter-in-law. Indeed, it is unworthy of you to kill a woman."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "देवकी ने असहाय होकर, दयापूर्वक कंस से प्रार्थना की: मेरे प्यारे भाई, तुम्हें शुभकामनाएँ। इस लड़की को मत मारो. वह आपकी बहू बनेगी. सचमुच, किसी स्त्री को मार डालना तुम्हारे लिये अयोग्य है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "દેવકીએ નિઃસહાય, દયાથી કંસને વિનંતી કરી: મારા વહાલા ભાઈ, તમારા માટે બધા સારા નસીબ. આ છોકરીને મારશો નહીં. તે તારી વહુ હશે. ખરેખર, સ્ત્રીની હત્યા કરવી તમારા માટે અયોગ્ય છે."
            }
        }
    },
    {
        "id": 100405,
        "sloka": "10.4.5",
        "verse_id": 100405,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My dear brother, by the influence of destiny you have already killed many babies, each of them as bright and beautiful as fire. But kindly spare this daughter. Give her to me as your gift."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रिय भाई, भाग्य के प्रभाव से तुम पहले ही कई शिशुओं को मार चुके हो, जिनमें से प्रत्येक अग्नि के समान उज्ज्वल और सुंदर थे। लेकिन कृपया इस बेटी को छोड़ दीजिए. उसे अपने उपहार के रूप में मुझे दे दो।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા વહાલા ભાઈ, નિયતિના પ્રભાવથી તમે ઘણા બાળકોને મારી નાખ્યા છે, તેમાંથી દરેક અગ્નિ જેવા તેજસ્વી અને સુંદર છે. પણ મહેરબાની કરીને આ દીકરીને બચાવો. તેણીને તમારી ભેટ તરીકે મને આપો."
            }
        }
    },
    {
        "id": 100406,
        "sloka": "10.4.6",
        "verse_id": 100406,
        "verseNumber": 6,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My lord, my brother, I am very poor, being bereft of all my children, but still I am your younger sister, and therefore it would be worthy of you to give me this last child as a gift."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रभु, मेरे भाई, मैं बहुत गरीब हूं, अपने सभी बच्चों से वंचित हूं, लेकिन फिर भी मैं आपकी छोटी बहन हूं, और इसलिए यह आपके योग्य होगा कि आप मुझे यह आखिरी बच्चा उपहार के रूप में दें।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા સ્વામી, મારા ભાઈ, હું ખૂબ જ ગરીબ છું, મારા બધા બાળકોથી વંચિત છું, પરંતુ તેમ છતાં હું તમારી નાની બહેન છું, અને તેથી તમે મને આ છેલ્લું બાળક ભેટમાં આપવા માટે લાયક છો."
            }
        }
    },
    {
        "id": 100407,
        "sloka": "10.4.7",
        "verse_id": 100407,
        "verseNumber": 7,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī continued: Piteously embracing her daughter and crying, Devakī begged Kaṁsa for the child, but he was so cruel that he chastised her and forcibly snatched the child from her hands."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने आगे कहा: अपनी बेटी को गले लगाते हुए और रोते हुए, देवकी ने कंस से बच्चे की याचना की, लेकिन वह इतना क्रूर था कि उसने उसे दंडित किया और उसके हाथों से बच्चे को जबरन छीन लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ ચાલુ રાખ્યું: પોતાની પુત્રીને ગળે લગાવીને રડતા, દેવકીએ કંસને બાળક માટે વિનંતી કરી, પરંતુ તે એટલો ક્રૂર હતો કે તેણે તેને શિક્ષા કરી અને બળજબરીથી તેના હાથમાંથી બાળક છીનવી લીધું."
            }
        }
    },
    {
        "id": 100408,
        "sloka": "10.4.8",
        "verse_id": 100408,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Having uprooted all relationships with his sister because of intense selfishness, Kaṁsa, who was sitting on his knees, grasped the newborn child by the legs and tried to dash her against the surface of a stone."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "घोर स्वार्थ के कारण अपनी बहन के साथ सारे रिश्ते तोड़ देने के बाद, कंस, जो अपने घुटनों के बल बैठा था, ने नवजात शिशु को पैरों से पकड़ लिया और उसे एक पत्थर की सतह पर पटकने की कोशिश की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તીવ્ર સ્વાર્થને કારણે તેની બહેન સાથેના તમામ સંબંધોને જડમૂળથી ઉખેડી નાખ્યા પછી, કંસ, જે તેના ઘૂંટણ પર બેઠો હતો, તેણે નવજાત બાળકને પગથી પકડ્યો અને તેને એક પથ્થરની સપાટી પર પછાડવાનો પ્રયાસ કર્યો."
            }
        }
    },
    {
        "id": 100409,
        "sloka": "10.4.9",
        "verse_id": 100409,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The child, Yoga-māyā-devī, the younger sister of Lord Viṣṇu, slipped upward from Kaṁsa’s hands and appeared in the sky as Devī, the goddess Durgā, with eight arms, completely equipped with weapons."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान विष्णु की छोटी बहन, बच्ची, योग-माया-देवी, कंस के हाथों से फिसल गई और आकाश में देवी, देवी दुर्गा के रूप में प्रकट हुई, आठ भुजाओं वाली, पूरी तरह से हथियारों से सुसज्जित।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બાળક, યોગ-માયા-દેવી, ભગવાન વિષ્ણુની નાની બહેન, કંસના હાથમાંથી ઉપરની તરફ સરકી ગઈ અને આકાશમાં દેવી, દેવી દુર્ગાના રૂપમાં પ્રગટ થઈ, જે આઠ હાથો સાથે, સંપૂર્ણ શસ્ત્રોથી સજ્જ છે."
            }
        }
    },
    {
        "id": 100410,
        "sloka": "10.4.10-11",
        "verse_id": 100410,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The goddess Durgā was decorated with flower garlands, smeared with sandalwood pulp and dressed with excellent garments and ornaments made of valuable jewels. Holding in her hands a bow, a trident, arrows, a shield, a sword, a conchshell, a disc and a club, and being praised by celestial beings like Apsarās, Kinnaras, Uragas, Siddhas, Cāraṇas and Gandharvas, who worshiped her with all kinds of presentations, she spoke as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "देवी दुर्गा को फूलों की मालाओं से सजाया गया था, चंदन का लेप लगाया गया था और बहुमूल्य रत्नों से बने उत्कृष्ट वस्त्र और आभूषण पहनाए गए थे। अपने हाथों में धनुष, त्रिशूल, बाण, ढाल, तलवार, शंख, चक्र और गदा धारण किए हुए और अप्सराओं, किन्नरों, उरगों, सिद्धों, चारणों और गंधर्वों जैसे दिव्य प्राणियों द्वारा स्तुति किए जाने पर, जो सभी प्रकार की प्रस्तुतियों से उसकी पूजा करते थे, उसने इस प्रकार बात की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "દેવી દુર્ગાને ફૂલોની માળાથી શણગારવામાં આવી હતી, ચંદનના પલ્પથી મઢવામાં આવી હતી અને મૂલ્યવાન ઝવેરાતથી બનેલા ઉત્તમ વસ્ત્રો અને આભૂષણોથી સજ્જ હતા. તેના હાથમાં ધનુષ્ય, ત્રિશૂળ, બાણ, ઢાલ, તલવાર, શંખ, ચકલી અને કલબ ધારણ કરીને અને અપ્સરાઓ, કિન્નરો, ઉરાગ, સિદ્ધ, ચરણો અને ગંધર્વો જેવા આકાશી જીવો દ્વારા વખાણ કરવામાં આવી હતી, જેમણે તેની પૂજા કરી હતી, તે તમામ પ્રકારની હાજર રહીને તે બોલ્યા."
            }
        }
    },
    {
        "id": 100412,
        "sloka": "10.4.12",
        "verse_id": 100412,
        "verseNumber": 12,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Kaṁsa, you fool, what will be the use of killing me? The Supreme Personality of Godhead, who has been your enemy from the very beginning and who will certainly kill you, has already taken His birth somewhere else. Therefore, do not unnecessarily kill other children."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे कंस, हे मूर्ख, मुझे मारने से क्या लाभ होगा? भगवान, जो शुरू से ही आपके शत्रु रहे हैं और जो निश्चित रूप से आपको मार डालेंगे, उन्होंने पहले ही कहीं और जन्म ले लिया है। इसलिए बेवजह दूसरे बच्चों को न मारें."
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે કંસ, મૂર્ખ, મને મારવાથી શું ફાયદો થશે? પરમ પુરૂષ ભગવાન, જે શરૂઆતથી જ તમારા શત્રુ છે અને જે ચોક્કસપણે તમને મારી નાખશે, તેમનો જન્મ બીજે ક્યાંક થઈ ગયો છે. તેથી, અન્ય બાળકોને બિનજરૂરી રીતે મારશો નહીં."
            }
        }
    },
    {
        "id": 100413,
        "sloka": "10.4.13",
        "verse_id": 100413,
        "verseNumber": 13,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After speaking to Kaṁsa in this way, the goddess Durgā, Yoga-māyā, appeared in different places, such as Vārāṇasī, and became celebrated by different names, such as Annapūrṇā, Durgā, Kālī and Bhadrā."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार कंस से बात करने के बाद, देवी दुर्गा, योग-माया, वाराणसी जैसे विभिन्न स्थानों में प्रकट हुईं, और अन्नपूर्णा, दुर्गा, काली और भद्रा जैसे विभिन्न नामों से मनाई जाने लगीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે કંસ સાથે વાત કર્યા પછી, દેવી દુર્ગા, યોગ-માયા, વારાણસી જેવા વિવિધ સ્થળોએ પ્રગટ થઈ, અને અન્નપૂર્ણા, દુર્ગા, કાલી અને ભદ્રા જેવા વિવિધ નામોથી ઉજવવામાં આવી."
            }
        }
    },
    {
        "id": 100414,
        "sloka": "10.4.14",
        "verse_id": 100414,
        "verseNumber": 14,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After hearing the words of the goddess Durgā, Kaṁsa was struck with wonder. Thus he approached his sister Devakī and brother-in-law Vasudeva, released them immediately from their shackles, and very humbly spoke as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "देवी दुर्गा के वचन सुनकर कंस आश्चर्यचकित रह गया। इस प्रकार वह अपनी बहन देवकी और बहनोई वसुदेव के पास गये, उन्हें तुरन्त बंधनों से मुक्त कर दिया और अत्यंत नम्रतापूर्वक इस प्रकार बोले।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "દેવી દુર્ગાના શબ્દો સાંભળીને કંસ આશ્ચર્યચકિત થઈ ગયા. આ રીતે તે તેની બહેન દેવકી અને વહુ વાસુદેવ પાસે ગયો, તેમને તરત જ તેમની બેડીઓમાંથી મુક્ત કર્યા, અને ખૂબ જ નમ્રતાપૂર્વક નીચે પ્રમાણે વાત કરી."
            }
        }
    },
    {
        "id": 100415,
        "sloka": "10.4.15",
        "verse_id": 100415,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Alas, my sister! Alas, my brother-in-law! I am indeed so sinful that exactly like a man-eater [Rākṣasa] who eats his own child, I have killed so many sons born of you."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हाय, मेरी बहन! हाय, मेरे जीजाजी! मैं वास्तव में इतना पापी हूं कि एक नरभक्षी [राक्षस] की तरह जो अपने ही बच्चे को खा जाता है, मैंने तुम्हारे द्वारा जन्मे कई पुत्रों को मार डाला है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કાશ, મારી બહેન! કાશ, મારી વહુ! હું ખરેખર એટલો પાપી છું કે એક માનવભક્ષક [રાક્ષસ] જે પોતાના બાળકને ખાય છે, મેં તમારાથી જન્મેલા ઘણા પુત્રોને મારી નાખ્યા છે."
            }
        }
    },
    {
        "id": 100416,
        "sloka": "10.4.16",
        "verse_id": 100416,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Being merciless and cruel, I have forsaken all my relatives and friends. Therefore, like a person who has killed a brāhmaṇa, I do not know to which planet I shall go, either after death or while breathing."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "निर्दयी और क्रूर होने के कारण मैंने अपने सभी रिश्तेदारों और दोस्तों को त्याग दिया है। इसलिए, उस व्यक्ति की तरह जिसने एक ब्राह्मण को मार डाला है, मैं नहीं जानता कि मैं किस ग्रह पर जाऊंगा, या तो मरने के बाद या सांस लेते समय।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "નિર્દય અને ક્રૂર હોવાથી, મેં મારા બધા સંબંધીઓ અને મિત્રોને છોડી દીધા છે. તેથી, બ્રાહ્મણની હત્યા કરનાર વ્યક્તિની જેમ, હું જાણતો નથી કે હું કયા ગ્રહ પર જઈશ, મૃત્યુ પછી અથવા શ્વાસ લેતી વખતે."
            }
        }
    },
    {
        "id": 100417,
        "sloka": "10.4.17",
        "verse_id": 100417,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Alas, not only human beings but sometimes even providence lies. And I am so sinful that I believed the omen of providence and killed so many of my sister’s children."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अफ़सोस, न केवल इंसान बल्कि कभी-कभी ईश्वर भी झूठ बोलता है। और मैं इतना पापी हूं कि मैंने भविष्यवाणी पर विश्वास किया और अपनी बहन के कई बच्चों को मार डाला।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "અરે, માત્ર મનુષ્ય જ નહીં પણ ક્યારેક પ્રોવિડન્સ પણ જૂઠું બોલે છે. અને હું એટલો પાપી છું કે મેં પ્રોવિડન્સના શુકન પર વિશ્વાસ કર્યો અને મારી બહેનના ઘણા બાળકોને મારી નાખ્યા."
            }
        }
    },
    {
        "id": 100418,
        "sloka": "10.4.18",
        "verse_id": 100418,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O great souls, your children have suffered their own misfortune. Therefore, please do not lament for them. All living entities are under the control of the Supreme, and they cannot always live together."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे महान आत्माओं, आपके बच्चों ने अपना दुर्भाग्य स्वयं झेला है। अत: कृपया उनके लिये शोक न करें। सभी जीव भगवान के नियंत्रण में हैं, और वे हमेशा एक साथ नहीं रह सकते।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે મહાન આત્માઓ, તમારા બાળકોએ પોતાનું દુર્ભાગ્ય ભોગવ્યું છે. તેથી, કૃપા કરીને તેમના માટે વિલાપ કરશો નહીં. તમામ જીવો પરમના નિયંત્રણ હેઠળ છે, અને તેઓ હંમેશા સાથે રહી શકતા નથી."
            }
        }
    },
    {
        "id": 100419,
        "sloka": "10.4.19",
        "verse_id": 100419,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In this world, we can see that pots, dolls and other products of the earth appear, break and then disappear, mixing with the earth. Similarly, the bodies of all conditioned living entities are annihilated, but the living entities, like the earth itself, are unchanging and never annihilated [na hanyate hanyamāne śarīre]."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस दुनिया में, हम देख सकते हैं कि बर्तन, गुड़िया और मिट्टी के अन्य उत्पाद दिखाई देते हैं, टूट जाते हैं और फिर मिट्टी में मिलकर गायब हो जाते हैं। इसी तरह, सभी बद्धजीवों के शरीर नष्ट हो जाते हैं, लेकिन जीव, पृथ्वी की तरह, अपरिवर्तनीय हैं और कभी नष्ट नहीं होते हैं [न हन्यते हन्यमाने शरीरे]।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ દુનિયામાં, આપણે જોઈ શકીએ છીએ કે વાસણો, ઢીંગલી અને પૃથ્વીના અન્ય ઉત્પાદનો દેખાય છે, તૂટી જાય છે અને પછી અદૃશ્ય થઈ જાય છે, પૃથ્વી સાથે ભળી જાય છે. તેવી જ રીતે, તમામ કન્ડિશન્ડ જીવોના શરીરનો નાશ થાય છે, પરંતુ જીવો, પૃથ્વીની જેમ, અપરિવર્તનશીલ છે અને ક્યારેય નાશ પામતા નથી [ના હન્યતે હન્યમાને શરીરે]."
            }
        }
    },
    {
        "id": 100420,
        "sloka": "10.4.20",
        "verse_id": 100420,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "One who does not understand the constitutional position of the body and the soul [ātmā] becomes too attached to the bodily concept of life. Consequently, because of attachment to the body and its by-products, he feels affected by union with and separation from his family, society and nation. As long as this continues, one continues his material life. [Otherwise, one is liberated.]"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जो व्यक्ति शरीर और आत्मा [आत्मा] की संवैधानिक स्थिति को नहीं समझता है, वह जीवन की शारीरिक अवधारणा से बहुत अधिक जुड़ जाता है। फलतः शरीर तथा उसके उपोत्पादों के प्रति आसक्ति के कारण वह अपने परिवार, समाज तथा राष्ट्र के साथ मिलन तथा वियोग का अनुभव करता है। जब तक यह जारी रहता है, व्यक्ति अपना भौतिक जीवन जारी रखता है। [अन्यथा, व्यक्ति मुक्त हो जाता है।]"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જે વ્યક્તિ શરીર અને આત્માની બંધારણીય સ્થિતિને સમજી શકતો નથી [આત્મા] તે જીવનની શારીરિક ખ્યાલ સાથે ખૂબ જ જોડાયેલો બની જાય છે. પરિણામે, શરીર અને તેના ઉપ-ઉત્પાદનો સાથેના આસક્તિને કારણે, તે તેના પરિવાર, સમાજ અને રાષ્ટ્ર સાથેના જોડાણ અને અલગતાની અસર અનુભવે છે. જ્યાં સુધી આ ચાલુ રહે છે ત્યાં સુધી વ્યક્તિ તેનું ભૌતિક જીવન ચાલુ રાખે છે. [અન્યથા, વ્યક્તિ મુક્ત થાય છે.]"
            }
        }
    },
    {
        "id": 100421,
        "sloka": "10.4.21",
        "verse_id": 100421,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My dear sister Devakī, all good fortune unto you. Everyone suffers and enjoys the results of his own work under the control of providence. Therefore, although your sons have unfortunately been killed by me, please do not lament for them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरी प्रिय बहन देवकी, तुम्हें शुभकामनाएँ। हर कोई प्रोविडेंस के नियंत्रण में अपने स्वयं के कार्यों के परिणामों को भुगतता है और उनका आनंद लेता है। अत: यद्यपि आपके पुत्र दुर्भाग्य से मेरे द्वारा मारे गये हैं, कृपया उनके लिये शोक न करें।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારી વહાલી બહેન દેવકી, તને સૌનું સૌભાગ્ય. દરેક વ્યક્તિ પ્રોવિડન્સના નિયંત્રણ હેઠળ પોતાના કાર્યના પરિણામો ભોગવે છે અને ભોગવે છે. તેથી, જો કે તમારા પુત્રો દુર્ભાગ્યે મારા દ્વારા માર્યા ગયા છે, કૃપા કરીને તેમના માટે વિલાપ કરશો નહીં."
            }
        }
    },
    {
        "id": 100422,
        "sloka": "10.4.22",
        "verse_id": 100422,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In the bodily conception of life, one remains in darkness, without self-realization, thinking, “I am being killed” or “I have killed my enemies.” As long as a foolish person thus considers the self to be the killer or the killed, he continues to be responsible for material obligations, and consequently he suffers the reactions of happiness and distress."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जीवन की शारीरिक अवधारणा में, व्यक्ति आत्म-बोध के बिना अंधेरे में रहता है, सोचता है, \"मुझे मारा जा रहा है\" या \"मैंने अपने दुश्मनों को मार डाला है।\" जब तक कोई मूर्ख व्यक्ति स्वयं को हत्यारा या मारा हुआ मानता है, तब तक वह भौतिक दायित्वों के लिए जिम्मेदार बना रहता है, और परिणामस्वरूप वह सुख और दुःख की प्रतिक्रियाएँ भोगता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જીવનની શારીરિક વિભાવનામાં, વ્યક્તિ અંધકારમાં રહે છે, આત્મ-અનુભૂતિ વિના, વિચારે છે કે, \"મારી હત્યા થઈ રહી છે\" અથવા \"મેં મારા દુશ્મનોને મારી નાખ્યા છે.\" જ્યાં સુધી મૂર્ખ વ્યક્તિ આ રીતે પોતાની જાતને ખૂની અથવા માર્યા ગયેલા માને છે, ત્યાં સુધી તે ભૌતિક જવાબદારીઓ માટે જવાબદાર રહે છે, અને પરિણામે તે સુખ અને દુઃખની પ્રતિક્રિયાઓ ભોગવે છે."
            }
        }
    },
    {
        "id": 100423,
        "sloka": "10.4.23",
        "verse_id": 100423,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Kaṁsa begged, “My dear sister and brother-in-law, please be merciful to such a poor-hearted person as me, since both of you are saintly persons. Please excuse my atrocities.” Having said this, Kaṁsa fell at the feet of Vasudeva and Devakī, his eyes full of tears of regret."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कंस ने विनती की, \"मेरी प्रिय बहन और जीजाजी, कृपया मेरे जैसे गरीब दिल वाले व्यक्ति पर दया करें, क्योंकि आप दोनों साधु व्यक्ति हैं। कृपया मेरे अत्याचारों को क्षमा करें।\" इतना कहकर कंस वसुदेव और देवकी के चरणों में गिर पड़ा, उसकी आँखों में पश्चाताप के आँसू भर आये।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કંસે વિનંતી કરી, \"મારી વહાલી બહેન અને વહુ, મારા જેવા ગરીબ હૃદયના વ્યક્તિ પર કૃપા કરો, કારણ કે તમે બંને પુણ્યશાળી છો. કૃપા કરીને મારા અત્યાચારને માફ કરો.\" આટલું કહીને, કંસ વાસુદેવ અને દેવકીના ચરણોમાં પડ્યો, તેની આંખો પસ્તાવાના આંસુઓથી ભરેલી હતી."
            }
        }
    },
    {
        "id": 100424,
        "sloka": "10.4.24",
        "verse_id": 100424,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Fully believing in the words of the goddess Durgā, Kaṁsa exhibited his familial affection for Devakī and Vasudeva by immediately releasing them from their iron shackles."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "देवी दुर्गा के शब्दों पर पूर्ण विश्वास करते हुए, कंस ने देवकी और वासुदेव को तुरंत उनकी लोहे की बेड़ियों से मुक्त करके उनके प्रति अपने पारिवारिक स्नेह का प्रदर्शन किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "દેવી દુર્ગાના શબ્દોમાં સંપૂર્ણ વિશ્વાસ રાખીને, કંસ દેવકી અને વાસુદેવ પ્રત્યેના તેમના પારિવારિક સ્નેહને તરત જ તેમના લોખંડના બંધનમાંથી મુક્ત કરીને પ્રદર્શિત કરે છે."
            }
        }
    },
    {
        "id": 100425,
        "sloka": "10.4.25",
        "verse_id": 100425,
        "verseNumber": 25,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When Devakī saw her brother actually repentant while explaining ordained events, she was relieved of all anger. Similarly, Vasudeva was also free from anger. Smiling, he spoke to Kaṁsa as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब देवकी ने अपने भाई को नियत घटनाओं की व्याख्या करते हुए वास्तव में पश्चाताप करते देखा, तो उसका सारा क्रोध शांत हो गया। इसी प्रकार वासुदेव भी क्रोध से मुक्त थे। मुस्कुराते हुए उन्होंने कंस से इस प्रकार बात की।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે દેવકીએ તેના ભાઈને નિયુક્ત પ્રસંગો સમજાવતી વખતે ખરેખર પસ્તાવો કરતા જોયો, ત્યારે તે તમામ ગુસ્સાથી મુક્ત થઈ ગઈ. એ જ રીતે વાસુદેવ પણ ક્રોધથી મુક્ત હતા. હસતાં હસતાં તેણે કંસ સાથે આ પ્રમાણે વાત કરી."
            }
        }
    },
    {
        "id": 100426,
        "sloka": "10.4.26",
        "verse_id": 100426,
        "verseNumber": 26,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O great personality Kaṁsa, only by the influence of ignorance does one accept the material body and bodily ego. What you have said about this philosophy is correct. Persons in the bodily concept of life, lacking self-realization, differentiate in terms of “This is mine” and “This belongs to another.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे महान व्यक्तित्व कंस, केवल अज्ञानता के प्रभाव से कोई व्यक्ति भौतिक शरीर और शारीरिक अहंकार को स्वीकार करता है। आपने इस दर्शन के बारे में जो कहा है वह सही है। जीवन की शारीरिक अवधारणा वाले व्यक्ति, आत्म-बोध की कमी के कारण, \"यह मेरा है\" और \"यह दूसरे का है\" के संदर्भ में अंतर करते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે મહાન વ્યક્તિત્વ કંસ, માત્ર અજ્ઞાનના પ્રભાવથી વ્યક્તિ ભૌતિક શરીર અને શારીરિક અહંકારને સ્વીકારે છે. તમે આ ફિલસૂફી વિશે જે કહ્યું છે તે સાચું છે. જીવનના શારીરિક ખ્યાલમાં વ્યક્તિઓ, આત્મ-અનુભૂતિનો અભાવ, \"આ મારું છે\" અને \"આ બીજાનું છે\" ની દ્રષ્ટિએ અલગ પડે છે."
            }
        }
    },
    {
        "id": 100427,
        "sloka": "10.4.27",
        "verse_id": 100427,
        "verseNumber": 27,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Persons with the vision of differentiation are imbued with the material qualities lamentation, jubilation, fear, envy, greed, illusion and madness. They are influenced by the immediate cause, which they are busy counteracting, because they have no knowledge of the remote, supreme cause, the Personality of Godhead."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भेद की दृष्टि वाले व्यक्ति भौतिक गुणों विलाप, उल्लास, भय, ईर्ष्या, लोभ, भ्रम और पागलपन से युक्त होते हैं। वे तात्कालिक कारण से प्रभावित होते हैं, जिसका प्रतिकार करने में वे व्यस्त रहते हैं, क्योंकि उन्हें दूरस्थ, सर्वोच्च कारण, भगवान के व्यक्तित्व का कोई ज्ञान नहीं है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભિન્નતાની દ્રષ્ટિ ધરાવતી વ્યક્તિઓ વિલાપ, આનંદ, ભય, ઈર્ષ્યા, લોભ, ભ્રમ અને ગાંડપણ જેવા ભૌતિક ગુણોથી રંગાયેલી હોય છે. તેઓ તાત્કાલિક કારણથી પ્રભાવિત થાય છે, જેનો પ્રતિકાર કરવામાં તેઓ વ્યસ્ત છે, કારણ કે તેમને દૂરસ્થ, સર્વોચ્ચ કારણ, ભગવાનના વ્યક્તિત્વનું કોઈ જ્ઞાન નથી."
            }
        }
    },
    {
        "id": 100428,
        "sloka": "10.4.28",
        "verse_id": 100428,
        "verseNumber": 28,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī continued: Thus having been addressed in purity by Devakī and Vasudeva, who were very much appeased, Kaṁsa felt pleased, and with their permission he entered his home."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने आगे कहा: इस प्रकार देवकी और वासुदेव द्वारा पवित्रतापूर्वक संबोधित किए जाने पर, जो बहुत प्रसन्न थे, कंस प्रसन्न हुआ, और उनकी अनुमति से वह अपने घर में प्रवेश कर गया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ ચાલુ રાખ્યું: આ રીતે દેવકી અને વાસુદેવ દ્વારા શુદ્ધતામાં સંબોધન કર્યા પછી, જેઓ ખૂબ જ પ્રસન્ન હતા, કંસ પ્રસન્ન થયા, અને તેમની પરવાનગીથી તેઓ તેમના ઘરમાં પ્રવેશ્યા."
            }
        }
    },
    {
        "id": 100429,
        "sloka": "10.4.29",
        "verse_id": 100429,
        "verseNumber": 29,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After that night passed, Kaṁsa summoned his ministers and informed them of all that had been spoken by Yoga-māyā [who had revealed that He who was to slay Kaṁsa had already been born somewhere else]."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उस रात बीतने के बाद, कंस ने अपने मंत्रियों को बुलाया और उन्हें योग-माया द्वारा कही गई सारी बातें बताईं [जिन्होंने खुलासा किया था कि जो कंस को मारना चाहता था वह पहले ही कहीं और पैदा हो चुका था]।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે રાત વીતી ગયા પછી, કંસે તેના મંત્રીઓને બોલાવ્યા અને તેમને યોગ-માયા દ્વારા બોલવામાં આવેલા બધાની જાણ કરી [જેણે જાહેર કર્યું કે જે કંસને મારવાના હતા તે પહેલેથી જ બીજે ક્યાંક જન્મ્યા હતા]."
            }
        }
    },
    {
        "id": 100430,
        "sloka": "10.4.30",
        "verse_id": 100430,
        "verseNumber": 30,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After hearing their master’s statement, the envious asuras, who were enemies of the demigods and were not very expert in their dealings, advised Kaṁsa as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपने स्वामी की बात सुनने के बाद, ईर्ष्यालु असुरों ने, जो देवताओं के शत्रु थे और अपने व्यवहार में बहुत कुशल नहीं थे, कंस को इस प्रकार सलाह दी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમના ગુરુનું નિવેદન સાંભળ્યા પછી, ઈર્ષાળુ અસુરો, જેઓ દેવતાઓના શત્રુ હતા અને તેમના વ્યવહારમાં બહુ નિષ્ણાત ન હતા, તેમણે કંસને નીચે મુજબ સલાહ આપી."
            }
        }
    },
    {
        "id": 100431,
        "sloka": "10.4.31",
        "verse_id": 100431,
        "verseNumber": 31,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "If this is so, O King of the Bhoja dynasty, beginning today we shall kill all the children born in all the villages, towns and pasturing grounds within the past ten days or slightly more."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यदि ऐसा है, तो हे भोज वंश के राजा, आज से हम पिछले दस दिनों या उससे कुछ अधिक दिनों के भीतर सभी गांवों, कस्बों और चरागाहों में पैदा हुए सभी बच्चों को मार डालेंगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જો એમ હોય તો, હે ભોજ વંશના રાજા, આજથી આપણે બધા ગામડાઓ, નગરો અને ચારણના મેદાનોમાં છેલ્લા દસ દિવસમાં જન્મેલા તમામ બાળકોને મારી નાખીશું."
            }
        }
    },
    {
        "id": 100432,
        "sloka": "10.4.32",
        "verse_id": 100432,
        "verseNumber": 32,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The demigods always fear the sound of your bowstring. They are constantly in anxiety, afraid of fighting. Therefore, what can they do by their endeavors to harm you?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "आपकी धनुष की प्रत्यंचा की ध्वनि से देवता सदैव डरते रहते हैं। वे लगातार चिंता में रहते हैं, लड़ाई से डरते हैं। इसलिए, वे आपको नुकसान पहुँचाने के अपने प्रयासों से क्या कर सकते हैं?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "દેવતાઓ હંમેશા તમારા ધનુષ્યના અવાજથી ડરે છે. તેઓ સતત ચિંતામાં રહે છે, લડાઈથી ડરતા હોય છે. તેથી, તેઓ તમને નુકસાન પહોંચાડવાના તેમના પ્રયત્નો દ્વારા શું કરી શકે છે?"
            }
        }
    },
    {
        "id": 100433,
        "sloka": "10.4.33",
        "verse_id": 100433,
        "verseNumber": 33,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "While being pierced by your arrows, which you discharged on all sides, some of them, who were injured by the multitude of arrows but who desired to live, fled the battlefield, intent on escaping."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "आपके द्वारा छोड़े गए बाणों से, जिन्हें आपने चारों ओर छोड़ दिया था, घायल होने पर, उनमें से कुछ, जो बाणों की भीड़ से घायल हो गए थे, लेकिन जो जीवित रहना चाहते थे, भागने के इरादे से युद्ध के मैदान से भाग गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તમારા તીરોથી વિંધાઈ રહ્યા હતા, જે તમે ચારે બાજુથી છોડ્યા હતા, તેમાંના કેટલાક, જેઓ તીરોના ટોળાથી ઘાયલ થયા હતા, પરંતુ જેઓ જીવવા માંગતા હતા, તેઓ ભાગી જવાના ઇરાદે યુદ્ધના મેદાનમાંથી ભાગી ગયા હતા."
            }
        }
    },
    {
        "id": 100434,
        "sloka": "10.4.34",
        "verse_id": 100434,
        "verseNumber": 34,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Defeated and bereft of all weapons, some of the demigods gave up fighting and praised you with folded hands, and some of them, appearing before you with loosened garments and hair, said, “O lord, we are very much afraid of you.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "पराजित और सभी हथियारों से रहित होकर, कुछ देवताओं ने युद्ध करना छोड़ दिया और हाथ जोड़कर आपकी स्तुति की, और उनमें से कुछ ढीले वस्त्र और बालों के साथ आपके सामने आए और कहा, \"हे भगवान, हम आपसे बहुत डरते हैं।\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પરાજય પામેલા અને તમામ શસ્ત્રોથી વંચિત, કેટલાક દેવતાઓએ યુદ્ધ છોડી દીધું અને હાથ જોડીને તમારી પ્રશંસા કરી, અને તેમાંથી કેટલાક, છૂટા વસ્ત્રો અને વાળ સાથે તમારી સમક્ષ હાજર થયા, અને કહ્યું, \"હે ભગવાન, અમે તમારાથી ખૂબ જ ડરીએ છીએ.\""
            }
        }
    },
    {
        "id": 100435,
        "sloka": "10.4.35",
        "verse_id": 100435,
        "verseNumber": 35,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When the demigods are bereft of their chariots, when they forget how to use weapons, when they are fearful or attached to something other than fighting, or when their bows are broken and they have thus lost the ability to fight, Your Majesty does not kill them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब देवता अपने रथों से वंचित हो जाते हैं, जब वे हथियारों का उपयोग करना भूल जाते हैं, जब वे भयभीत होते हैं या लड़ने के अलावा किसी और चीज़ से आसक्त होते हैं, या जब उनके धनुष टूट जाते हैं और वे लड़ने की क्षमता खो देते हैं, तो महाराज उन्हें नहीं मारते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે દેવતાઓ તેમના રથથી વંચિત હોય છે, જ્યારે તેઓ શસ્ત્રોનો ઉપયોગ કરવાનું ભૂલી જાય છે, જ્યારે તેઓ ભયભીત હોય છે અથવા યુદ્ધ સિવાય અન્ય કોઈ વસ્તુ સાથે જોડાયેલા હોય છે, અથવા જ્યારે તેમના ધનુષ તૂટી જાય છે અને તેઓ લડવાની ક્ષમતા ગુમાવી દે છે, ત્યારે મહારાજ તેમને મારતા નથી."
            }
        }
    },
    {
        "id": 100436,
        "sloka": "10.4.36",
        "verse_id": 100436,
        "verseNumber": 36,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The demigods boast uselessly while away from the battlefield. Only where there is no fighting can they show their prowess. Therefore, from such demigods we have nothing to fear. As for Lord Viṣṇu, He is in seclusion in the core of the hearts of the yogīs. As for Lord Śiva, he has gone to the forest. And as for Lord Brahmā, he is always engaged in austerities and meditation. The other demigods, headed by Indra, are devoid of prowess. Therefore you have nothing to fear."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "युद्धभूमि से दूर रहने पर देवता व्यर्थ डींगें हांकते हैं। वे केवल वहीं अपना पराक्रम दिखा सकते हैं जहां कोई लड़ाई नहीं है। अत: ऐसे देवताओं से हमें डरने की कोई आवश्यकता नहीं है। जहां तक ​​भगवान विष्णु की बात है, वे योगियों के हृदय के केंद्र में एकांत में हैं। जहाँ तक भगवान शिव की बात है, वे वन में चले गये हैं। और जहाँ तक भगवान ब्रह्मा की बात है, वे सदैव तपस्या और ध्यान में लगे रहते हैं। इंद्र सहित अन्य देवता शक्ति से रहित हैं। इसलिए तुम्हें डरने की कोई बात नहीं है."
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ડેમિગોડ્સ યુદ્ધના મેદાનથી દૂર રહીને નકામી રીતે શેખી કરે છે. જ્યાં લડાઈ ન હોય ત્યાં જ તેઓ પોતાનું પરાક્રમ બતાવી શકે છે. તેથી, આવા દેવતાઓથી આપણે ડરવાનું કંઈ નથી. ભગવાન વિષ્ણુ માટે, તેઓ યોગીઓના હૃદયના મૂળમાં એકાંતમાં છે. ભગવાન શિવની વાત કરીએ તો તે વનમાં ગયા છે. અને ભગવાન બ્રહ્માની વાત કરીએ તો, તેઓ હંમેશા તપસ્યા અને ધ્યાન માં વ્યસ્ત રહે છે. ઇન્દ્રની આગેવાની હેઠળના અન્ય દેવતાઓ પરાક્રમથી વંચિત છે. તેથી તમારે ડરવાનું કંઈ નથી."
            }
        }
    },
    {
        "id": 100437,
        "sloka": "10.4.37",
        "verse_id": 100437,
        "verseNumber": 37,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Nonetheless, because of their enmity, our opinion is that the demigods should not be neglected. Therefore, to uproot them completely, engage us in fighting with them, for we are ready to follow you."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "फिर भी, शत्रुता के कारण देवताओं की उपेक्षा नहीं की जानी चाहिए। अत: उन्हें समूल उखाड़ फेंकने के लिए हमें उनसे युद्ध में लगाओ, क्योंकि हम तुम्हारे पीछे चलने को तैयार हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમ છતાં, તેમની દુશ્મનાવટને કારણે, અમારો અભિપ્રાય છે કે દેવતાઓની ઉપેક્ષા ન કરવી જોઈએ. તેથી, તેમને સંપૂર્ણ રીતે જડમૂળથી ઉખેડી નાખો, અમને તેમની સાથે લડવામાં જોડો, કારણ કે અમે તમને અનુસરવા તૈયાર છીએ."
            }
        }
    },
    {
        "id": 100438,
        "sloka": "10.4.38",
        "verse_id": 100438,
        "verseNumber": 38,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As a disease, if initially neglected, becomes acute and impossible to cure, or as the senses, if not controlled at first, are impossible to control later, an enemy, if neglected in the beginning, later becomes insurmountable."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जिस प्रकार किसी रोग को, यदि प्रारंभ में उपेक्षित किया जाए, तो तीव्र हो जाता है और उसका उपचार करना असंभव हो जाता है, अथवा जिस प्रकार इंद्रियों को, यदि प्रारंभ में नियंत्रित न किया जाए, तो बाद में नियंत्रित करना असंभव हो जाता है, उसी प्रकार यदि प्रारंभ में ही उपेक्षित कर दिया जाए, तो शत्रु बाद में दुर्बल हो जाता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક રોગ તરીકે, જો શરૂઆતમાં ઉપેક્ષા કરવામાં આવે, તો તે તીવ્ર અને ઇલાજ અશક્ય બની જાય છે, અથવા જેમ કે ઇન્દ્રિયો, જો શરૂઆતમાં કાબૂમાં ન હોય, તો પછીથી નિયંત્રિત કરવું અશક્ય હોય છે, દુશ્મન, જો શરૂઆતમાં ઉપેક્ષા કરવામાં આવે તો, પછીથી દુસ્તર બની જાય છે."
            }
        }
    },
    {
        "id": 100439,
        "sloka": "10.4.39",
        "verse_id": 100439,
        "verseNumber": 39,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The foundation of all the demigods is Lord Viṣṇu, who lives and is worshiped wherever there are religious principles, traditional culture, the Vedas, cows, brāhmaṇas, austerities, and sacrifices with proper remuneration."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "सभी देवताओं की नींव भगवान विष्णु हैं, जो जहां भी धार्मिक सिद्धांत, पारंपरिक संस्कृति, वेद, गाय, ब्राह्मण, तपस्या और उचित पारिश्रमिक के साथ बलिदान होते हैं, वहां रहते हैं और उनकी पूजा की जाती है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તમામ દેવતાઓનો પાયો ભગવાન વિષ્ણુ છે, જે જ્યાં પણ ધાર્મિક સિદ્ધાંતો, પરંપરાગત સંસ્કૃતિ, વેદ, ગાય, બ્રાહ્મણ, તપસ્યા અને યોગ્ય મહેનતાણું સાથે બલિદાન હોય ત્યાં વસે છે અને તેમની પૂજા કરવામાં આવે છે."
            }
        }
    },
    {
        "id": 100440,
        "sloka": "10.4.40",
        "verse_id": 100440,
        "verseNumber": 40,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, we, who are your adherents in all respects, shall therefore kill the Vedic brāhmaṇas, the persons engaged in offering sacrifices and austerities, and the cows that supply milk, from which clarified butter is obtained for the ingredients of sacrifice."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजा, हम, जो सभी प्रकार से आपके अनुयायी हैं, इसलिए वैदिक ब्राह्मणों, यज्ञ और तपस्या में लगे व्यक्तियों और दूध देने वाली गायों को मार डालेंगे, जिनसे यज्ञ की सामग्री के लिए स्पष्ट मक्खन प्राप्त होता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, અમે, જેઓ બધી રીતે તમારા અનુયાયીઓ છીએ, તેથી અમે વૈદિક બ્રાહ્મણો, યજ્ઞો અને તપસ્યામાં રોકાયેલા વ્યક્તિઓ અને દૂધ આપતી ગાયોને મારી નાખીશું, જેમાંથી બલિદાનના ઘટકો માટે સ્પષ્ટ માખણ મેળવવામાં આવે છે."
            }
        }
    },
    {
        "id": 100441,
        "sloka": "10.4.41",
        "verse_id": 100441,
        "verseNumber": 41,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The brāhmaṇas, the cows, Vedic knowledge, austerity, truthfulness, control of the mind and senses, faith, mercy, tolerance and sacrifice are the different parts of the body of Lord Viṣṇu, and they are the paraphernalia for a godly civilization."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "ब्राह्मण, गाय, वैदिक ज्ञान, तपस्या, सत्यता, मन और इंद्रियों पर नियंत्रण, विश्वास, दया, सहिष्णुता और बलिदान भगवान विष्णु के शरीर के विभिन्न अंग हैं, और वे एक ईश्वरीय सभ्यता के लिए सामग्री हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બ્રાહ્મણો, ગાયો, વૈદિક જ્ઞાન, તપસ્યા, સત્યતા, મન અને ઇન્દ્રિયોનું નિયંત્રણ, શ્રદ્ધા, દયા, સહનશીલતા અને ત્યાગ એ ભગવાન વિષ્ણુના શરીરના જુદાં જુદાં અંગો છે, અને તેઓ એક ઈશ્વરીય સંસ્કૃતિ માટે સાધનસામગ્રી છે."
            }
        }
    },
    {
        "id": 100442,
        "sloka": "10.4.42",
        "verse_id": 100442,
        "verseNumber": 42,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Viṣṇu, the Supersoul within the core of everyone’s heart, is the ultimate enemy of the asuras and is therefore known as asura-dviṭ. He is the leader of all the demigods because all the demigods, including Lord Śiva and Lord Brahmā, exist under His protection. The great saintly persons, sages and Vaiṣṇavas also depend upon Him. To persecute the Vaiṣṇavas, therefore, is the only way to kill Viṣṇu."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान विष्णु, हर किसी के हृदय के मूल में स्थित परमात्मा, असुरों के परम शत्रु हैं और इसलिए उन्हें असुर-द्वित्व के रूप में जाना जाता है। वह सभी देवताओं के नेता हैं क्योंकि भगवान शिव और भगवान ब्रह्मा सहित सभी देवता उनके संरक्षण में रहते हैं। महान संत, साधु और वैष्णव भी उन पर निर्भर रहते हैं। इसलिए, वैष्णवों पर अत्याचार करना, विष्णु को मारने का एकमात्र तरीका है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન વિષ્ણુ, દરેકના હૃદયના મૂળમાં રહેલા પરમાત્મા, અસુરોના અંતિમ શત્રુ છે અને તેથી તેઓ અસુર-દ્વિત તરીકે ઓળખાય છે. તે તમામ દેવતાઓના નેતા છે કારણ કે ભગવાન શિવ અને ભગવાન બ્રહ્મા સહિત તમામ દેવતાઓ તેમના રક્ષણ હેઠળ અસ્તિત્વ ધરાવે છે. મહાન સંતપુરુષો, ઋષિઓ અને વૈષ્ણવો પણ તેમના પર આધાર રાખે છે. તેથી, વૈષ્ણવોને સતાવવો એ વિષ્ણુને મારવાનો એકમાત્ર રસ્તો છે."
            }
        }
    },
    {
        "id": 100443,
        "sloka": "10.4.43",
        "verse_id": 100443,
