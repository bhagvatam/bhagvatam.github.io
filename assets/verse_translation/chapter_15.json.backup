[
    {
        "id": 101501,
        "sloka": "10.15.1",
        "verse_id": 101501,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: When Lord Rāma and Lord Kṛṣṇa attained the age of paugaṇḍa [six to ten] while living in Vṛndāvana, the cowherd men allowed Them to take up the task of tending the cows. Engaging thus in the company of Their friends, the two boys rendered the land of Vṛndāvana most auspicious by imprinting upon it the marks of Their lotus feet."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: जब भगवान राम और भगवान कृष्ण ने वृन्दावन में रहते हुए पौगंड [छह से दस] वर्ष की आयु प्राप्त की, तो चरवाहों ने उन्हें गायों को चराने का कार्य करने की अनुमति दी। इस प्रकार अपने मित्रों की संगति में संलग्न होकर, दोनों बालकों ने वृन्दावन की भूमि पर अपने चरण कमलों के चिह्न अंकित करके उसे परम मंगलमय बना दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: જ્યારે ભગવાન રામ અને ભગવાન કૃષ્ણ વૃંદાવનમાં રહેતા પૌગંડ [છ થી દસ] વર્ષની વયે પહોંચ્યા, ત્યારે ગોવાળિયાઓએ તેમને ગાયોની દેખરેખનું કાર્ય હાથ ધરવા દીધું. આ રીતે તેમના મિત્રોની સંગતમાં સામેલ થઈને, બે છોકરાઓએ વૃંદાવનની ભૂમિને તેમના કમળના ચરણોની નિશાનીઓ પર અંકિત કરીને ખૂબ જ શુભ બનાવી."
            }
        }
    },
    {
        "id": 101502,
        "sloka": "10.15.2",
        "verse_id": 101502,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Thus desiring to enjoy pastimes, Lord Mādhava, sounding His flute, surrounded by cowherd boys who were chanting His glories, and accompanied by Lord Baladeva, kept the cows before Him and entered the Vṛndāvana forest, which was full of flowers and rich with nourishment for the animals."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार लीलाओं का आनंद लेने की इच्छा से, भगवान माधव अपनी बांसुरी बजाते हुए, चरवाहे लड़कों से घिरे हुए थे जो उनकी महिमा का जाप कर रहे थे, और भगवान बलदेव के साथ, गायों को अपने सामने रखा और वृन्दावन वन में प्रवेश किया, जो फूलों से भरा था और जानवरों के लिए पोषण से समृद्ध था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે વિનોદનો આનંદ માણવાની ઈચ્છા ધરાવતા, ભગવાન માધવ, તેમની વાંસળી વગાડતા, ગોવાળો છોકરાઓથી ઘેરાયેલા, જેઓ તેમની કીર્તિનો જપ કરી રહ્યા હતા, અને ભગવાન બલદેવની સાથે, તેમની આગળ ગાયો રાખી અને વૃંદાવન વનમાં પ્રવેશ્યા, જે ફૂલોથી ભરેલું હતું અને પ્રાણીઓ માટે પોષણથી સમૃદ્ધ હતું."
            }
        }
    },
    {
        "id": 101503,
        "sloka": "10.15.3",
        "verse_id": 101503,
        "verseNumber": 3,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The Supreme Personality of Godhead looked over that forest, which resounded with the charming sounds of bees, animals and birds, and which was enhanced by a lake whose clear water resembled the minds of great souls and by a breeze carrying the fragrance of hundred-petaled lotuses. Seeing all this, Lord Kṛṣṇa decided to enjoy the auspicious atmosphere."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान के परम व्यक्तित्व ने उस जंगल को देखा, जो मधुमक्खियों, जानवरों और पक्षियों की मनमोहक आवाज़ों से गूंज रहा था, और जो एक झील से बढ़ गया था जिसका साफ पानी महान आत्माओं के दिमाग जैसा दिखता था और सौ पंखुड़ियों वाले कमल की सुगंध वाली हवा थी। यह सब देखकर, भगवान कृष्ण ने शुभ वातावरण का आनंद लेने का फैसला किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પરમપુરુષ ભગવાને તે જંગલ તરફ જોયું, જે મધમાખીઓ, પ્રાણીઓ અને પક્ષીઓના મોહક અવાજોથી ગુંજી ઉઠ્યું હતું, અને જે એક સરોવર દ્વારા ઉન્નત થયું હતું જેનું સ્વચ્છ પાણી મહાન આત્માઓના મન જેવું હતું અને સો-પાંખડીવાળા કમળની સુગંધ વહન કરતી પવન દ્વારા. આ બધું જોઈને, ભગવાન કૃષ્ણએ શુભ વાતાવરણનો આનંદ લેવાનું નક્કી કર્યું."
            }
        }
    },
    {
        "id": 101504,
        "sloka": "10.15.4",
        "verse_id": 101504,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The primeval Lord saw that the stately trees, with their beautiful reddish buds and their heavy burden of fruits and flowers, were bending down to touch His feet with the tips of their branches. Thus He smiled gently and addressed His elder brother."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "आदि भगवान ने देखा कि खूबसूरत लाल कलियों और फलों और फूलों के भारी बोझ के साथ आलीशान पेड़ अपनी शाखाओं की युक्तियों से उनके चरणों को छूने के लिए झुक रहे थे। इस प्रकार वह धीरे से मुस्कुराए और अपने बड़े भाई को संबोधित किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આદિમ ભગવાને જોયું કે ભવ્ય વૃક્ષો, તેમની સુંદર લાલ કળીઓ અને તેમના ફળો અને ફૂલોના ભારે ભાર સાથે, તેમની ડાળીઓની ટીપ્સ સાથે તેમના ચરણ સ્પર્શ કરવા માટે નીચે ઝૂકી રહ્યા હતા. આમ તેણે હળવું સ્મિત કર્યું અને તેના મોટા ભાઈને સંબોધન કર્યું."
            }
        }
    },
    {
        "id": 101505,
        "sloka": "10.15.5",
        "verse_id": 101505,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The Supreme Personality of Godhead said: O greatest of Lords, just see how these trees are bowing their heads at Your lotus feet, which are worshipable by the immortal demigods. The trees are offering You their fruits and flowers to eradicate the dark ignorance that has caused their birth as trees."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान के परम व्यक्तित्व ने कहा: हे भगवानों में सबसे महान, जरा देखो कि कैसे ये पेड़ आपके कमल चरणों में अपना सिर झुका रहे हैं, जो अमर देवताओं द्वारा पूजनीय हैं। वृक्ष उस अंधकारपूर्ण अज्ञान को मिटाने के लिए आपको अपने फल और फूल अर्पित कर रहे हैं जिसके कारण उनका वृक्ष के रूप में जन्म हुआ है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાનના પરમ પુરૂષે કહ્યું: હે પરમ ભગવાનો, જુઓ કે આ વૃક્ષો તમારા કમળના ચરણોમાં કેવી રીતે માથું નમાવી રહ્યા છે, જે અમર દેવતાઓ દ્વારા પૂજનીય છે. વૃક્ષો તને પોતાનાં ફળો અને ફૂલો અર્પણ કરી રહ્યાં છે, જેના કારણે તેમનો વૃક્ષ તરીકે જન્મ થયો છે તે અંધકારમય અજ્ઞાનને દૂર કરવા."
            }
        }
    },
    {
        "id": 101506,
        "sloka": "10.15.6",
        "verse_id": 101506,
        "verseNumber": 6,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Original Personality, these bees must all be great sages and most elevated devotees of Yours, for they are worshiping You by following You along the path and chanting Your glories, which are themselves a holy place for the entire world. Though You have disguised Yourself within this forest, O sinless one, they refuse to abandon You, their worshipable Lord."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे मूल व्यक्तित्व, ये मधुमक्खियाँ अवश्य ही महान ऋषि और आपकी सबसे श्रेष्ठ भक्त होंगी, क्योंकि वे आपके मार्ग पर चलकर आपकी पूजा कर रही हैं और आपकी महिमा का गान कर रही हैं, जो स्वयं पूरी दुनिया के लिए एक पवित्र स्थान है। यद्यपि आपने स्वयं को इस वन में छिपाकर रखा है, हे पापरहित, वे आपको, अपने पूजनीय भगवान को त्यागने से इनकार करते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે મૂળ વ્યક્તિત્વ, આ મધમાખીઓ બધા મહાન ઋષિમુનિઓ અને તમારા ઉચ્ચતમ ભક્તો હોવા જોઈએ, કારણ કે તેઓ તમને માર્ગ પર અનુસરીને અને તમારા મહિમાનો જપ કરીને તમારી પૂજા કરે છે, જે સમગ્ર વિશ્વ માટે એક પવિત્ર સ્થાન છે. હે નિર્દોષ, તમે આ જંગલમાં તમારો વેશ ધારણ કર્યો હોવા છતાં, તેઓ તેમના પૂજ્ય ભગવાન, તમારો ત્યાગ કરવાનો ઇનકાર કરે છે."
            }
        }
    },
    {
        "id": 101507,
        "sloka": "10.15.7",
        "verse_id": 101507,
        "verseNumber": 7,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O worshipable one, these peacocks are dancing before You out of joy, these doe are pleasing You with affectionate glances, just as the gopīs do, and these cuckoos are honoring You with Vedic prayers. All these residents of the forest are most fortunate, and their behavior toward You certainly befits great souls receiving another great soul at home."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे पूजनीय, ये मोर खुशी से आपके सामने नाच रहे हैं, ये हिरणियाँ आपको गोपियों की तरह स्नेह भरी निगाहों से प्रसन्न कर रही हैं, और ये कोयल वैदिक प्रार्थनाओं के साथ आपका सम्मान कर रही हैं। वन के ये सभी निवासी अत्यंत भाग्यशाली हैं, और आपके प्रति उनका व्यवहार निश्चित रूप से उन महान आत्माओं के अनुरूप है जो घर पर एक और महान आत्मा को प्राप्त कर रहे हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે પૂજનીય, આ મોર આનંદથી તારી સમક્ષ નાચી રહ્યા છે, આ ડોઓ તને પ્રેમભરી નજરોથી પ્રસન્ન કરે છે, જેમ ગોપીઓ કરે છે, અને આ કોયલ વૈદિક પ્રાર્થનાઓથી તારું સન્માન કરે છે. જંગલના આ બધા રહેવાસીઓ સૌથી ભાગ્યશાળી છે, અને તમારા પ્રત્યેનું તેમનું વર્તન ચોક્કસપણે મહાન આત્માઓને ઘરે બીજા મહાન આત્માને પ્રાપ્ત કરે છે."
            }
        }
    },
    {
        "id": 101508,
        "sloka": "10.15.8",
        "verse_id": 101508,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "This earth has now become most fortunate, because You have touched her grass and bushes with Your feet and her trees and creepers with Your fingernails, and because You have graced her rivers, mountains, birds and animals with Your merciful glances. But above all, You have embraced the young cowherd women between Your two arms — a favor hankered after by the goddess of fortune herself."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "यह पृथ्वी अब सबसे भाग्यशाली हो गई है, क्योंकि आपने इसकी घास और झाड़ियों को अपने पैरों से और इसके पेड़ों और लताओं को अपने नाखूनों से छुआ है, और क्योंकि आपने इसकी नदियों, पहाड़ों, पक्षियों और जानवरों को अपनी दयालु दृष्टि से अनुग्रहित किया है। लेकिन सबसे बढ़कर, आपने युवा चरवाहे महिलाओं को अपनी दोनों भुजाओं के बीच गले लगा लिया है - एक ऐसा अनुग्रह जिसके लिए स्वयं भाग्य की देवी लालायित हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ પૃથ્વી હવે સૌથી ભાગ્યશાળી બની છે, કારણ કે તમે તમારા પગથી તેના ઘાસ અને ઝાડીઓને અને તેના વૃક્ષો અને લતાઓને તમારા નખથી સ્પર્શ કર્યા છે, અને કારણ કે તમે તેની નદીઓ, પર્વતો, પક્ષીઓ અને પ્રાણીઓને તમારી દયાળુ નજરોથી આકર્ષ્યા છે. પરંતુ સૌથી વધુ, તમે તમારા બે હાથો વચ્ચે યુવાન ગોવાળો સ્ત્રીઓને આલિંગન આપ્યું છે - એક તરફેણ જે નસીબની દેવીએ પોતે જ કરેલી છે."
            }
        }
    },
    {
        "id": 101509,
        "sloka": "10.15.9",
        "verse_id": 101509,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: Thus expressing His satisfaction with the beautiful forest of Vṛndāvana and its inhabitants, Lord Kṛṣṇa enjoyed tending the cows and other animals with His friends on the banks of the river Yamunā below Govardhana Hill."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: इस प्रकार वृन्दावन के सुंदर वन और उसके निवासियों के प्रति अपनी संतुष्टि व्यक्त करते हुए, भगवान कृष्ण ने गोवर्धन पर्वत के नीचे यमुना नदी के तट पर अपने दोस्तों के साथ गायों और अन्य जानवरों को चराने का आनंद लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: આ રીતે વૃંદાવનના સુંદર જંગલ અને તેના રહેવાસીઓ પ્રત્યે તેમનો સંતોષ વ્યક્ત કરતા, ભગવાન કૃષ્ણને તેમના મિત્રો સાથે ગોવર્ધન પર્વતની નીચે યમુના નદીના કિનારે ગાયો અને અન્ય પ્રાણીઓની સંભાળ રાખવામાં આનંદ થયો."
            }
        }
    },
    {
        "id": 101510,
        "sloka": "10.15.10-12",
        "verse_id": 101510,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Sometimes the honeybees in Vṛndāvana became so mad with ecstasy that they closed their eyes and began to sing. Lord Kṛṣṇa, moving along the forest path with His cowherd boyfriends and Baladeva, would then respond to the bees by imitating their singing while His friends sang about His pastimes. Sometimes Lord Kṛṣṇa would imitate the chattering of a parrot, sometimes, with a sweet voice, the call of a cuckoo, and sometimes the cooing of swans. Sometimes He vigorously imitated the dancing of a peacock, making His cowherd boyfriends laugh. Sometimes, with a voice as deep as the rumbling of clouds, He would call out with great affection the names of the animals who had wandered far from the herd, thus enchanting the cows and the cowherd boys."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कभी-कभी वृन्दावन में मधुमक्खियाँ आनंद से इतनी उन्मत्त हो जाती थीं कि वे अपनी आँखें बंद कर लेती थीं और गाने लगती थीं। भगवान कृष्ण, अपने ग्वाल-बालों और बलदेव के साथ वन पथ पर चलते हुए, मधुमक्खियों के गायन का अनुकरण करके उन्हें जवाब देते थे, जबकि उनके मित्र उनकी लीलाओं के बारे में गाते थे। कभी-कभी भगवान कृष्ण तोते की चहचहाहट की नकल करते थे, कभी मीठी आवाज के साथ, कोयल की आवाज़ की, और कभी-कभी हंसों की कूक की। कभी-कभी वह मोर के नृत्य की जोरदार नकल करते थे, जिससे उनके चरवाहे प्रेमी हंसते थे। कभी-कभी, बादलों की गड़गड़ाहट जैसी गहरी आवाज़ के साथ, वह बड़े प्यार से उन जानवरों के नाम पुकारता था जो झुंड से दूर भटक गए थे, और इस प्रकार गायों और चरवाहे लड़कों को मंत्रमुग्ध कर देते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કેટલીકવાર વૃંદાવનમાં મધમાખીઓ આનંદથી એટલી પાગલ થઈ જાય છે કે તેઓ પોતાની આંખો બંધ કરીને ગાવા લાગી. ભગવાન કૃષ્ણ, તેમના ગોવાળો બોયફ્રેન્ડ્સ અને બલદેવ સાથે જંગલના માર્ગ પર આગળ વધતા, પછી મધમાખીઓને તેમના ગાયનની નકલ કરીને જવાબ આપતા હતા જ્યારે તેમના મિત્રો તેમના મનોરંજન વિશે ગાયા હતા. ક્યારેક ભગવાન કૃષ્ણ પોપટની બકબકની નકલ કરતા, ક્યારેક, મધુર અવાજ સાથે, કોયલનો પોકાર, અને ક્યારેક હંસનો અવાજ. કેટલીકવાર તે જોરશોરથી મોરના નૃત્યની નકલ કરતો, તેના ગોવાળો બોયફ્રેન્ડને હસાવતો. કેટલીકવાર, વાદળોના ગડગડાટ જેવા ઊંડા અવાજ સાથે, તે ખૂબ જ પ્રેમથી એવા પ્રાણીઓના નામ બોલાવતા હતા જેઓ ટોળાથી દૂર ભટક્યા હતા, આમ ગાયો અને ગોવાળના છોકરાઓને મોહિત કરી દેતા હતા."
            }
        }
    },
    {
        "id": 101513,
        "sloka": "10.15.13",
        "verse_id": 101513,
        "verseNumber": 13,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Sometimes He would cry out in imitation of birds such as the cakoras, krauñcas, cakrāhvas, bhāradvājas and peacocks, and sometimes He would run away with the smaller animals in mock fear of lions and tigers."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कभी-कभी वह चकोर, क्रौंच, चक्रह्वा, भारद्वाज और मोर जैसे पक्षियों की नकल करके चिल्लाता था, और कभी-कभी वह शेरों और बाघों के डर से छोटे जानवरों के साथ भाग जाता था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કેટલીકવાર તે કાકોરા, ક્રૌંકા, ચકરાવા, ભારદ્વાજ અને મોર જેવા પક્ષીઓની નકલમાં બૂમો પાડતો, અને ક્યારેક તે સિંહ અને વાઘના ડરથી નાના પ્રાણીઓ સાથે ભાગી જતો."
            }
        }
    },
    {
        "id": 101514,
        "sloka": "10.15.14",
        "verse_id": 101514,
        "verseNumber": 14,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When His elder brother, fatigued from playing, would lie down with His head upon the lap of a cowherd boy, Lord Kṛṣṇa would help Him relax by personally massaging His feet and offering other services."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब उनके बड़े भाई, खेलने से थककर, एक चरवाहे लड़के की गोद में अपना सिर रखकर लेट जाते थे, तो भगवान कृष्ण व्यक्तिगत रूप से उनके पैरों की मालिश करके और अन्य सेवाएं देकर उन्हें आराम करने में मदद करते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે તેમના મોટા ભાઈ, રમવાથી થાકેલા, ગોવાળના છોકરાના ખોળામાં તેમનું માથું રાખીને સૂઈ જતા, ત્યારે ભગવાન કૃષ્ણ તેમને વ્યક્તિગત રીતે તેમના પગની માલિશ કરીને અને અન્ય સેવાઓ પ્રદાન કરીને આરામ કરવામાં મદદ કરતા."
            }
        }
    },
    {
        "id": 101515,
        "sloka": "10.15.15",
        "verse_id": 101515,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Sometimes, as the cowherd boys danced, sang, moved about and playfully fought with each other, Kṛṣṇa and Balarāma, standing nearby hand in hand, would glorify Their friends’ activities and laugh."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कभी-कभी, जब चरवाहे लड़के नृत्य करते थे, गाते थे, घूमते थे और एक-दूसरे के साथ खेलते थे, तो कृष्ण और बलराम, हाथ में हाथ डाले खड़े होकर, अपने दोस्तों की गतिविधियों की प्रशंसा करते थे और हँसते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કેટલીકવાર, જેમ ગોવાળો છોકરાઓ નાચતા, ગાયા, ફરતા અને રમતિયાળ રીતે એકબીજા સાથે લડતા, કૃષ્ણ અને બલરામ, નજીકમાં હાથ જોડીને ઉભા રહેતા, તેમના મિત્રોની પ્રવૃત્તિઓનો મહિમા કરતા અને હસતા."
            }
        }
    },
    {
        "id": 101516,
        "sloka": "10.15.16",
        "verse_id": 101516,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Sometimes Lord Kṛṣṇa grew tired from fighting and lay down at the base of a tree, resting upon a bed made of soft twigs and buds and using the lap of a cowherd friend as His pillow."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कभी-कभी भगवान कृष्ण युद्ध से थक जाते थे और एक पेड़ के नीचे नरम टहनियों और कलियों से बने बिस्तर पर आराम करते थे और एक चरवाहे मित्र की गोद को अपना तकिया बनाते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કેટલીકવાર ભગવાન કૃષ્ણ લડાઈથી થાકી ગયા હતા અને ઝાડના પાયા પર સૂઈ ગયા હતા, નરમ ડાળીઓ અને કળીઓથી બનેલા પલંગ પર આરામ કરતા હતા અને ગોવાળ મિત્રના ખોળાને તેમના ઓશીકા તરીકે ઉપયોગ કરતા હતા."
            }
        }
    },
    {
        "id": 101517,
        "sloka": "10.15.17",
        "verse_id": 101517,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Some of the cowherd boys, who were all great souls, would then massage His lotus feet, and others, qualified by being free of all sin, would expertly fan the Supreme Lord."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कुछ चरवाहे लड़के, जो सभी महान आत्माएँ थे, उनके कमल पैरों की मालिश करते थे, और अन्य, सभी पापों से मुक्त होने के कारण योग्य, कुशलता से परम भगवान को पंखा करते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કેટલાક ગોવાળો છોકરાઓ, જેઓ બધા મહાન આત્માઓ હતા, પછી તેમના કમળના ચરણોમાં માલિશ કરશે, અને અન્ય, બધા પાપોથી મુક્ત થઈને લાયક, નિપુણતાથી પરમ ભગવાનને ચાહશે."
            }
        }
    },
    {
        "id": 101518,
        "sloka": "10.15.18",
        "verse_id": 101518,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My dear King, other boys would sing enchanting songs appropriate to the occasion, and their hearts would melt out of love for the Lord."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रिय राजा, अन्य लड़के अवसर के अनुरूप मंत्रमुग्ध कर देने वाले गीत गाएंगे, और उनके हृदय प्रभु के प्रति प्रेम से पिघल जायेंगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા વ્હાલા રાજા, અન્ય છોકરાઓ પ્રસંગને અનુરૂપ મોહક ગીતો ગાશે, અને તેમના હૃદય ભગવાન માટેના પ્રેમથી પીગળી જશે."
            }
        }
    },
    {
        "id": 101519,
        "sloka": "10.15.19",
        "verse_id": 101519,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In this way the Supreme Lord, whose soft lotus feet are personally attended by the goddess of fortune, concealed His transcendental opulences by His internal potency and acted like the son of a cowherd. Yet even while enjoying like a village boy in the company of other village residents, He often exhibited feats only God could perform."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार भगवान, जिनके कोमल कमल चरणों में भाग्य की देवी व्यक्तिगत रूप से उपस्थित रहती हैं, ने अपनी दिव्य ऐश्वर्य को अपनी आंतरिक शक्ति से छुपाया और एक चरवाहे के पुत्र की तरह व्यवहार किया। फिर भी, गाँव के अन्य निवासियों के साथ एक गाँव के लड़के की तरह आनंद लेते हुए भी, वह अक्सर ऐसे करतब दिखाते थे जो केवल भगवान ही कर सकते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે પરમ ભગવાન, જેમના કોમળ કમળના ચરણોમાં સૌભાગ્યની દેવી અંગત રીતે હાજરી આપે છે, તેમણે તેમની આંતરિક શક્તિ દ્વારા તેમની દિવ્ય ઐશ્વર્યને છુપાવી અને ગોવાળના પુત્રની જેમ વર્ત્યા. તેમ છતાં, ગામડાના છોકરાની જેમ ગામના અન્ય રહેવાસીઓની સંગતમાં આનંદ માણતી વખતે પણ, તે ઘણીવાર એવા પરાક્રમો પ્રદર્શિત કરતો હતો જે ફક્ત ભગવાન જ કરી શકે."
            }
        }
    },
    {
        "id": 101520,
        "sloka": "10.15.20",
        "verse_id": 101520,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Once, some of the cowherd boys — Śrīdāmā, the very close friend of Rāma and Kṛṣṇa, along with Subala, Stokakṛṣṇa and others — lovingly spoke the following words."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक बार, कुछ चरवाहे लड़के - राम और कृष्ण के बहुत करीबी दोस्त श्रीदामा, सुबाला, स्टोकाकृष्ण और अन्य लोगों के साथ - प्यार से निम्नलिखित शब्द बोले।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એકવાર, કેટલાક ગોવાળિયા છોકરાઓ - શ્રીદામા, રામ અને કૃષ્ણના ખૂબ નજીકના મિત્ર, સુબાલા, સ્તોકકૃષ્ણ અને અન્યો સાથે - પ્રેમથી નીચેના શબ્દો બોલ્યા."
            }
        }
    },
    {
        "id": 101521,
        "sloka": "10.15.21",
        "verse_id": 101521,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[The cowherd boys said:] O Rāma, Rāma, mighty-armed one! O Kṛṣṇa, destroyer of the miscreants! Not far from here is a very great forest filled with rows of palm trees."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[ग्वालों ने कहा:] हे राम, राम, महाबाहु! हे कृष्ण, दुष्टों का नाश करने वाले! यहाँ से कुछ ही दूरी पर ताड़ के पेड़ों की कतारों से भरा एक बहुत बड़ा जंगल है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ગોવાળના છોકરાઓએ કહ્યું:] હે રામ, રામ, પરાક્રમી! હે કૃષ્ણ, દુષ્ટોનો નાશ કરનાર! અહીંથી દૂર ખજૂરીની હારમાળાઓથી ભરેલું ખૂબ જ મોટું જંગલ છે."
            }
        }
    },
    {
        "id": 101522,
        "sloka": "10.15.22",
        "verse_id": 101522,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In that Tālavana forest many fruits are falling from the trees, and many are already lying on the ground. But all the fruits are being guarded by the evil Dhenuka."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उस तलवना वन में बहुत से फल पेड़ों से गिर रहे हैं, और बहुत से पहले से ही जमीन पर पड़े हुए हैं। लेकिन सभी फलों की रक्षा दुष्ट धेनुका द्वारा की जा रही है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે તાલાવણના જંગલમાં વૃક્ષો પરથી ઘણા ફળો પડી રહ્યા છે, અને ઘણા જમીન પર પડ્યા છે. પરંતુ તમામ ફળોની રક્ષા દુષ્ટ ધેનુકા દ્વારા કરવામાં આવી રહી છે."
            }
        }
    },
    {
        "id": 101523,
        "sloka": "10.15.23",
        "verse_id": 101523,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Rāma, O Kṛṣṇa! Dhenuka is a most powerful demon and has assumed the form of an ass. He is surrounded by many friends who have assumed a similar shape and who are just as powerful as he."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राम, हे कृष्ण! धेनुका एक अत्यंत शक्तिशाली राक्षस है और उसने गधे का रूप धारण कर लिया है। वह कई दोस्तों से घिरा हुआ है जिन्होंने उसके समान आकार धारण कर लिया है और जो उसके जैसे ही शक्तिशाली हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રામ, હે કૃષ્ણ! ધેનુકા સૌથી શક્તિશાળી રાક્ષસ છે અને તેણે ગધેડાનું રૂપ ધારણ કર્યું છે. તે ઘણા મિત્રોથી ઘેરાયેલો છે જેમણે સમાન આકાર ધારણ કર્યો છે અને જેઓ તેમના જેવા જ શક્તિશાળી છે."
            }
        }
    },
    {
        "id": 101524,
        "sloka": "10.15.24",
        "verse_id": 101524,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The demon Dhenuka has eaten men alive, and therefore all people and animals are terrified of going to the Tāla forest. O killer of the enemy, even the birds are afraid to fly there."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "राक्षस धेनुका ने मनुष्यों को जीवित खा लिया है, और इसलिए सभी लोग और जानवर ताल वन में जाने से डरते हैं। हे शत्रु संहारक, पक्षी भी वहां उड़ने से डरते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ધેનુકા રાક્ષસ માણસોને જીવતા ખાઈ ગયો છે, અને તેથી બધા લોકો અને પ્રાણીઓ તાલાના જંગલમાં જતા ગભરાય છે. હે દુશ્મનના હત્યારા, પક્ષીઓ પણ ત્યાં ઉડતા ડરે છે."
            }
        }
    },
    {
        "id": 101525,
        "sloka": "10.15.25",
        "verse_id": 101525,
        "verseNumber": 25,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In the Tāla forest are sweet-smelling fruits no one has ever tasted. Indeed, even now we can smell the fragrance of the tāla fruits spreading all about."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "ताला वन में मीठी-महक वाले फल हैं जिनका स्वाद आज तक किसी ने नहीं चखा है। दरअसल, अब भी हम चारों ओर फैली ताल फलों की खुशबू को महसूस कर सकते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તાલાના જંગલમાં મધુર સુગંધવાળા ફળો છે જે ક્યારેય કોઈએ ચાખ્યા નથી. ખરેખર, અત્યારે પણ આપણે ચારે બાજુ ફેલાતા તાલા ફળોની સુગંધ અનુભવી શકીએ છીએ."
            }
        }
    },
    {
        "id": 101526,
        "sloka": "10.15.26",
        "verse_id": 101526,
        "verseNumber": 26,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O Kṛṣṇa! Please get those fruits for us. Our minds are so attracted by their aroma! Dear Balarāma, our desire to have those fruits is very great. If You think it’s a good idea, let’s go to that Tāla forest."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे कृष्ण! कृपया वे फल हमारे लिये ले आइये। उनकी सुगंध से हमारा मन इतना आकर्षित हो जाता है! प्रिय बलराम, उन फलों को पाने की हमारी इच्छा बहुत महान है। यदि आपको लगता है कि यह एक अच्छा विचार है, तो आइए उस ताला वन में चलें।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે કૃષ્ણ! કૃપા કરીને અમારા માટે તે ફળો મેળવો. આપણું મન તેમની સુગંધથી આકર્ષાય છે! પ્રિય બલરામ, તે ફળ મેળવવાની અમારી ઈચ્છા ખૂબ જ મહાન છે. જો તમને લાગે કે તે સારો વિચાર છે, તો ચાલો તે તાલા જંગલમાં જઈએ."
            }
        }
    },
    {
        "id": 101527,
        "sloka": "10.15.27",
        "verse_id": 101527,
        "verseNumber": 27,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Hearing the words of Their dear companions, Kṛṣṇa and Balarāma laughed and, desiring to please them, set off for the Tālavana surrounded by Their cowherd boyfriends."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपने प्रिय साथियों की बातें सुनकर, कृष्ण और बलराम हँसे और, उन्हें प्रसन्न करने की इच्छा से, अपने चरवाहे मित्रों से घिरे हुए तालवन की ओर चल पड़े।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમના પ્રિય સાથીઓના શબ્દો સાંભળીને, કૃષ્ણ અને બલરામ હસ્યા અને, તેમને ખુશ કરવા ઈચ્છતા, તેમના ગોવાળિયા પ્રેમીઓથી ઘેરાયેલા તાલાવણ તરફ પ્રયાણ કર્યું."
            }
        }
    },
    {
        "id": 101528,
        "sloka": "10.15.28",
        "verse_id": 101528,
        "verseNumber": 28,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Balarāma entered the Tāla forest first. Then with His two arms He began forcefully shaking the trees with the power of a maddened elephant, causing the tāla fruits to fall to the ground."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान बलराम ने सबसे पहले ताल वन में प्रवेश किया। फिर उन्होंने अपनी दोनों भुजाओं से पागल हाथी की शक्ति से पेड़ों को जोर-जोर से हिलाना शुरू कर दिया, जिससे ताल फल जमीन पर गिरने लगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બલરામે સૌ પ્રથમ તાલના જંગલમાં પ્રવેશ કર્યો. પછી તેના બે હાથ વડે તેણે બળપૂર્વક પાગલ હાથીની શક્તિથી ઝાડને હલાવવાનું શરૂ કર્યું, જેના કારણે તાલાના ફળો જમીન પર પડી ગયા."
            }
        }
    },
    {
        "id": 101529,
        "sloka": "10.15.29",
        "verse_id": 101529,
        "verseNumber": 29,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Hearing the sound of the falling fruits, the ass demon Dhenuka ran forward to attack, making the earth and trees tremble."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "फलों के गिरने की आवाज सुनकर गधा राक्षस धेनुका पृथ्वी और वृक्षों को कंपाता हुआ हमला करने के लिए आगे बढ़ा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ખરતા ફળોનો અવાજ સાંભળીને ગધેડો રાક્ષસ ધેનુકા હુમલો કરવા માટે આગળ દોડ્યો, જેનાથી પૃથ્વી અને વૃક્ષો ધ્રૂજી ગયા."
            }
        }
    },
    {
        "id": 101530,
        "sloka": "10.15.30",
        "verse_id": 101530,
        "verseNumber": 30,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The powerful demon rushed up to Lord Baladeva and sharply struck the Lord’s chest with the hooves of his hind legs. Then Dhenuka began to run about, braying loudly."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शक्तिशाली दानव भगवान बलदेव के पास पहुंचा और अपने पिछले पैरों के खुरों से भगवान की छाती पर तेजी से प्रहार किया। तब धेनुका जोर-जोर से चिल्लाते हुए इधर-उधर भागने लगी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શક્તિશાળી રાક્ષસ ભગવાન બલદેવ પાસે દોડી ગયો અને તેના પાછળના પગના ખૂંખાર વડે ભગવાનની છાતી પર જોરથી પ્રહાર કર્યો. પછી ધેનુકા જોર જોરથી દોડવા લાગી."
            }
        }
    },
    {
        "id": 101531,
        "sloka": "10.15.31",
        "verse_id": 101531,
        "verseNumber": 31,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Moving again toward Lord Balarāma, O King, the furious ass situated himself with his back toward the Lord. Then, screaming in rage, the demon hurled his two hind legs at Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, भगवान बलराम की ओर फिर से बढ़ते हुए, क्रोधित गधा अपनी पीठ भगवान की ओर करके स्थित हो गया। तब, क्रोध में चिल्लाते हुए, राक्षस ने अपने दोनों पिछले पैरों को उस पर फेंक दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ફરીથી ભગવાન બલરામ તરફ આગળ વધવું, હે રાજા, ક્રોધિત ગધેડો ભગવાન તરફ તેની પીઠ સાથે સ્થિત છે. પછી, ક્રોધાવેશમાં ચીસો પાડતા, રાક્ષસે તેના પાછળના બે પગ તેના પર ફેંક્યા."
            }
        }
    },
    {
        "id": 101532,
        "sloka": "10.15.32",
        "verse_id": 101532,
        "verseNumber": 32,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Balarāma seized Dhenuka by his hooves, whirled him about with one hand and threw him into the top of a palm tree. The violent wheeling motion killed the demon."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान बलराम ने धेनुका को अपने खुरों से पकड़ लिया, उसे एक हाथ से घुमाया और एक ताड़ के पेड़ के शीर्ष पर फेंक दिया। चक्र की हिंसक गति ने राक्षस को मार डाला।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બલરામે ધેનુકાને તેના ખુરથી પકડી, તેને એક હાથ વડે ચક્કર માર્યો અને તેને તાડના ઝાડની ટોચ પર ફેંકી દીધો. હિંસક ચક્ર ગતિએ રાક્ષસને મારી નાખ્યો."
            }
        }
    },
    {
        "id": 101533,
        "sloka": "10.15.33",
        "verse_id": 101533,
        "verseNumber": 33,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Balarāma threw the dead body of Dhenukāsura into the tallest palm tree in the forest, and when the dead demon landed in the treetop, the tree began shaking. The great palm tree, causing a tree by its side also to shake, broke under the weight of the demon. The neighboring tree caused yet another tree to shake, and this one struck yet another tree, which also began shaking. In this way many trees in the forest shook and broke."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान बलराम ने धेनुकासुर के शव को जंगल के सबसे ऊंचे ताड़ के पेड़ में फेंक दिया, और जब मृत राक्षस पेड़ की चोटी पर उतरा, तो पेड़ हिलने लगा। विशाल ताड़ का पेड़, जिससे उसके किनारे का एक पेड़ भी हिल गया, राक्षस के वजन से टूट गया। पड़ोसी पेड़ ने एक और पेड़ को हिला दिया, और इसने दूसरे पेड़ को टक्कर मार दी, जिससे वह भी हिलने लगा। इस प्रकार जंगल में अनेक वृक्ष हिलकर टूट गये।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બલરામે ધેનુકાસુરના મૃત દેહને જંગલના સૌથી ઊંચા તાડના ઝાડમાં ફેંકી દીધો, અને જ્યારે મૃત રાક્ષસ ઝાડની ટોચ પર ઉતર્યો, ત્યારે વૃક્ષ ધ્રૂજવા લાગ્યું. મહાન તાડનું વૃક્ષ, જેના કારણે તેની બાજુનું એક વૃક્ષ પણ હચમચી ગયું, તે રાક્ષસના વજન હેઠળ તૂટી ગયું. પડોશના ઝાડને કારણે બીજા ઝાડને ધ્રુજારી આવી, અને આ એક બીજા ઝાડ સાથે અથડાયું, જે પણ ધ્રૂજવા લાગ્યું. આ રીતે જંગલમાં અનેક વૃક્ષો હલી ગયા અને તૂટી પડ્યા."
            }
        }
    },
    {
        "id": 101534,
        "sloka": "10.15.34",
        "verse_id": 101534,
        "verseNumber": 34,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Because of Lord Balarāma’s pastime of throwing the body of the ass demon into the top of the tallest palm tree, all the trees began shaking and striking against one another as if blown about by powerful winds."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान बलराम द्वारा गधे राक्षस के शरीर को सबसे ऊंचे ताड़ के पेड़ के शीर्ष पर फेंकने की लीला के कारण, सभी पेड़ हिलने लगे और एक दूसरे से टकराने लगे जैसे कि शक्तिशाली हवाओं से उड़ गए हों।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન બલરામના ગધેડા રાક્ષસના શરીરને સૌથી ઉંચા તાડના ઝાડની ટોચ પર ફેંકવાના શોખને કારણે, બધા વૃક્ષો ધ્રૂજવા લાગ્યા અને એક બીજા પર અથડાવા લાગ્યા, જાણે કે જોરદાર પવન ફૂંકાતા હોય."
            }
        }
    },
    {
        "id": 101535,
        "sloka": "10.15.35",
        "verse_id": 101535,
        "verseNumber": 35,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "My dear Parīkṣit, that Lord Balarāma killed Dhenukāsura is not such a wonderful thing, considering that He is the unlimited Personality of Godhead, the controller of the entire universe. Indeed, the entire cosmos rests upon Him just as a woven cloth rests upon its own horizontal and vertical threads."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "मेरे प्रिय परीक्षित, यह देखते हुए कि भगवान बलराम ने धेनुकासुर का वध किया, यह इतनी आश्चर्यजनक बात नहीं है, यह देखते हुए कि वे संपूर्ण ब्रह्मांड के नियंत्रक, असीमित व्यक्तित्व वाले भगवान हैं। वास्तव में, संपूर्ण ब्रह्मांड उसी पर टिका हुआ है, जैसे एक बुना हुआ कपड़ा अपने क्षैतिज और ऊर्ध्वाधर धागों पर टिका होता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મારા વ્હાલા પરીક્ષિત, ભગવાન બલરામે ધેનુકાસુરનો વધ કર્યો તે એટલી અદ્ભુત બાબત નથી, કારણ કે તે ભગવાનના અમર્યાદિત વ્યક્તિત્વ છે, સમગ્ર બ્રહ્માંડના નિયંત્રક છે. ખરેખર, આખું બ્રહ્માંડ તેના પર ટકેલું છે જેમ વણેલું કાપડ તેના પોતાના આડા અને ઊભા થ્રેડો પર ટકે છે."
            }
        }
    },
    {
        "id": 101536,
        "sloka": "10.15.36",
        "verse_id": 101536,
        "verseNumber": 36,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The other ass demons, close friends of Dhenukāsura, were enraged upon seeing his death, and thus they all immediately ran to attack Kṛṣṇa and Balarāma."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "धेनुकासुर के घनिष्ठ मित्र अन्य गधा राक्षस उसकी मृत्यु देखकर क्रोधित हो गए और इस प्रकार वे सभी तुरंत कृष्ण और बलराम पर हमला करने के लिए दौड़ पड़े।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "અન્ય ગધેડા રાક્ષસો, ધેનુકાસુરના નજીકના મિત્રો, તેમના મૃત્યુને જોઈને ગુસ્સે થયા, અને આ રીતે તેઓ બધા તરત જ કૃષ્ણ અને બલરામ પર હુમલો કરવા દોડ્યા."
            }
        }
    },
    {
        "id": 101537,
        "sloka": "10.15.37",
        "verse_id": 101537,
        "verseNumber": 37,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, as the demons attacked, Kṛṣṇa and Balarāma easily seized them one after another by their hind legs and threw them all into the tops of the palm trees."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, जैसे ही राक्षसों ने हमला किया, कृष्ण और बलराम ने आसानी से उन्हें अपने पिछले पैरों से एक के बाद एक पकड़ लिया और उन सभी को ताड़ के पेड़ों के शीर्ष पर फेंक दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, જેમ રાક્ષસોએ હુમલો કર્યો, કૃષ્ણ અને બલરામે તેમને એક પછી એક તેમના પાછળના પગથી સરળતાથી પકડી લીધા અને તે બધાને તાડના ઝાડની ટોચ પર ફેંકી દીધા."
            }
        }
    },
    {
        "id": 101538,
        "sloka": "10.15.38",
        "verse_id": 101538,
        "verseNumber": 38,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The earth then appeared beautifully covered with heaps of fruits and with the dead bodies of the demons, which were entangled in the broken tops of the palm trees. Indeed, the earth shone like the sky decorated with clouds."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तब पृथ्वी फलों के ढेर और राक्षसों के शवों से खूबसूरती से ढकी हुई दिखाई दी, जो ताड़ के पेड़ों की टूटी हुई चोटियों में उलझे हुए थे। सचमुच, पृथ्वी बादलों से सुशोभित आकाश के समान चमक रही थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પૃથ્વી પછી ફળોના ઢગલા અને રાક્ષસોના મૃતદેહોથી સુંદર રીતે ઢંકાયેલી દેખાઈ, જે તાડના ઝાડની તૂટેલી ટોચમાં ફસાઈ ગઈ હતી. ખરેખર, પૃથ્વી વાદળોથી સુશોભિત આકાશની જેમ ચમકતી હતી."
            }
        }
    },
    {
        "id": 101539,
        "sloka": "10.15.39",
        "verse_id": 101539,
        "verseNumber": 39,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Hearing of this magnificent feat of the two brothers, the demigods and other elevated living beings rained down flowers and offered music and prayers in glorification."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "दोनों भाइयों के इस शानदार पराक्रम को सुनकर, देवताओं और अन्य श्रेष्ठ प्राणियों ने फूलों की वर्षा की और महिमा में संगीत और प्रार्थनाएँ कीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બંને ભાઈઓના આ ભવ્ય પરાક્રમ વિશે સાંભળીને, દેવતાઓ અને અન્ય ઉચ્ચ જીવોએ ફૂલોનો વરસાદ કર્યો અને સ્તુતિમાં સંગીત અને પ્રાર્થના કરી."
            }
        }
    },
    {
        "id": 101540,
        "sloka": "10.15.40",
        "verse_id": 101540,
        "verseNumber": 40,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "People now felt free to return to the forest where Dhenuka had been killed, and without fear they ate the fruits of the palm trees. Also, the cows could now graze freely upon the grass there."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "लोग अब स्वतंत्र होकर उस जंगल में लौट आए जहां धेनुका मारा गया था, और बिना किसी डर के उन्होंने ताड़ के पेड़ों के फल खाए। साथ ही, गायें अब वहां स्वतंत्र रूप से घास चर सकती थीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "લોકો હવે જંગલમાં પાછા ફરવા માટે મુક્ત થયા જ્યાં ધેનુકાને મારવામાં આવ્યો હતો, અને ભય વિના તેઓએ તાડના ઝાડના ફળ ખાધા. વળી, ગાયો હવે ત્યાંના ઘાસ પર મુક્તપણે ચરી શકતી હતી."
            }
        }
    },
    {
        "id": 101541,
        "sloka": "10.15.41",
        "verse_id": 101541,
        "verseNumber": 41,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Then lotus-eyed Lord Śrī Kṛṣṇa, whose glories are most pious to hear and chant, returned home to Vraja with His elder brother, Balarāma. Along the way, the cowherd boys, His faithful followers, chanted His glories."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तब कमल-नेत्र भगवान श्रीकृष्ण, जिनकी महिमा सुनने और कीर्तन करने के लिए अत्यंत पवित्र है, अपने बड़े भाई बलराम के साथ व्रज में घर लौट आए। रास्ते में, चरवाहे लड़के, उनके वफादार अनुयायी, उनकी महिमा का जाप करते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પછી કમળ આંખોવાળા ભગવાન શ્રી કૃષ્ણ, જેમનો મહિમા સાંભળવા અને જપ કરવા માટે સૌથી વધુ પવિત્ર છે, તેમના મોટા ભાઈ, બલરામ સાથે વ્રજ પાસે પાછા ફર્યા. રસ્તામાં, ગોવાળો છોકરાઓ, તેમના વિશ્વાસુ અનુયાયીઓ, તેમના મહિમાનો મંત્રોચ્ચાર કરતા હતા."
            }
        }
    },
    {
        "id": 101542,
        "sloka": "10.15.42",
        "verse_id": 101542,
        "verseNumber": 42,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Lord Kṛṣṇa’s hair, powdered with the dust raised by the cows, was decorated with a peacock feather and forest flowers. The Lord glanced charmingly and smiled beautifully, playing upon His flute while His companions chanted His glories. The gopīs, all together, came forward to meet Him, their eyes very eager to see Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "भगवान कृष्ण के बाल, गायों द्वारा उठाए गए धूल से सने हुए, मोर पंख और वन फूलों से सजाए गए थे। जब उनके साथी उनकी महिमा का गान कर रहे थे, तब भगवान अपनी बांसुरी बजाते हुए मनमोहक दृष्टि से देख रहे थे और खूबसूरती से मुस्कुरा रहे थे। गोपियाँ, सभी एक साथ, उनसे मिलने के लिए आगे आईं, उनकी आँखें उन्हें देखने के लिए बहुत उत्सुक थीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ભગવાન કૃષ્ણના વાળ, ગાયો દ્વારા ઉગાડવામાં આવેલી ધૂળથી પાઉડર, મોર પીંછા અને જંગલના ફૂલોથી શણગારવામાં આવ્યા હતા. ભગવાન મોહક રીતે જોયા અને સુંદર રીતે સ્મિત કર્યું, તેમની વાંસળી વગાડતા હતા જ્યારે તેમના સાથીઓએ તેમના મહિમાનો મંત્રોચ્ચાર કર્યો હતો. ગોપીઓ, બધા એક સાથે, તેમને મળવા આગળ આવ્યા, તેમની આંખો તેમને જોવા માટે ખૂબ ઉત્સુક હતી."
            }
        }
    },
    {
        "id": 101543,
        "sloka": "10.15.43",
        "verse_id": 101543,
        "verseNumber": 43,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "With their beelike eyes, the women of Vṛndāvana drank the honey of the beautiful face of Lord Mukunda, and thus they gave up the distress they had felt during the day because of separation from Him. The young Vṛndāvana ladies cast sidelong glances at the Lord — glances filled with bashfulness, laughter and submission — and Śrī Kṛṣṇa, completely accepting these glances as a proper offering of respect, entered the cowherd village."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपनी गोलाकार आँखों से, वृन्दावन की महिलाओं ने भगवान मुकुंद के सुंदर चेहरे का शहद पी लिया, और इस तरह उन्होंने उनसे अलग होने के कारण दिन के दौरान महसूस की गई परेशानी को त्याग दिया। युवा वृन्दावन महिलाओं ने भगवान की ओर तिरछी निगाहें डालीं - लज्जा, हंसी और समर्पण से भरी नजरें - और श्रीकृष्ण ने, इन नजरों को सम्मान की उचित पेशकश के रूप में पूरी तरह से स्वीकार करते हुए, चरवाहे गांव में प्रवेश किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમની મધમાખી જેવી આંખોથી, વૃંદાવનની સ્ત્રીઓએ ભગવાન મુકુંદના સુંદર ચહેરાનું મધ પીધું, અને આ રીતે તેઓએ તેમનાથી વિખૂટા પડવાને કારણે દિવસ દરમિયાન અનુભવેલી તકલીફનો ત્યાગ કર્યો. વૃંદાવનની યુવાન મહિલાઓએ ભગવાન તરફ એક તરફ નજર નાખી - શરમ, હાસ્ય અને આધીનતાથી ભરેલી નજરો - અને શ્રી કૃષ્ણ, આ નજરોને આદરના યોગ્ય અર્પણ તરીકે સંપૂર્ણપણે સ્વીકારીને, ગોવાળ ગામમાં પ્રવેશ્યા."
            }
        }
    },
    {
        "id": 101544,
        "sloka": "10.15.44",
        "verse_id": 101544,
        "verseNumber": 44,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Mother Yaśodā and mother Rohiṇī, acting most affectionately toward their two sons, offered all the best things to Them in response to Their every desire and at the various appropriate times."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "माता यशोदा और माता रोहिणी ने, अपने दोनों पुत्रों के प्रति अत्यधिक स्नेह दिखाते हुए, उनकी हर इच्छा के अनुसार और विभिन्न उचित समय पर उन्हें सभी सर्वोत्तम चीजें अर्पित कीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "માતા યશોદા અને માતા રોહિણી, તેમના બે પુત્રો પ્રત્યે ખૂબ જ પ્રેમથી વર્તે છે, તેમની દરેક ઇચ્છાના જવાબમાં અને વિવિધ યોગ્ય સમયે તેમને બધી શ્રેષ્ઠ વસ્તુઓ પ્રદાન કરે છે."
            }
        }
    },
    {
        "id": 101545,
        "sloka": "10.15.45",
        "verse_id": 101545,
        "verseNumber": 45,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "By being bathed and massaged, the two young Lords were relieved of the weariness caused by walking on the country roads. Then They were dressed in attractive robes and decorated with transcendental garlands and fragrances."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "स्नान और मालिश से, दोनों युवा लॉर्ड्स को ग्रामीण सड़कों पर चलने के कारण होने वाली थकान से राहत मिली। फिर उन्हें आकर्षक वस्त्र पहनाए गए और दिव्य मालाओं और सुगंधियों से सजाया गया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "સ્નાન અને માલિશ કરીને, બંને યુવાન લોર્ડ્સ દેશના રસ્તાઓ પર ચાલવાથી થતા થાકમાંથી મુક્ત થયા. પછી તેઓ આકર્ષક ઝભ્ભો પહેર્યા હતા અને ગુણાતીત માળા અને સુગંધથી શણગારવામાં આવ્યા હતા."
            }
        }
    },
    {
        "id": 101546,
        "sloka": "10.15.46",
        "verse_id": 101546,
        "verseNumber": 46,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "After dining sumptuously on the delicious food given Them by Their mothers and being pampered in various ways, the two brothers lay down upon Their excellent beds and happily went to sleep in the village of Vraja."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपनी माताओं द्वारा दिए गए स्वादिष्ट भोजन पर शानदार भोजन करने और विभिन्न तरीकों से लाड़ प्यार करने के बाद, दोनों भाई अपने उत्कृष्ट बिस्तरों पर लेट गए और खुशी से व्रज गांव में सोने चले गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમની માતાઓ દ્વારા તેમને આપવામાં આવેલ સ્વાદિષ્ટ ભોજન પર ભરપૂર ભોજન કર્યા પછી અને વિવિધ રીતે લાડ લડાવવામાં આવ્યા પછી, બંને ભાઈઓ તેમના ઉત્તમ પથારી પર સૂઈ ગયા અને વ્રજ ગામમાં ખુશીથી સૂઈ ગયા."
            }
        }
    },
    {
        "id": 101547,
        "sloka": "10.15.47",
        "verse_id": 101547,
        "verseNumber": 47,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, the Supreme Lord Kṛṣṇa thus wandered about the Vṛndāvana area, performing His pastimes. Once, surrounded by His boyfriends, He went without Balarāma to the Yamunā River."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, परम भगवान कृष्ण इस प्रकार अपनी लीलाएँ करते हुए वृन्दावन क्षेत्र में घूमते रहे। एक बार, वह अपने मित्रों से घिरे हुए, बलराम के बिना यमुना नदी पर गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, પરમ ભગવાન કૃષ્ણ આ રીતે વૃંદાવન વિસ્તારમાં ભટકતા હતા, તેમના મનોરંજન કરતા હતા. એકવાર, તેમના બોયફ્રેન્ડ્સથી ઘેરાયેલા, તેઓ બલરામ વિના યમુના નદીમાં ગયા."
            }
        }
    },
    {
        "id": 101548,
        "sloka": "10.15.48",
        "verse_id": 101548,
        "verseNumber": 48,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "At that time the cows and cowherd boys were feeling acute distress from the glaring summer sun. Afflicted by thirst, they drank the water of the Yamunā River. But it had been contaminated with poison."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उस समय ग्रीष्म की तेज धूप से गायें और ग्वाल-बाल अत्यंत व्याकुल हो रहे थे। प्यास से व्याकुल होकर उन्होंने यमुना नदी का जल पिया। लेकिन वह जहर से दूषित हो चुका था।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે સમયે ગાયો અને ગોવાળિયાઓ ઉનાળાના ચમકદાર સૂર્યથી તીવ્ર તકલીફ અનુભવતા હતા. તરસથી પીડિત, તેઓએ યમુના નદીનું પાણી પીધું. પરંતુ તે ઝેરથી દૂષિત હતું."
            }
        }
    },
    {
        "id": 101549,
        "sloka": "10.15.49-50",
        "verse_id": 101549,
        "verseNumber": 49,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As soon as they touched the poisoned water, all the cows and boys lost their consciousness by the divine power of the Lord and fell lifeless at the water’s edge. O hero of the Kurus, seeing them in such a condition, Lord Kṛṣṇa, the master of all masters of mystic potency, felt compassion for these devotees, who had no Lord other than Him. Thus He immediately brought them back to life by showering His nectarean glance upon them."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जैसे ही उन्होंने जहरीले पानी को छुआ, भगवान की दिव्य शक्ति से सभी गायें और लड़के अपनी चेतना खो बैठे और पानी के किनारे बेजान होकर गिर पड़े। हे कौरवों के नायक, उन्हें ऐसी हालत में देखकर, सभी गुरुओं के गुरु, भगवान कृष्ण को इन भक्तों पर दया आ गई, जिनके पास उनके अलावा कोई भगवान नहीं था। इस प्रकार उन्होंने तुरंत उन पर अपनी अमृतमयी दृष्टि बरसाकर उन्हें पुनर्जीवित कर दिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ઝેરીલા પાણીને સ્પર્શતાની સાથે જ ભગવાનની દૈવી શક્તિથી તમામ ગાયો અને છોકરાઓ હોશ ગુમાવી બેઠા અને પાણીની ધાર પર નિર્જીવ પડી ગયા. હે કુરુઓના નાયક, તેમને આવી સ્થિતિમાં જોઈને, ભગવાન કૃષ્ણ, જે તમામ રહસ્યમય શક્તિના માસ્ટરના સ્વામી છે, તેમને આ ભક્તો માટે દયા આવી, જેમની પાસે તેમના સિવાય કોઈ ભગવાન નથી. આ રીતે તેમણે તરત જ તેમના પર તેમની અમૃત નજર નાખીને તેમને જીવંત કર્યા."
            }
        }
    },
    {
        "id": 101551,
        "sloka": "10.15.51",
        "verse_id": 101551,
        "verseNumber": 51,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Regaining their full consciousness, the cows and boys stood up out of the water and began to look at one another in great astonishment."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "अपनी पूर्ण चेतना प्राप्त करके, गायें और लड़के पानी से बाहर खड़े हो गए और बड़े आश्चर्य से एक-दूसरे को देखने लगे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમના સંપૂર્ણ હોશમાં આવ્યા પછી, ગાયો અને છોકરાઓ પાણીની બહાર ઉભા થયા અને ખૂબ જ આશ્ચર્યથી એકબીજાને જોવા લાગ્યા."
            }
        }
    },
    {
        "id": 101552,
        "sloka": "10.15.52",
        "verse_id": 101552,
        "verseNumber": 52,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O King, the cowherd boys then considered that although they had drunk poison and in fact had died, simply by the merciful glance of Govinda they had regained their lives and stood up by their own strength."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे राजन, तब चरवाहे लड़कों ने सोचा कि यद्यपि उन्होंने जहर पी लिया था और वास्तव में मर गए थे, लेकिन गोविंदा की दयालु दृष्टि से वे फिर से जीवित हो गए और अपनी ताकत से खड़े हो गए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે રાજા, ગોવાળો છોકરાઓએ વિચાર્યું કે જો કે તેઓએ ઝેર પીધું હતું અને વાસ્તવમાં તેઓ મૃત્યુ પામ્યા હતા, માત્ર ગોવિંદાની દયાળુ નજરથી તેઓએ તેમનું જીવન પાછું મેળવ્યું હતું અને પોતાની શક્તિથી ઉભા થયા હતા."
            }
        }
    }
]