        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The gopīs again came to the bank of the Kālindī. Meditating on Kṛṣṇa and eagerly hoping He would come, they sat down together to sing of Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "गोपियाँ फिर कालिंदी के तट पर आईं। कृष्ण का ध्यान करते हुए और उत्सुकता से उम्मीद करते हुए कि वह आएंगे, वे उनके भजन गाने के लिए एक साथ बैठ गए।"
            },
