[
    {
        "id": 103001,
        "sloka": "10.30.1",
        "verse_id": 103001,
        "verseNumber": 1,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: When Lord Kṛṣṇa disappeared so suddenly, the gopīs felt great sorrow at losing sight of Him, like a group of female elephants who have lost their mate."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: जब भगवान कृष्ण अचानक गायब हो गए, तो गोपियों को उनकी दृष्टि खोने पर बहुत दुःख हुआ, जैसे मादा हाथियों के समूह ने अपना साथी खो दिया हो।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: જ્યારે ભગવાન કૃષ્ણ આ રીતે અચાનક અદૃશ્ય થઈ ગયા, ત્યારે ગોપીઓએ તેમની દૃષ્ટિ ગુમાવવાનું ખૂબ જ દુ:ખ અનુભવ્યું, જેમ કે માદા હાથીઓના સમૂહ જેમણે પોતાનો સાથી ગુમાવ્યો છે."
            }
        }
    },
    {
        "id": 103002,
        "sloka": "10.30.2",
        "verse_id": 103002,
        "verseNumber": 2,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As the cowherd women remembered Lord Kṛṣṇa, their hearts were overwhelmed by His movements and loving smiles, His playful glances and enchanting talks, and by the many other pastimes He would enjoy with them. Thus absorbed in thoughts of Kṛṣṇa, the Lord of Ramā, the gopīs began acting out His various transcendental pastimes."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जैसे ही ग्वाल-बालों ने भगवान कृष्ण को याद किया, उनके हृदय उनकी गतिविधियों और प्रेमपूर्ण मुस्कान, उनकी चंचल दृष्टि और मंत्रमुग्ध करने वाली बातों और उनके साथ उनके द्वारा आनंदित की जाने वाली कई अन्य लीलाओं से अभिभूत हो गए। इस प्रकार राम के भगवान कृष्ण के विचारों में डूबकर गोपियाँ उनकी विभिन्न दिव्य लीलाएँ करने लगीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જેમ જેમ ગોવાળો સ્ત્રીઓ ભગવાન કૃષ્ણનું સ્મરણ કરતી હતી, તેમ તેમ તેમનું હૃદય તેમની હિલચાલ અને પ્રેમાળ સ્મિત, તેમની રમતિયાળ નજરો અને મોહક વાતોથી અભિભૂત થઈ ગયું હતું, અને અન્ય ઘણા મનોરંજનથી તેઓ તેમની સાથે આનંદ માણતા હતા. આ રીતે રામના ભગવાન કૃષ્ણના વિચારોમાં લીન થઈને, ગોપીઓએ તેમના વિવિધ દિવ્ય વિનોદની ક્રિયાઓ કરવાનું શરૂ કર્યું."
            }
        }
    },
    {
        "id": 103003,
        "sloka": "10.30.3",
        "verse_id": 103003,
        "verseNumber": 3,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Because the beloved gopīs were absorbed in thoughts of their beloved Kṛṣṇa, their bodies imitated His way of moving and smiling, His way of beholding them, His speech and His other distinctive features. Deeply immersed in thinking of Him and maddened by remembering His pastimes, they declared to one another, “I am Kṛṣṇa!”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "चूँकि प्रिय गोपियाँ अपने प्रिय कृष्ण के विचारों में लीन थीं, उनके शरीर उनके चलने और मुस्कुराने के तरीके, उन्हें देखने के तरीके, उनकी वाणी और उनकी अन्य विशिष्ट विशेषताओं की नकल करते थे। उनके बारे में गहराई से सोचने में डूबे हुए और उनकी लीलाओं को याद करके उन्मत्त होकर, वे एक-दूसरे से कहने लगे, \"मैं कृष्ण हूँ!\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કારણ કે પ્રિય ગોપીઓ તેમના પ્રિય કૃષ્ણના વિચારોમાં લીન હતી, તેમના શરીરે તેમની હલનચલન અને સ્મિત કરવાની રીત, તેમની તેમને જોવાની રીત, તેમની વાણી અને તેમના અન્ય વિશિષ્ટ લક્ષણોનું અનુકરણ કર્યું હતું. તેમના વિશે વિચારવામાં ઊંડે ડૂબેલા અને તેમના મનોરંજનને યાદ કરીને પાગલ થઈને, તેઓએ એકબીજાને જાહેર કર્યું, \"હું કૃષ્ણ છું!\""
            }
        }
    },
    {
        "id": 103004,
        "sloka": "10.30.4",
        "verse_id": 103004,
        "verseNumber": 4,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Singing loudly of Kṛṣṇa, they searched for Him throughout the Vṛndāvana forest like a band of madwomen. They even asked the trees about Him, who as the Supersoul is present inside and outside of all created things, just like the sky."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण का ऊँचे स्वर से गायन करते हुए, वे पागलों की टोली की तरह पूरे वृन्दावन वन में उन्हें ढूँढ़ने लगीं। उन्होंने पेड़ों से भी उसके बारे में पूछा, जो परमात्मा के रूप में आकाश की तरह सभी निर्मित चीजों के अंदर और बाहर मौजूद है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણના મોટેથી ગાતા, તેઓ પાગલ સ્ત્રીઓના ટોળાની જેમ વૃંદાવનના જંગલમાં તેમને શોધતા હતા. તેઓએ વૃક્ષોને પણ તેમના વિશે પૂછ્યું, જે આકાશની જેમ જ સર્વ સર્જિત વસ્તુઓની અંદર અને બહાર પરમાત્મા તરીકે હાજર છે."
            }
        }
    },
    {
        "id": 103005,
        "sloka": "10.30.5",
        "verse_id": 103005,
        "verseNumber": 5,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[The gopīs said:] O aśvattha tree, O plakṣa, O nyagrodha, have you seen Kṛṣṇa? That son of Nanda Mahārāja has gone away after stealing our minds with His loving smiles and glances."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[गोपियों ने कहा:] हे अश्वत्थ वृक्ष, हे प्लक्ष, हे न्यग्रोध, क्या तुमने कृष्ण को देखा है? नंद महाराज का वह पुत्र अपनी प्रेमपूर्ण मुस्कान और दृष्टि से हमारा मन चुराकर चला गया है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ગોપીઓએ કહ્યું:] હે અશ્વત્થ વૃક્ષ, ઓ પ્લાક્ષ, ઓ ન્યારોધ, શું તમે કૃષ્ણને જોયા છે? નંદ મહારાજનો તે પુત્ર તેમના પ્રેમાળ સ્મિત અને નજરોથી આપણું મન ચોરીને ચાલ્યો ગયો છે."
            }
        }
    },
    {
        "id": 103006,
        "sloka": "10.30.6",
        "verse_id": 103006,
        "verseNumber": 6,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O kurabaka tree, O aśoka, O nāga, punnāga and campaka, has Balarāma’s younger brother, whose smile removes the audacity of all proud women, passed this way?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे कुरबाक वृक्ष, हे अशोक, हे नाग, पुन्नाग और चंपक, क्या बलराम का छोटा भाई, जिसकी मुस्कान सभी घमंडी महिलाओं के साहस को दूर कर देती है, इस रास्ते से गुजरा है?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ઓ કુરાબક વૃક્ષ, ઓ અશોક, ઓ નાગ, પુન્નાગ અને કેમ્પક, શું બલરામનો નાનો ભાઈ, જેનું સ્મિત બધી ગૌરવવંતી સ્ત્રીઓની ધૈર્ય દૂર કરે છે, આ રીતે પસાર થયો છે?"
            }
        }
    },
    {
        "id": 103007,
        "sloka": "10.30.7",
        "verse_id": 103007,
        "verseNumber": 7,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O most kind tulasī, to whom the feet of Govinda are so dear, have you seen that infallible one walk by, wearing you and encircled by swarms of bees?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे अत्यंत दयालु तुलसी, जिन्हें गोविंद के चरण अत्यंत प्रिय हैं, क्या तुमने उस अचूक को तुम्हें अपने ऊपर धारण किए हुए और मधुमक्खियों के झुंड से घिरे हुए चलते हुए देखा है?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે પરમ કૃપાળુ તુલસી, જેને ગોવિંદના ચરણ અતિ પ્રિય છે, તેં તે અચૂકને તને ધારણ કરીને મધમાખીઓના ટોળાથી ઘેરાયેલો ચાલતો જોયો છે?"
            }
        }
    },
    {
        "id": 103008,
        "sloka": "10.30.8",
        "verse_id": 103008,
        "verseNumber": 8,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O mālati, O mallikā, O jāti and yūthikā, has Mādhava gone by here, giving you pleasure with the touch of His hand?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे मालती, हे मल्लिका, हे जाति और युथिका, क्या माधव तुम्हें अपने हाथ के स्पर्श से आनंद देकर यहाँ से चला गया है?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ઓ માલતી, ઓ મલ્લિકા, ઓ જાતિ અને યુતિકા, શું માધવ અહીંથી ચાલ્યો ગયો છે, તેના હાથના સ્પર્શથી તમને આનંદ થયો છે?"
            }
        }
    },
    {
        "id": 103009,
        "sloka": "10.30.9",
        "verse_id": 103009,
        "verseNumber": 9,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O cūta, O priyāla, O panasa, āsana and kovidāra, O jambu, O arka, O bilva, bakula and āmra, O kadamba and nīpa and all you other plants and trees living by the banks of the Yamunā who have dedicated your very existence to the welfare of others, we gopīs have lost our minds, so please tell us where Kṛṣṇa has gone."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे कूट, हे प्रियाल, हे पनासा, आसन और कोविदार, हे जम्बू, हे अर्क, हे बिल्व, बकुला और आम्र, हे कदम्ब और नीपा तथा आप सभी यमुना के किनारे रहने वाले पेड़-पौधे, जिन्होंने अपना अस्तित्व दूसरों के कल्याण के लिए समर्पित कर दिया है, हम गोपियों ने अपना दिमाग खो दिया है, इसलिए कृपया हमें बताएं कि कहां हैं कृष्ण चले गये."
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ઓ કુત, હે પ્રિયલ, ઓ પનાસ, આસન અને કોવિદાર, ઓ જંબુ, ઓ અરકા, ઓ બિલ્વ, બકુલ અને આમરા, ઓ કદંબા અને નીપ અને તમે યમુના કિનારે રહેતા અન્ય તમામ છોડ અને વૃક્ષો કે જેમણે તમારું અસ્તિત્વ અન્યના કલ્યાણ માટે સમર્પિત કર્યું છે, કૃપા કરીને અમને કહો કે આપણું મન ક્યાં ખોવાઈ ગયું છે. કૃષ્ણ ગયા છે."
            }
        }
    },
    {
        "id": 103010,
        "sloka": "10.30.10",
        "verse_id": 103010,
        "verseNumber": 10,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O mother earth, what austerity did you perform to attain the touch of Lord Keśava’s lotus feet, which has brought you such great joy that your bodily hairs are standing on end? You appear very beautiful in this condition. Was it during the Lord’s current appearance that you acquired this ecstatic symptom, or was it perhaps much earlier, when He stepped upon you in His form of the dwarf Vāmanadeva, or even earlier, when He embraced you in His form of the boar Varāhadeva?"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे धरती माता, भगवान केशव के चरण कमलों का स्पर्श पाने के लिए आपने कौन सी तपस्या की, जिससे आपको इतना आनंद मिला कि आपके शरीर के रोंगटे खड़े हो गए हैं? इस हालत में आप बेहद खूबसूरत लग रही हैं. क्या भगवान के वर्तमान स्वरूप के दौरान आपने यह परमानंद लक्षण प्राप्त किया था, या शायद यह बहुत पहले था, जब उन्होंने बौने वामनदेव के रूप में आप पर कदम रखा था, या उससे भी पहले, जब उन्होंने अपने सूअर वराहदेव के रूप में आपको गले लगाया था?"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે ધરતી માતા, ભગવાન કેશવના ચરણ કમળના સ્પર્શને પામવા માટે તેં કયું તપ કર્યું, જેનાથી તને એટલો આનંદ થયો કે તારા શરીરના વાળ ખરી રહ્યા છે? આ સ્થિતિમાં તમે ખૂબ જ સુંદર દેખાશો. શું ભગવાનના હાલના દેખાવ દરમિયાન તમે આ આનંદકારક લક્ષણ પ્રાપ્ત કર્યું હતું, અથવા કદાચ તે ખૂબ પહેલા હતું, જ્યારે તેમણે તેમના વામનદેવના રૂપમાં તમારા પર પગ મૂક્યો હતો, અથવા તેનાથી પણ પહેલા, જ્યારે તેમણે તમને તેમના ડુક્કર વરાહદેવના રૂપમાં આલિંગન આપ્યું હતું?"
            }
        }
    },
    {
        "id": 103011,
        "sloka": "10.30.11",
        "verse_id": 103011,
        "verseNumber": 11,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O friend, wife of the deer, has Lord Acyuta been here with His beloved, bringing great joy to your eyes? Indeed, blowing this way is the fragrance of His garland of kunda flowers, which was smeared with the kuṅkuma from the breasts of His girlfriend when He embraced Her."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे मित्र, हिरण की पत्नी, क्या भगवान अच्युत अपनी प्रेमिका के साथ यहाँ आये हैं, जिससे आपकी आँखों में बहुत खुशी आ रही है? दरअसल, इस तरह से उनकी कुंद फूलों की माला की सुगंध उड़ रही है, जो उनकी प्रेमिका के गले लगाने पर उनके स्तनों से निकले कुंकुमा से लगी हुई थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે મિત્ર, હરણની પત્ની, શું ભગવાન અચ્યુતા અહીં તેમના પ્રિય સાથે આવ્યા છે, તમારી આંખોમાં ખૂબ આનંદ લાવ્યા છે? ખરેખર, આ રીતે ફૂંકવું એ તેમની કુંડાના ફૂલોની માળાની સુગંધ છે, જે તેની પ્રેમિકાના છાતીમાંથી કુંકુમાથી મઢેલી હતી જ્યારે તેણે તેણીને ભેટી હતી."
            }
        }
    },
    {
        "id": 103012,
        "sloka": "10.30.12",
        "verse_id": 103012,
        "verseNumber": 12,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O trees, we see that you are bowing down. When the younger brother of Rāma walked by here, followed by intoxicated bees swarming around the tulasī mañjarīs decorating His garland, did He acknowledge your obeisances with His affectionate glances? He must have been resting His arm on the shoulder of His beloved and carrying a lotus flower in His free hand."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे वृक्षों, हम देख रहे हैं कि तुम झुक रहे हो। जब राम के छोटे भाई यहाँ से गुजर रहे थे और उनके पीछे-पीछे मदमस्त मधुमक्खियाँ उनकी माला सजा रही तुलसी मंजरी के चारों ओर घूम रही थीं, तो क्या उन्होंने अपनी स्नेह भरी दृष्टि से आपका प्रणाम स्वीकार किया था? वह अपनी बांह अपने प्रिय के कंधे पर रख रहा होगा और अपने खाली हाथ में कमल का फूल लिए हुए होगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "હે વૃક્ષો, અમે જોઈએ છીએ કે તમે નમસ્કાર કરો છો. જ્યારે રામનો નાનો ભાઈ અહીંથી ચાલતો હતો, અને તેની માળા સજાવીને તુલસી મંજરીઓની આસપાસ નશામાં મધમાખીઓનું ટોળું ફરતું હતું, ત્યારે શું તેમણે તેમની સ્નેહભરી નજરથી તમારા પ્રણામનો સ્વીકાર કર્યો હતો? તે પોતાના પ્રિયતમના ખભા પર પોતાનો હાથ મૂકીને પોતાના મુક્ત હાથમાં કમળનું ફૂલ લઈને ફરતો હોવો જોઈએ."
            }
        }
    },
    {
        "id": 103013,
        "sloka": "10.30.13",
        "verse_id": 103013,
        "verseNumber": 13,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Let us ask these creepers about Kṛṣṇa. Even though they are embracing the arms of their husband, this tree, they certainly must have been touched by Kṛṣṇa’s fingernails, since out of joy they are manifesting eruptions on their skin."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "आइए हम इन लताओं से कृष्ण के बारे में पूछें । भले ही वे अपने पति, इस वृक्ष की बाहों को गले लगा रही हैं, उन्हें निश्चित रूप से कृष्ण के नाखूनों ने छुआ होगा, क्योंकि खुशी से वे अपनी त्वचा पर दाने प्रकट कर रही हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ચાલો આ લતાઓને કૃષ્ણ વિશે પૂછીએ. તેમ છતાં તેઓ તેમના પતિ, આ વૃક્ષના હાથને આલિંગન કરી રહ્યાં છે, તેઓ ચોક્કસપણે કૃષ્ણના નખથી સ્પર્શ્યા હશે, કારણ કે આનંદથી તેઓ તેમની ચામડી પર વિસ્ફોટ પ્રગટ કરી રહ્યા છે."
            }
        }
    },
    {
        "id": 103014,
        "sloka": "10.30.14",
        "verse_id": 103014,
        "verseNumber": 14,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Having spoken these words, the gopīs, distraught from searching for Kṛṣṇa, began to act out His various pastimes, fully absorbed in thoughts of Him."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इन शब्दों को कहने के बाद, गोपियाँ, कृष्ण की खोज से व्याकुल होकर, उनके विचारों में पूरी तरह से लीन होकर, उनकी विभिन्न लीलाएँ करने लगीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ શબ્દો બોલ્યા પછી, ગોપીઓ, કૃષ્ણની શોધથી પરેશાન થઈને, તેમના વિચારોમાં સંપૂર્ણ રીતે લીન થઈને, તેમના વિવિધ મનોરંજન કરવા લાગી."
            }
        }
    },
    {
        "id": 103015,
        "sloka": "10.30.15",
        "verse_id": 103015,
        "verseNumber": 15,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "One gopī imitated Pūtanā, while another acted like infant Kṛṣṇa and pretended to suck her breast. Another gopī, crying in imitation of infant Kṛṣṇa, kicked a gopī who was taking the role of the cart demon, Śakaṭāsura."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक गोपी ने पूतना की नकल की, जबकि दूसरी ने शिशु कृष्ण की तरह अभिनय किया और उसके स्तन चूसने का नाटक किया। एक अन्य गोपी ने, शिशु कृष्ण की नकल में रोते हुए, एक गोपी को लात मार दी जो गाड़ी दानव शकटासुर की भूमिका निभा रही थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક ગોપીએ પૂતનાનું અનુકરણ કર્યું, જ્યારે બીજીએ શિશુ કૃષ્ણ જેવું વર્તન કર્યું અને તેના સ્તન ચૂસવાનો ઢોંગ કર્યો. અન્ય એક ગોપી, શિશુ કૃષ્ણની નકલમાં રડતી, એક ગોપીને લાત મારી, જે કાર્ટ રાક્ષસ, શકટાસુરની ભૂમિકા ભજવી રહી હતી."
            }
        }
    },
    {
        "id": 103016,
        "sloka": "10.30.16",
        "verse_id": 103016,
        "verseNumber": 16,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "One gopī took the role of Tṛṇāvarta and carried away another, who was acting like infant Kṛṣṇa, while yet another gopī crawled about, her ankle bells tinkling as she pulled her feet."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक गोपी ने तृणावर्त की भूमिका निभाई और दूसरी को अपने साथ ले गई, जो शिशु कृष्ण की तरह अभिनय कर रही थी, जबकि एक अन्य गोपी रेंगती रही, जब वह अपने पैर खींचती थी तो उसके पायल की घंटियाँ बजती थीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક ગોપીએ તૃણાવર્તની ભૂમિકા ભજવી અને બીજી ગોપીને લઈ ગઈ, જે શિશુ કૃષ્ણની જેમ વર્તી રહી હતી, જ્યારે બીજી ગોપી આજુબાજુ રડી રહી હતી, જ્યારે તેણીએ તેના પગ ખેંચ્યા ત્યારે તેણીની ઘૂંટીની ઘંટડી ધ્રૂજી રહી હતી."
            }
        }
    },
    {
        "id": 103017,
        "sloka": "10.30.17",
        "verse_id": 103017,
        "verseNumber": 17,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Two gopīs acted like Rāma and Kṛṣṇa in the midst of several others, who took the role of cowherd boys. One gopī enacted Kṛṣṇa’s killing of the demon Vatsāsura, represented by another gopī, and a pair of gopīs acted out the killing of Bakāsura."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "दो गोपियों ने कई अन्य लोगों के बीच राम और कृष्ण की तरह अभिनय किया, जिन्होंने चरवाहे लड़कों की भूमिका निभाई। एक गोपी ने कृष्ण द्वारा राक्षस वत्सासुर के वध का अभिनय किया, जिसका प्रतिनिधित्व एक अन्य गोपी ने किया, और गोपियों की एक जोड़ी ने बकासुर के वध का अभिनय किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બે ગોપીઓએ અન્ય કેટલાક લોકોની વચ્ચે રામ અને કૃષ્ણની જેમ અભિનય કર્યો, જેમણે ગોવાળો છોકરાઓની ભૂમિકા ભજવી. એક ગોપીએ કૃષ્ણ દ્વારા રાક્ષસ વત્સાસુરને મારવાનો કાયદો ઘડ્યો હતો, જેનું પ્રતિનિધિત્વ બીજી ગોપી દ્વારા કરવામાં આવ્યું હતું, અને ગોપીઓની જોડીએ બકાસુરને મારવાનું કામ કર્યું હતું."
            }
        }
    },
    {
        "id": 103018,
        "sloka": "10.30.18",
        "verse_id": 103018,
        "verseNumber": 18,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "When one gopī perfectly imitated how Kṛṣṇa would call the cows who had wandered far away, how He would play His flute and how He would engage in various sports, the others congratulated her with exclamations of “Well done! Well done!”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब एक गोपी ने पूरी तरह से अनुकरण किया कि कृष्ण दूर भटकती गायों को कैसे बुलाते हैं, वह अपनी बांसुरी कैसे बजाते हैं और कैसे विभिन्न खेलों में संलग्न होते हैं, तो दूसरों ने उसे \"शाबाश! शाबाश!\" कहकर बधाई दी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે એક ગોપીએ સંપૂર્ણ રીતે અનુકરણ કર્યું કે કૃષ્ણ કેવી રીતે દૂર ભટકતી ગાયોને બોલાવશે, તે કેવી રીતે તેમની વાંસળી વગાડશે અને કેવી રીતે તે વિવિધ રમતોમાં વ્યસ્ત રહેશે, ત્યારે અન્ય લોકોએ તેણીને \"શાબાશ! શાબાશ!\" ના ઉદ્ગારો સાથે અભિનંદન આપ્યા."
            }
        }
    },
    {
        "id": 103019,
        "sloka": "10.30.19",
        "verse_id": 103019,
        "verseNumber": 19,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Another gopī, her mind fixed on Kṛṣṇa, walked about with her arm resting on the shoulder of a friend and declared, “I am Kṛṣṇa! Just see how gracefully I move!”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक अन्य गोपी, जिसका मन कृष्ण पर केंद्रित था, अपने मित्र के कंधे पर हाथ रखकर घूम रही थी और घोषणा कर रही थी, \"मैं कृष्ण हूँ! बस देखो मैं कितनी खूबसूरती से चलती हूँ!\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "બીજી ગોપી, તેનું મન કૃષ્ણ પર સ્થિર હતું, તેનો હાથ મિત્રના ખભા પર રાખીને ચાલ્યો ગયો અને જાહેર કર્યું, \"હું કૃષ્ણ છું! જરા જુઓ કે હું કેટલી સુંદર રીતે આગળ વધી રહ્યો છું!\""
            }
        }
    },
    {
        "id": 103020,
        "sloka": "10.30.20",
        "verse_id": 103020,
        "verseNumber": 20,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "“Don’t be afraid of the wind and rain,” said one gopī. “I will save you.” And with that she lifted her shawl above her head."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक गोपी ने कहा, \"हवा और बारिश से मत डरो।\" \"मैं तुम्हें बचाऊंगा।\" और इसके साथ ही उसने अपना शॉल अपने सिर के ऊपर उठा लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "\"પવન અને વરસાદથી ડરશો નહીં,\" એક ગોપીએ કહ્યું. \"હું તને બચાવીશ.\" અને તે સાથે તેણીએ તેણીની શાલ તેના માથા ઉપર ઉંચી કરી."
            }
        }
    },
    {
        "id": 103021,
        "sloka": "10.30.21",
        "verse_id": 103021,
        "verseNumber": 21,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Śukadeva Gosvāmī continued:] O King, one gopī climbed on another’s shoulders and, putting her foot on the other’s head, said, “Go away from here, O wicked snake! You should know that I have taken birth in this world just to punish the envious.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[शुकदेव गोस्वामी ने आगे कहा:] हे राजन, एक गोपी दूसरे के कंधे पर चढ़ गई और अपना पैर दूसरे के सिर पर रखकर बोली, \"यहाँ से चले जाओ, हे दुष्ट साँप! तुम्हें पता होना चाहिए कि मैंने ईर्ष्यालु लोगों को दंडित करने के लिए ही इस दुनिया में जन्म लिया है।\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[શુકદેવ ગોસ્વામીએ આગળ કહ્યું:] હે રાજા, એક ગોપી બીજાના ખભા પર ચડી અને, બીજાના માથા પર પગ મૂકીને બોલી, \"હે દુષ્ટ સાપ, અહીંથી ચાલ્યા જાઓ, તમારે જાણવું જોઈએ કે મેં ઈર્ષ્યા કરનારાઓને સજા કરવા માટે જ આ જગતમાં જન્મ લીધો છે.\""
            }
        }
    },
    {
        "id": 103022,
        "sloka": "10.30.22",
        "verse_id": 103022,
        "verseNumber": 22,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Then another gopī spoke up: My dear cowherd boys, look at this raging forest fire! Quickly close your eyes and I will easily protect you."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "तभी एक अन्य गोपी बोली: मेरे प्यारे ग्वालबालों, इस भड़कती हुई जंगल की आग को देखो! जल्दी से अपनी आँखें बंद करो और मैं आसानी से तुम्हारी रक्षा करूँगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "પછી બીજી ગોપી બોલી: મારા વહાલા ગોવાળિયાઓ, જંગલની આ આગને જુઓ! ઝડપથી તમારી આંખો બંધ કરો અને હું તમને સરળતાથી સુરક્ષિત કરીશ."
            }
        }
    },
    {
        "id": 103023,
        "sloka": "10.30.23",
        "verse_id": 103023,
        "verseNumber": 23,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "One gopī tied up her slender companion with a flower garland and said, “Now I will bind this boy who has broken the butter pots and stolen the butter.” The second gopī then covered her face and beautiful eyes, pretending to be afraid."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "एक गोपी ने अपने दुबले-पतले साथी को फूलों की माला से बांध दिया और कहा, \"अब मैं इस लड़के को बांधूंगी जिसने मक्खन की मटकी तोड़ दी है और मक्खन चुरा लिया है।\" तब दूसरी गोपी ने डरने का नाटक करते हुए अपना चेहरा और सुंदर आँखें ढँक लीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "એક ગોપીએ તેના પાતળી સાથીને ફૂલની માળાથી બાંધી દીધી અને કહ્યું, \"હવે હું આ છોકરાને બાંધીશ જેણે માખણની વાસણ તોડી નાખી છે અને માખણ ચોરી લીધું છે.\" બીજી ગોપીએ પછી ભયનો ઢોંગ કરીને પોતાનો ચહેરો અને સુંદર આંખો ઢાંકી દીધી."
            }
        }
    },
    {
        "id": 103024,
        "sloka": "10.30.24",
        "verse_id": 103024,
        "verseNumber": 24,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "While the gopīs were thus imitating Kṛṣṇa’s pastimes and asking Vṛndāvana’s creepers and trees where Kṛṣṇa, the Supreme Soul, might be, they happened to see His footprints in a corner of the forest."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जब गोपियाँ इस प्रकार कृष्ण की लीलाओं का अनुकरण कर रही थीं और वृन्दावन की लताओं और पेड़ों से पूछ रही थीं कि कृष्ण, परम आत्मा, कहाँ हो सकते हैं, तो उन्हें जंगल के एक कोने में उनके पैरों के निशान दिखाई दिए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે ગોપીઓ આ રીતે કૃષ્ણના મનોરંજનનું અનુકરણ કરી રહી હતી અને વૃંદાવનના લતા અને વૃક્ષોને પૂછી રહી હતી કે કૃષ્ણ, પરમાત્મા ક્યાં હોઈ શકે છે, ત્યારે તેમને જંગલના એક ખૂણામાં તેમના પગના નિશાન જોવા મળ્યા."
            }
        }
    },
    {
        "id": 103025,
        "sloka": "10.30.25",
        "verse_id": 103025,
        "verseNumber": 25,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[The gopīs said:] The marks of a flag, lotus, thunderbolt, elephant goad, barleycorn and so forth on these footprints clearly distinguish them as belonging to that great soul, the son of Nanda Mahārāja."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[गोपियों ने कहा:] इन पदचिह्नों पर ध्वज, कमल, वज्र, हाथी अंकुश, जौ आदि के निशान स्पष्ट रूप से उन्हें उस महान आत्मा, नंद महाराज के पुत्र के रूप में पहचानते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ગોપીઓએ કહ્યું:] આ પગના નિશાનો પર ધ્વજ, કમળ, વીજળી, હાથીનો ગોડો, જવના દાણા વગેરેના ચિહ્નો સ્પષ્ટપણે તેમને તે મહાન આત્માના, નંદ મહારાજના પુત્ર તરીકે ઓળખે છે."
            }
        }
    },
    {
        "id": 103026,
        "sloka": "10.30.26",
        "verse_id": 103026,
        "verseNumber": 26,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "The gopīs began following Kṛṣṇa’s path, as shown by His many footprints, but when they saw that these prints were thoroughly intermixed with those of His dearmost consort, they became perturbed and spoke as follows."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "गोपियों ने कृष्ण के मार्ग का अनुसरण करना शुरू कर दिया, जैसा कि उनके कई पदचिह्नों से पता चलता है, लेकिन जब उन्होंने देखा कि ये पदचिह्न उनकी सबसे प्रिय पत्नी के पदचिन्हों के साथ पूरी तरह से मिश्रित हो गए हैं, तो वे परेशान हो गईं और इस प्रकार बोलीं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ગોપીઓએ કૃષ્ણના માર્ગનું અનુસરણ કરવાનું શરૂ કર્યું, જેમ કે તેમના અનેક પદચિહ્નો દ્વારા દર્શાવવામાં આવ્યું છે, પરંતુ જ્યારે તેઓએ જોયું કે આ છાપો તેમની સૌથી પ્રિય પત્નીની સાથે સંપૂર્ણ રીતે ભળી ગયા છે, ત્યારે તેઓ અસ્વસ્થ થઈ ગયા અને નીચે પ્રમાણે બોલ્યા."
            }
        }
    },
    {
        "id": 103027,
        "sloka": "10.30.27",
        "verse_id": 103027,
        "verseNumber": 27,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[The gopīs said:] Here we see the footprints of some gopī who must have been walking along with the son of Nanda Mahārāja. He must have put His arm on Her shoulder, just as an elephant rests His trunk on the shoulder of an accompanying she-elephant."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[गोपियों ने कहा:] यहां हमें कुछ गोपी के पैरों के निशान दिखाई देते हैं जो नंद महाराज के पुत्र के साथ चल रहे होंगे। उसने अपना हाथ उसके कंधे पर रखा होगा, जैसे एक हाथी अपनी सूंड अपने साथ चल रही हथिनी के कंधे पर रखता है।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[ગોપીઓએ કહ્યું:] અહીં આપણે કેટલીક ગોપીઓના પગના નિશાન જોઈએ છીએ જેઓ નંદ મહારાજના પુત્ર સાથે ચાલતા હોવા જોઈએ. તેણે તેનો હાથ તેના ખભા પર મૂક્યો હોવો જોઈએ, જેમ એક હાથી તેની થડ તેની સાથે આવતી તેણી-હાથીના ખભા પર રાખે છે."
            }
        }
    },
    {
        "id": 103028,
        "sloka": "10.30.28",
        "verse_id": 103028,
        "verseNumber": 28,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Certainly this particular gopī has perfectly worshiped the all-powerful Personality of Godhead, Govinda, since He was so pleased with Her that He abandoned the rest of us and brought Her to a secluded place."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "निश्चित रूप से इस विशेष गोपी ने भगवान गोविंद के सर्वशक्तिमान व्यक्तित्व की पूरी तरह से पूजा की है, क्योंकि वह उससे इतने प्रसन्न थे कि उन्होंने हममें से बाकी लोगों को त्याग दिया और उन्हें एक एकांत स्थान पर ले आए।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ચોક્કસપણે આ ખાસ ગોપીએ ભગવાનના સર્વશક્તિમાન વ્યક્તિત્વ, ગોવિંદની સંપૂર્ણ રીતે પૂજા કરી છે, કારણ કે તે તેના પર એટલો પ્રસન્ન હતો કે તેણે અમને બાકીનાને છોડી દીધા અને તેણીને એકાંત સ્થાન પર લાવ્યા."
            }
        }
    },
    {
        "id": 103029,
        "sloka": "10.30.29",
        "verse_id": 103029,
        "verseNumber": 29,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "O girls! The dust of Govinda’s lotus feet is so sacred that even Brahmā, Śiva and the goddess Ramā take that dust upon their heads to dispel sinful reactions."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "हे लड़कियो! गोविंदा के चरण कमलों की धूल इतनी पवित्र है कि ब्रह्मा, शिव और देवी राम भी पापपूर्ण प्रतिक्रियाओं को दूर करने के लिए उस धूल को अपने सिर पर लेते हैं।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ઓ છોકરીઓ! ગોવિંદના કમળના પગની ધૂળ એટલી પવિત્ર છે કે બ્રહ્મા, શિવ અને દેવી રામ પણ તે ધૂળને પાપી પ્રતિક્રિયાઓને દૂર કરવા માટે તેમના માથા પર લે છે."
            }
        }
    },
    {
        "id": 103030,
        "sloka": "10.30.30",
        "verse_id": 103030,
        "verseNumber": 30,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "These footprints of that special gopī greatly disturb us. Of all the gopīs, She alone was taken away to a secluded place, where She is enjoying the lips of Kṛṣṇa. Look, we can’t see Her footprints over here! It’s obvious that the grass and sprouts were hurting the tender soles of Her feet, and so the lover lifted up His beloved."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उस विशेष गोपी के ये पैरों के निशान हमें बहुत परेशान करते हैं। सभी गोपियों में से, वह अकेली थी जिसे एक एकांत स्थान पर ले जाया गया, जहाँ वह कृष्ण के होठों का आनंद ले रही थी। देखो, हम यहाँ उसके पैरों के निशान नहीं देख सकते हैं! यह स्पष्ट है कि घास और अंकुर उसके पैरों के कोमल तलवों को चोट पहुँचा रहे थे, और इसलिए प्रेमी ने अपनी प्रेमिका को ऊपर उठा लिया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તે વિશેષ ગોપીના આ પગના નિશાન આપણને ખૂબ જ પરેશાન કરે છે. બધી ગોપીઓમાંથી, તેણીને એકાંતમાં લઈ જવામાં આવી હતી, જ્યાં તે કૃષ્ણના હોઠનો આનંદ માણી રહી છે. જુઓ, અમે અહીં તેના પગના ચિહ્નો જોઈ શકતા નથી! તે સ્પષ્ટ છે કે ઘાસ અને સ્પ્રાઉટ્સ તેના પગના નાજુક તળિયાને નુકસાન પહોંચાડી રહ્યા હતા, અને તેથી પ્રેમીએ તેના પ્રિયને ઉપાડ્યો."
            }
        }
    },
    {
        "id": 103031,
        "sloka": "10.30.31",
        "verse_id": 103031,
        "verseNumber": 31,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Please observe, my dear gopīs, how in this place lusty Kṛṣṇa’s footprints are pressed more deeply into the ground. Carrying the weight of His beloved must have been difficult for Him. And over here that intelligent boy must have put Her down to gather some flowers."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृपया ध्यान दें, मेरी प्रिय गोपियों, कैसे इस स्थान पर कामातुर कृष्ण के पदचिह्न जमीन में अधिक गहराई तक दबे हुए हैं। अपने प्रिय का भार उठाना उसके लिए कठिन रहा होगा। और यहाँ पर उस बुद्धिमान लड़के ने कुछ फूल इकट्ठा करने के लिए उसे नीचे रखा होगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "મહેરબાની કરીને અવલોકન કરો, મારા પ્રિય ગોપીઓ, કેવી રીતે આ સ્થાનમાં કૃષ્ણના પદચિહ્નો જમીનમાં વધુ ઊંડે દબાયેલા છે. તેના પ્રિયનું વજન વહન કરવું તેના માટે મુશ્કેલ હતું. અને અહીં તે બુદ્ધિશાળી છોકરાએ તેને કેટલાક ફૂલો ભેગા કરવા માટે નીચે મૂક્યા હશે."
            }
        }
    },
    {
        "id": 103032,
        "sloka": "10.30.32",
        "verse_id": 103032,
        "verseNumber": 32,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Just see how in this place dear Kṛṣṇa collected flowers for His beloved. Here He has left the impression of only the front part of His feet because He was standing on His toes to reach the flowers."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जरा देखिए कि कैसे इस स्थान पर प्रिय कृष्ण ने अपने प्रिय के लिए फूल एकत्र किए। यहां उन्होंने केवल अपने पैरों के अगले हिस्से की छाप छोड़ी है क्योंकि वह फूलों तक पहुंचने के लिए अपने पैर की उंगलियों पर खड़े थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જરા જુઓ કે કેવી રીતે આ જગ્યાએ પ્રિય કૃષ્ણે તેમના પ્રિય માટે ફૂલો એકઠા કર્યા. અહીં તેણે તેના પગના આગળના ભાગની જ છાપ છોડી દીધી છે કારણ કે તે ફૂલો સુધી પહોંચવા માટે તેના અંગૂઠા પર ઊભો હતો."
            }
        }
    },
    {
        "id": 103033,
        "sloka": "10.30.33",
        "verse_id": 103033,
        "verseNumber": 33,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Certainly Kṛṣṇa sat down here with His girlfriend to arrange Her hair. The lusty boy must have made a crown for that lusty girl out of the flowers He had collected."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "निश्चित रूप से कृष्ण अपनी प्रेमिका के साथ उसके बाल व्यवस्थित करने के लिए यहां बैठे थे। कामातुर लड़के ने अपने द्वारा एकत्र किए गए फूलों से उस कामातुर लड़की के लिए एक मुकुट बनाया होगा।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "ચોક્કસપણે કૃષ્ણ અહીં તેની ગર્લફ્રેન્ડ સાથે તેના વાળ ગોઠવવા બેઠા હતા. લંપટ છોકરાએ તે લંપટ છોકરી માટે તેણે ભેગા કરેલા ફૂલોમાંથી તાજ બનાવ્યો હશે."
            }
        }
    },
    {
        "id": 103034,
        "sloka": "10.30.34",
        "verse_id": 103034,
        "verseNumber": 34,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "[Śukadeva Gosvāmī continued:] Lord Kṛṣṇa enjoyed with that gopī, although He enjoys only within, being self-satisfied and complete in Himself. Thus by contrast He showed the wretchedness of ordinary lusty men and hardhearted women."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "[शुकदेव गोस्वामी ने आगे कहा:] भगवान कृष्ण ने उस गोपी के साथ आनंद लिया, हालांकि वे आत्म-संतुष्ट और स्वयं में पूर्ण होकर, केवल भीतर ही आनंद लेते थे। इस प्रकार इसके विपरीत उन्होंने सामान्य कामुक पुरुषों और कठोर हृदय वाली महिलाओं की दयनीयता को दिखाया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "[શુકદેવ ગોસ્વામીએ ચાલુ રાખ્યું:] ભગવાન કૃષ્ણએ તે ગોપી સાથે આનંદ માણ્યો, જો કે તે માત્ર અંદર જ આનંદ લે છે, આત્મસંતુષ્ટ અને પોતાનામાં સંપૂર્ણ છે. આમ તેનાથી વિપરિત તેમણે સામાન્ય લંપટ પુરૂષો અને કઠોર મહિલાઓની દુ:ખીતા દર્શાવી."
            }
        }
    },
    {
        "id": 103035,
        "sloka": "10.30.35-36",
        "verse_id": 103035,
        "verseNumber": 35,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As the gopīs wandered about, their minds completely bewildered, they pointed out various signs of Kṛṣṇa’s pastimes. The particular gopī whom Kṛṣṇa had led into a secluded forest when He had abandoned all the other young girls began to think Herself the best of women. “My beloved has rejected all the other gopīs,” She thought, “even though they are driven by Cupid himself. He has chosen to reciprocate with Me alone.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जैसे-जैसे गोपियाँ इधर-उधर घूमती रहीं, उनका मन पूरी तरह से भ्रमित हो गया, उन्होंने कृष्ण की लीलाओं के विभिन्न संकेत बताए। वह विशेष गोपी जिसे कृष्ण एकांत जंगल में ले गए थे जब उन्होंने अन्य सभी युवा लड़कियों को छोड़ दिया था, वह खुद को सर्वश्रेष्ठ महिलाओं में समझने लगी थी। \"मेरे प्रिय ने अन्य सभी गोपियों को अस्वीकार कर दिया है,\" उसने सोचा, \"भले ही वे स्वयं कामदेव द्वारा संचालित हों। उन्होंने अकेले मेरे साथ प्रतिशोध लेने का विकल्प चुना है।\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જેમ જેમ ગોપીઓ ભટકતી હતી, તેમ તેમ તેમનું મન સંપૂર્ણ રીતે વિચલિત થઈ ગયું હતું, તેઓએ કૃષ્ણના મનોરંજનના વિવિધ ચિહ્નો દર્શાવ્યા હતા. ખાસ ગોપી જેમને કૃષ્ણ એકાંત વનમાં લઈ ગયા હતા જ્યારે તેમણે અન્ય તમામ યુવતીઓને ત્યજી દીધી હતી તે પોતાની જાતને સ્ત્રીઓમાં શ્રેષ્ઠ માનવા લાગી. તેણીએ વિચાર્યું, \"મારા પ્રિયે અન્ય તમામ ગોપીઓનો અસ્વીકાર કર્યો છે,\" ભલે તેઓ પોતે કામદેવ દ્વારા ચલાવવામાં આવે છે. તેણે એકલા મારી સાથે બદલો લેવાનું પસંદ કર્યું છે.\""
            }
        }
    },
    {
        "id": 103037,
        "sloka": "10.30.37",
        "verse_id": 103037,
        "verseNumber": 37,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "As the two lovers passed through one part of the Vṛndāvana forest, the special gopī began feeling proud of Herself. She told Lord Keśava, “I cannot walk any further. Please carry Me wherever You want to go.”"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "जैसे ही दोनों प्रेमी वृन्दावन वन के एक हिस्से से गुजरे, विशेष गोपी को खुद पर गर्व महसूस होने लगा। उसने भगवान केशव से कहा, \"मैं अब और नहीं चल सकती। आप जहां भी जाना चाहें, कृपया मुझे ले चलें।\""
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "જ્યારે બે પ્રેમીઓ વૃંદાવન જંગલના એક ભાગમાં પસાર થયા, ત્યારે વિશેષ ગોપી પોતાના પર ગર્વ અનુભવવા લાગી. તેણીએ ભગવાન કેશવને કહ્યું, \"હું આગળ ચાલી શકતી નથી. તમે જ્યાં જવા માંગતા હો ત્યાં કૃપા કરીને મને લઈ જાઓ.\""
            }
        }
    },
    {
        "id": 103038,
        "sloka": "10.30.38",
        "verse_id": 103038,
        "verseNumber": 38,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Thus addressed, Lord Kṛṣṇa replied, “Just climb on My shoulder.” But as soon as He said this, He disappeared. His beloved consort then immediately felt great remorse."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "इस प्रकार संबोधित करते हुए, भगवान कृष्ण ने उत्तर दिया, \"बस मेरे कंधे पर चढ़ो।\" लेकिन जैसे ही उन्होंने यह कहा, वह गायब हो गये। तब उसकी प्रिय पत्नी को तुरंत बहुत पश्चाताप हुआ।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "આ રીતે સંબોધીને, ભગવાન કૃષ્ણએ જવાબ આપ્યો, \"મારા ખભા પર ચઢી જા.\" પણ આટલું કહેતાં જ તે ગાયબ થઈ ગયો. તેની પ્રિય પત્નીએ તરત જ ભારે પસ્તાવો અનુભવ્યો."
            }
        }
    },
    {
        "id": 103039,
        "sloka": "10.30.39",
        "verse_id": 103039,
        "verseNumber": 39,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "She cried out: O master! My lover! O dearmost, where are You? Where are You? Please, O mighty-armed one, O friend, show Yourself to Me, Your poor servant!"
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "वह चिल्ला उठी: हे स्वामी! मेरे प्रेमी! हे प्रियतम, तुम कहाँ हो? आप कहां हैं? कृपया, हे महाबाहु, हे मित्र, अपने आप को मुझे, अपने गरीब सेवक को दिखाओ!"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેણીએ બૂમ પાડી: ઓ ધણી! મારા પ્રેમી! હે સૌથી પ્રિય, તમે ક્યાં છો? તમે ક્યાં છો? કૃપા કરીને, હે પરાક્રમી શસ્ત્રધારી, હે મિત્ર, તમારી જાતને મને બતાવો, તમારા ગરીબ સેવક!"
            }
        }
    },
    {
        "id": 103040,
        "sloka": "10.30.40",
        "verse_id": 103040,
        "verseNumber": 40,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Śukadeva Gosvāmī said: While continuing to search out Kṛṣṇa’s path, the gopīs discovered their unhappy friend close by. She was bewildered by separation from Her lover."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "शुकदेव गोस्वामी ने कहा: कृष्ण के मार्ग की खोज जारी रखते हुए, गोपियों ने अपने दुखी मित्र को निकट ही पाया। वह अपने प्रेमी के वियोग से व्याकुल थी।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "શુકદેવ ગોસ્વામીએ કહ્યું: કૃષ્ણના માર્ગની શોધ ચાલુ રાખતી વખતે, ગોપીઓએ તેમના દુ:ખી મિત્રને નજીકમાં શોધી કાઢ્યો. તેણી તેના પ્રેમીથી અલગ થવાથી હેરાન થઈ ગઈ હતી."
            }
        }
    },
    {
        "id": 103041,
        "sloka": "10.30.41",
        "verse_id": 103041,
        "verseNumber": 41,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "She told them how Mādhava had given Her much respect, but how She then suffered dishonor because of Her misbehavior. The gopīs were extremely amazed to hear this."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उसने उन्हें बताया कि कैसे माधव ने उसे बहुत सम्मान दिया था, लेकिन फिर उसके दुर्व्यवहार के कारण उसे कैसे अपमान सहना पड़ा। यह सुनकर गोपियों को अत्यंत आश्चर्य हुआ।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેણીએ તેમને કહ્યું કે કેવી રીતે માધવે તેણીને ખૂબ માન આપ્યું હતું, પરંતુ તેણીએ કેવી રીતે તેણીના ગેરવર્તણૂકને કારણે અપમાન સહન કર્યું. આ સાંભળીને ગોપીઓ અત્યંત આશ્ચર્યચકિત થઈ ગઈ."
            }
        }
    },
    {
        "id": 103042,
        "sloka": "10.30.42",
        "verse_id": 103042,
        "verseNumber": 42,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "In search of Kṛṣṇa, the gopīs then entered the depths of the forest as far as the light of the moon shone. But when they found themselves engulfed in darkness, they decided to turn back."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "कृष्ण की तलाश में, गोपियाँ जंगल की गहराई तक प्रवेश कर गईं जहाँ तक चंद्रमा की रोशनी चमक रही थी। लेकिन जब उन्होंने खुद को अंधेरे में घिरा हुआ पाया तो उन्होंने वापस लौटने का फैसला किया।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "કૃષ્ણની શોધમાં, ગોપીઓ પછી ચંદ્રનો પ્રકાશ ચમક્યો ત્યાં સુધી જંગલના ઊંડાણમાં પ્રવેશ કર્યો. પરંતુ જ્યારે તેઓ પોતાને અંધકારમાં ડૂબેલા જણાયા, ત્યારે તેઓએ પાછા ફરવાનું નક્કી કર્યું."
            }
        }
    },
    {
        "id": 103043,
        "sloka": "10.30.43",
        "verse_id": 103043,
        "verseNumber": 43,
        "languages": {
            "english": {
                "language_id": 1,
                "lang": "english",
                "description": "Their minds absorbed in thoughts of Him, they conversed about Him, acted out His pastimes and felt themselves filled with His presence. They completely forgot about their homes as they loudly sang the glories of Kṛṣṇa’s transcendental qualities."
            },
            "hindi": {
                "language_id": 2,
                "lang": "hindi",
                "description": "उनके मन उनके विचारों में डूबे हुए थे, वे उनके बारे में बातचीत करते थे, उनकी लीलाएँ करते थे और स्वयं को उनकी उपस्थिति से भरा हुआ महसूस करते थे। वे अपने घरों के बारे में पूरी तरह से भूल गए क्योंकि वे जोर-जोर से कृष्ण के दिव्य गुणों की महिमा गाते थे।"
            },
            "gujarati": {
                "language_id": 3,
                "lang": "gujarati",
                "description": "તેમના મન તેમના વિચારોમાં સમાઈ ગયા, તેઓએ તેમના વિશે વાતચીત કરી, તેમના મનોરંજનનો અભિનય કર્યો અને પોતાને તેમની હાજરીથી ભરપૂર અનુભવ્યું. તેઓ તેમના ઘર વિશે સંપૂર્ણપણે ભૂલી ગયા કારણ કે તેઓ મોટેથી કૃષ્ણના દિવ્ય ગુણોનો મહિમા ગાતા હતા."
            }
        }
    },
    {
        "id": 103044,
